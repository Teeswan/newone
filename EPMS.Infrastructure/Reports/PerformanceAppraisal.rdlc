          <!-- Footer Section with Remarks and Signatures -->
          <Textbox Name="OtherRemarks"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Other remarks:&#13;&#10;Appraiser's Comment for Discussion;</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>9.1in</Top><Height>0.5in</Height><Width>7.5in</Width></Textbox>
          <Textbox Name="SignLine1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>--------------------------------------------------------------------------------------------------------------------------------------------------</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>10.0in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>
          <Textbox Name="SignLabels1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Signature of Appraisee &amp;amp; Date                                                    Signature of Appraiser &amp;amp; Date</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>10.2in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>
          
          <Textbox Name="ReviewBy"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Review by</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>10.6in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>
          
          <Textbox Name="SignLine2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>________________________</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>11.3in</Top><Height>0.2in</Height><Width>3in</Width></Textbox>
