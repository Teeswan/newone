<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="EPMS">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>performance-appraisal-ds</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Responses">
      <Query>
        <DataSourceName>EPMS</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="QuestionCategory"><DataField>QuestionCategory</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SortOrder"><DataField>SortOrder</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="QuestionText"><DataField>QuestionText</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RatingValue"><DataField>RatingValue</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="AnswerText"><DataField>AnswerText</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RespondentName"><DataField>RespondentName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RespondentRole"><DataField>RespondentRole</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RespondentPosition"><DataField>RespondentPosition</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RespondentDepartment"><DataField>RespondentDepartment</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <!-- Top Title Bar -->
          <Textbox Name="MainTitle">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Performance Appraisal Form</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Height>0.3in</Height><Width>7.5in</Width>
            <Style><BackgroundColor>#FDE9D9</BackgroundColor><PaddingLeft>5pt</PaddingLeft><VerticalAlign>Middle</VerticalAlign></Style>
          </Textbox>

          <!-- Center Headers -->
          <Textbox Name="SubHeader">
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Performance Evaluation Form</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>ACE Data Systems Ltd.,</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
            </Paragraphs>
            <Top>0.4in</Top><Height>0.4in</Height><Width>7.5in</Width>
          </Textbox>

          <!-- Employee Info Table -->
          <Tablix Name="TablixEmployeeInfo">
            <TablixBody>
              <TablixColumns><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>6.0in</Width></TablixColumn></TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblEmpName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Employee Name :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValEmpName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!EmployeeName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblEmpId"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Employee ID :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValEmpId"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!EmployeeCode.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblPos"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Current Position :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValPos"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!PositionTitle.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblDept"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Department :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValDept"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!DepartmentName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblAssDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Assessment Date :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValAssDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!AssessmentDate.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.2in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="LblEffDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Effective Date :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="ValEffDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!EffectiveDate.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixRowHierarchy>
            <Top>0.9in</Top><Height>1.2in</Height><Width>7.5in</Width>
          </Tablix>

          <!-- Evaluation Section Title -->
          <Textbox Name="LblEvaluation"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Evaluation</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>2.2in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>

          <!-- List to repeat per Evaluator (Manager/Supervisor) -->
          <Tablix Name="ListEvaluators">
            <TablixBody>
              <TablixColumns><TablixColumn><Width>7.5in</Width></TablixColumn></TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>2.5in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="RectEval">
                          <ReportItems>
                            <!-- Evaluator Info Table -->
                            <Tablix Name="EvalInfoGrid">
                              <TablixBody>
                                <TablixColumns><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>6.0in</Width></TablixColumn></TablixColumns>
                                <TablixRows>
                                  <TablixRow><Height>0.25in</Height><TablixCells>
                                    <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Evaluator Information</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>#E9F5EA</BackgroundColor></Style></Textbox><ColSpan>2</ColSpan></CellContents></TablixCell><TablixCell />
                                  </TablixCells></TablixRow>
                                  <TablixRow><Height>0.2in</Height><TablixCells>
                                    <TablixCell><CellContents><Textbox Name="L7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Name</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                    <TablixCell><CellContents><Textbox Name="V7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!RespondentName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                  </TablixCells></TablixRow>
                                  <TablixRow><Height>0.2in</Height><TablixCells>
                                    <TablixCell><CellContents><Textbox Name="L8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Current Position :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                    <TablixCell><CellContents><Textbox Name="V8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!RespondentPosition.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                  </TablixCells></TablixRow>
                                  <TablixRow><Height>0.2in</Height><TablixCells>
                                    <TablixCell><CellContents><Textbox Name="L9"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Department :</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                    <TablixCell><CellContents><Textbox Name="V9"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!RespondentDepartment.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                  </TablixCells></TablixRow>
                                  <TablixRow><Height>0.2in</Height><TablixCells>
                                    <TablixCell><CellContents><Textbox Name="L10"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Role</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                    <TablixCell><CellContents><Textbox Name="V10"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RespondentRole.Value="Manager","☑","☐") + " Direct Manager " + IIF(Fields!RespondentRole.Value="Peer","☑","☐") + " Peer " + IIF(Fields!RespondentRole.Value="Subordinate","☑","☐") + " Subordinate"</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                                  </TablixCells></TablixRow>
                                </TablixRows>
                              </TablixBody>
                              <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                              <TablixRowHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixRowHierarchy>
                              <Height>1.05in</Height><Width>7.5in</Width>
                            </Tablix>

                            <!-- Evaluation Questions Header -->
                            <Textbox Name="LblEvalSub"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Performance Evaluation Questions</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.15in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>

                            <!-- Main Appraisal Table (Inside List) -->
                            <Tablix Name="TablixMain">
                              <TablixBody>
                                <TablixColumns>
                                  <TablixColumn><Width>0.4in</Width></TablixColumn>
                                  <TablixColumn><Width>0.4in</Width></TablixColumn>
                                  <TablixColumn><Width>4.2in</Width></TablixColumn>
                                  <TablixColumn><Width>0.5in</Width></TablixColumn>
                                  <TablixColumn><Width>0.5in</Width></TablixColumn>
                                  <TablixColumn><Width>0.5in</Width></TablixColumn>
                                  <TablixColumn><Width>0.5in</Width></TablixColumn>
                                  <TablixColumn><Width>0.5in</Width></TablixColumn>
                                </TablixColumns>
                                <TablixRows>
                                  <!-- Table Header -->
                                  <TablixRow><Height>0.3in</Height>
                                    <TablixCells>
                                      <TablixCell><CellContents><Textbox Name="ColCat"><Paragraphs><Paragraph><TextRuns><TextRun><Value /></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="ColNo"><Paragraphs><Paragraph><TextRuns><TextRun><Value>No</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>White</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="ColCriteria"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Criteria</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><BackgroundColor>White</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="Col5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>5</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="Col4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>4</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="Col3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>3</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="Col2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>2</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="Col1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>1</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                                    </TablixCells>
                                  </TablixRow>
                                  <!-- Data Row -->
                                  <TablixRow><Height>0.35in</Height>
                                    <TablixCells>
                                      <TablixCell><CellContents><Textbox Name="ValCategory"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!QuestionCategory.Value</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><WritingMode>Vertical</WritingMode><PaddingTop>5pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="ValNo"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SortOrder.Value</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="ValCriteria"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!QuestionText.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="V5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RatingValue.Value=5,"X","")</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="V4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RatingValue.Value=4,"X","")</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="V3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RatingValue.Value=3,"X","")</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="V2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RatingValue.Value=2,"X","")</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                      <TablixCell><CellContents><Textbox Name="V1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!RatingValue.Value=1,"X","")</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                    </TablixCells>
                                  </TablixRow>
                                </TablixRows>
                              </TablixBody>
                              <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                              <TablixRowHierarchy>
                                <TablixMembers>
                                  <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                                  <TablixMember>
                                    <Group Name="GrpCategory"><GroupExpressions><GroupExpression>=Fields!QuestionCategory.Value</GroupExpression></GroupExpressions></Group>
                                    <TablixMembers>
                                      <TablixMember><Group Name="Details" /></TablixMember>
                                    </TablixMembers>
                                  </TablixMember>
                                </TablixMembers>
                              </TablixRowHierarchy>
                              <Top>1.4in</Top><Height>0.65in</Height><Width>7.5in</Width>
                            </Tablix>
                          </ReportItems>
                        </Rectangle>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember>
                  <Group Name="GroupEvaluator">
                    <GroupExpressions><GroupExpression>=Fields!RespondentName.Value</GroupExpression></GroupExpressions>
                    <PageBreak><BreakLocation>Between</BreakLocation></PageBreak>
                  </Group>
                </TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>Responses</DataSetName>
            <Top>2.4in</Top><Height>2.5in</Height><Width>7.5in</Width>
          </Tablix>

          <!-- Additional Comments Section -->
          <Textbox Name="AddComments"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Additional Comments</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>5.0in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>
          <Textbox Name="L_1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>--------------------------------------------------------------------------------------------------------------------------------------------------</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>5.3in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>
          <Textbox Name="L_2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>--------------------------------------------------------------------------------------------------------------------------------------------------</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>5.5in</Top><Height>0.2in</Height><Width>7.5in</Width></Textbox>

          <!-- Score Summary / Outcome Section -->
          <Tablix Name="ScoreCalcTab">
            <TablixBody>
              <TablixColumns><TablixColumn><Width>2.0in</Width></TablixColumn><TablixColumn><Width>3.5in</Width></TablixColumn><TablixColumn><Width>2.0in</Width></TablixColumn></TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.3in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="H_1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Arial</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H_2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Formula</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H_3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Score</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.8in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="V_1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Total Points</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="V_2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!TotalPoints.Value + " / (" + Parameters!AnsweredQuestionsCount.Value + " X 5) X 100"</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="V_3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!FinalScore.Value</Value><Style><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
