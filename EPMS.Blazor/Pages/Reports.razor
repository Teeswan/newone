@page "/reports"
@page "/reports/{reportType}"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@layout MainLayout
@inject IReportBlazorService ReportService
@inject IAppraisalCycleBlazorService CycleService
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<PageTitle>Reports - EPMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudPaper Class="pa-6 mb-6" Elevation="0">
        <MudStack Row="true" Gap="4" AlignItems="AlignItems.Center">
            <MudStack Row="false" Gap="1" Style="flex-grow: 1;">
                <MudText Typo="Typo.h4" Class="text-gray-900">Performance Reports</MudText>
                <MudText Typo="Typo.body1" Class="text-gray-600">Generate and download performance reports in PDF format</MudText>
            </MudStack>
            
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Label="Appraisal Cycle" @bind-Value="_selectedCycleId" Variant="Variant.Outlined" Dense="true" Placeholder="Select Cycle">
                    @foreach (var cycle in _cycles)
                    {
                        <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudStack>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Employee Summary</MudText>
                    
                    <MudAutocomplete T="EmployeeDto" Label="Select Employee" @bind-Value="_selectedEmployee" 
                                    SearchFunc="@SearchEmployees" ToStringFunc="@(e => e?.FullName)"
                                    Variant="Variant.Outlined" Dense="true" Class="mb-2" />

                    <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateEmployeeReport" 
                               Disabled="@(_selectedCycleId == null || _selectedEmployee == null || isLoading)">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                        Generate
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6">Dept Comparison</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Compare scores across departments</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Secondary" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateDepartmentReport"
                               Disabled="@(_selectedCycleId == null || isLoading)">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                        Generate
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.h6">High & Low</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Ranked list of performers</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateHighLowReport"
                               Disabled="@(_selectedCycleId == null || isLoading)">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                        Generate
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Info" />
                    <MudText Typo="Typo.h6">Recommendations</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Promotion and increment list</MudText>
                    <MudSpacer />
                    <MudButton Color="Color.Info" Variant="Variant.Filled" FullWidth="true" OnClick="GeneratePromotionReport"
                               Disabled="@(_selectedCycleId == null || isLoading)">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                        Generate
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Parameter] public string? ReportType { get; set; }

    private bool isLoading = false;
    private List<AppraisalCycleDto> _cycles = new();
    private List<EmployeeDto> _employees = new();
    private int? _selectedCycleId;
    private EmployeeDto? _selectedEmployee;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            _cycles = (await CycleService.GetAllAppraisalCyclesAsync()).ToList();
            _employees = (await EmployeeService.GetEmployeesAsync()).ToList();
            
            if (_cycles.Any()) _selectedCycleId = _cycles.First().CycleId;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading cycles: {ex.Message}", Severity.Error);
        }
    }

    private async Task<IEnumerable<EmployeeDto>> SearchEmployees(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _employees;
        return _employees.Where(x => x.FullName.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task GenerateEmployeeReport()
    {
        if (_selectedCycleId == null || _selectedEmployee == null) return;
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GenerateEmployeePerformanceSummaryReportAsync(_selectedEmployee.EmployeeId, _selectedCycleId.Value);
            await ReportService.DownloadPdfAsync(pdfBytes, $"Summary_{_selectedEmployee.FullName}_{DateTime.Now:yyyyMMdd}.pdf");
            Snackbar.Add("Employee Performance Summary report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally { isLoading = false; }
    }

    private async Task GenerateDepartmentReport()
    {
        if (_selectedCycleId == null) return;
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GenerateDepartmentPerformanceComparisonReportAsync(_selectedCycleId.Value);
            await ReportService.DownloadPdfAsync(pdfBytes, $"Department_Comparison_{DateTime.Now:yyyyMMdd}.pdf");
            Snackbar.Add("Department Performance Comparison report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally { isLoading = false; }
    }

    private async Task GenerateHighLowReport()
    {
        if (_selectedCycleId == null) return;
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GenerateHighLowPerformerReportAsync(_selectedCycleId.Value);
            await ReportService.DownloadPdfAsync(pdfBytes, $"High_Low_Performers_{DateTime.Now:yyyyMMdd}.pdf");
            Snackbar.Add("High & Low Performers report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally { isLoading = false; }
    }

    private async Task GeneratePromotionReport()
    {
        if (_selectedCycleId == null) return;
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GeneratePromotionIncrementRecommendationReportAsync(_selectedCycleId.Value);
            await ReportService.DownloadPdfAsync(pdfBytes, $"Promotion_Recommendations_{DateTime.Now:yyyyMMdd}.pdf");
            Snackbar.Add("Promotion & Increment Recommendations report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally { isLoading = false; }
    }
}