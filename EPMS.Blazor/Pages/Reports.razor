@page "/reports"
@page "/reports/{reportType}"
@using EPMS.Blazor.Services
@layout MainLayout
@inject IReportBlazorService ReportService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<PageTitle>Reports - EPMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudPaper Class="pa-6 mb-6" Elevation="0">
        <MudStack Row="false" Gap="4">
            <MudText Typo="Typo.h4" Class="text-gray-900">Performance Reports</MudText>
            <MudText Typo="Typo.body1" Class="text-gray-600">Generate and download performance reports in PDF format</MudText>
        </MudStack>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Employee Performance Summary</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Generate a detailed performance report for an individual employee</MudText>
                    <MudSpacer />
                    <MudStack Row="true" Gap="2">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateEmployeeReport">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                            Generate Report
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6">Department Comparison</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Compare performance scores across all departments</MudText>
                    <MudSpacer />
                    <MudStack Row="true" Gap="2">
                        <MudButton Color="Color.Secondary" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateDepartmentReport">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                            Generate Report
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.h6">High & Low Performers</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">Ranked list of employees by performance score</MudText>
                    <MudSpacer />
                    <MudStack Row="true" Gap="2">
                        <MudButton Color="Color.Success" Variant="Variant.Filled" FullWidth="true" OnClick="GenerateHighLowReport">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                            Generate Report
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack Row="false" Gap="3" AlignItems="AlignItems.Stretch">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Info" />
                    <MudText Typo="Typo.h6">Promotion Recommendations</MudText>
                    <MudText Typo="Typo.body2" Class="text-gray-600">List employees eligible for promotion or increment</MudText>
                    <MudSpacer />
                    <MudStack Row="true" Gap="2">
                        <MudButton Color="Color.Info" Variant="Variant.Filled" FullWidth="true" OnClick="GeneratePromotionReport">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" />
                            Generate Report
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public string? ReportType { get; set; }

    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        if (!string.IsNullOrEmpty(ReportType))
        {
            await Task.Delay(500);
            switch (ReportType.ToLower())
            {
                case "employee":
                    await GenerateEmployeeReport();
                    break;
                case "department":
                    await GenerateDepartmentReport();
                    break;
                case "performers":
                    await GenerateHighLowReport();
                    break;
                case "promotion":
                    await GeneratePromotionReport();
                    break;
            }
        }
    }

    private async Task GenerateEmployeeReport()
    {
        try
        {
            isLoading = true;
            
            var sampleReportData = new EmployeePerformanceSummaryReportDto
            {
                EmployeeCode = "EMP-001",
                FullName = "John Doe",
                PositionTitle = "Senior Software Engineer",
                LevelName = "Level 4",
                DepartmentName = "Engineering",
                ReviewPeriod = "Q1 2025",
                ReviewStartDate = new DateTime(2025, 1, 1),
                ReviewEndDate = new DateTime(2025, 3, 31),
                TotalWeightedScore = 88.5m,
                AchievementPercentage = 88.5m,
                FinalRating = 4.4m,
                PerformanceLevel = "Exceeds Expectations",
                PromotionEligibility = true,
                HasActivePip = false,
                MeetingsCompletedCount = 12,
                KpiCategoryScores = new List<KpiCategoryScoreDto>
                {
                    new KpiCategoryScoreDto { CategoryName = "Technical Skills", Score = 90, WeightedScore = 36 },
                    new KpiCategoryScoreDto { CategoryName = "Leadership", Score = 85, WeightedScore = 17 },
                    new KpiCategoryScoreDto { CategoryName = "Teamwork", Score = 92, WeightedScore = 18.4m },
                    new KpiCategoryScoreDto { CategoryName = "Communication", Score = 87, WeightedScore = 17.4m }
                },
                FeedbackCriteria = new List<FeedbackCriterionDto>
                {
                    new FeedbackCriterionDto { CriterionName = "Problem Solving", AverageScore = 4.3m, RespondentCount = 8 },
                    new FeedbackCriterionDto { CriterionName = "Communication", AverageScore = 4.1m, RespondentCount = 8 },
                    new FeedbackCriterionDto { CriterionName = "Collaboration", AverageScore = 4.5m, RespondentCount = 8 }
                }
            };

            var pdfBytes = await ReportService.GenerateEmployeePerformanceSummaryReportAsync(sampleReportData);
            await ReportService.DownloadPdfAsync(pdfBytes, "Employee_Performance_Summary.pdf");
            
            Snackbar.Add("Employee Performance Summary report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GenerateDepartmentReport()
    {
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GenerateDepartmentPerformanceComparisonReportAsync();
            await ReportService.DownloadPdfAsync(pdfBytes, "Department_Performance_Comparison.pdf");
            Snackbar.Add("Department Performance Comparison report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GenerateHighLowReport()
    {
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GenerateHighLowPerformerReportAsync();
            await ReportService.DownloadPdfAsync(pdfBytes, "High_Low_Performers.pdf");
            Snackbar.Add("High & Low Performers report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GeneratePromotionReport()
    {
        try
        {
            isLoading = true;
            var pdfBytes = await ReportService.GeneratePromotionIncrementRecommendationReportAsync();
            await ReportService.DownloadPdfAsync(pdfBytes, "Promotion_Increment_Recommendations.pdf");
            Snackbar.Add("Promotion & Increment Recommendations report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}