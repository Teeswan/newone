@page "/admin/employees"
@attribute [Authorize(Policy = Permissions.GlobalAdminManagement)]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@inject IGlobalAdminBlazorService GlobalAdminService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Admin — Employees</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3 mb-2" Color="Color.Success" />
                All Employees
            </MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mt-1">
                Step 3 of 3 — View every employee across the organization
                @if (_filterTeamId.HasValue && !string.IsNullOrEmpty(_filterTeamName))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2" OnClose="ClearTeamFilter">
                        @_filterTeamName
                    </MudChip>
                }
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Navigation.NavigateTo("/admin/teams"))">
            Back to Teams
        </MudButton>
    </div>

    <AuthorizeView Policy="@Permissions.GlobalAdminManagement">
        <Authorized>
            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else if (!FilteredEmployees.Any())
            {
                <MudAlert Severity="Severity.Info">No employees found.</MudAlert>
                <MudButton Class="mt-4" Variant="Variant.Outlined" Color="Color.Primary"
                           OnClick="@(() => Navigation.NavigateTo("/admin/teams"))">
                    Back to Teams
                </MudButton>
            }
            else
            {
                <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
                    <MudTextField @bind-Value="_search" Placeholder="Search employees..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                </MudPaper>

                <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                    <MudTable Items="FilteredEmployees" T="EmployeeDto" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Code</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Department</MudTh>
                            <MudTh>Team</MudTh>
                            <MudTh>Position</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh Style="text-align: right;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="employee">
                            <MudTd>@employee.EmployeeCode</MudTd>
                            <MudTd>@employee.FullName</MudTd>
                            <MudTd>@employee.DepartmentName</MudTd>
                            <MudTd>@employee.TeamName</MudTd>
                            <MudTd>@employee.PositionTitle</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(employee.IsActive == true ? Color.Success : Color.Error)">
                                    @(employee.IsActive == true ? "Active" : "Inactive")
                                </MudChip>
                            </MudTd>
                            <MudTd Style="text-align: right;">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                               Title="View profile"
                                               OnClick="@(() => Navigation.NavigateTo($"/employees/details/{employee.EmployeeId}"))" />
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudPaper>
            }
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Error">Access Denied.</MudAlert>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>

@code {
    private List<EmployeeDto> _employees = new();
    private bool _isLoading = true;
    private string _search = "";
    private int? _filterTeamId;
    private string? _filterTeamName;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("Admin Dashboard", "/admin/dashboard"),
        new BreadcrumbItem("Departments", "/admin/departments"),
        new BreadcrumbItem("Teams", "/admin/teams"),
        new BreadcrumbItem("Employees", "/admin/employees", disabled: true)
    };

    private IEnumerable<EmployeeDto> FilteredEmployees => _employees
        .Where(e => !_filterTeamId.HasValue || e.TeamId == _filterTeamId.Value)
        .Where(e => string.IsNullOrWhiteSpace(_search)
            || e.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || e.EmployeeCode.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        ParseQueryFilters();
        await LoadData();
    }

    protected override void OnParametersSet() => ParseQueryFilters();

    private void ParseQueryFilters()
    {
        _filterTeamId = null;
        _filterTeamName = null;

        var queryIndex = Navigation.Uri.IndexOf('?', StringComparison.Ordinal);
        if (queryIndex < 0) return;

        foreach (var part in Navigation.Uri[(queryIndex + 1)..].Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length != 2) continue;

            if (kv[0].Equals("teamId", StringComparison.OrdinalIgnoreCase)
                && int.TryParse(Uri.UnescapeDataString(kv[1]), out var teamId))
            {
                _filterTeamId = teamId;
            }
            else if (kv[0].Equals("teamName", StringComparison.OrdinalIgnoreCase))
            {
                _filterTeamName = Uri.UnescapeDataString(kv[1]);
            }
        }
    }

    private void ClearTeamFilter() => Navigation.NavigateTo("/admin/employees");

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            _employees = await GlobalAdminService.GetEmployeesAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _employees = new List<EmployeeDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
