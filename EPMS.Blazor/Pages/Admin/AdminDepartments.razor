@page "/admin/departments"
@attribute [Authorize(Policy = Permissions.GlobalAdminManagement)]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using EPMS.Blazor.Dialogs
@inject IGlobalAdminBlazorService GlobalAdminService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Admin — Departments</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
                <MudIcon Icon="@Icons.Material.Filled.Domain" Class="mr-3 mb-2" Color="Color.Primary" />
                All Departments
            </MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mt-1">
                Step 1 of 3 — Full read/write access to every department
            </MudText>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/admin/dashboard"))">
                Dashboard
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => Navigation.NavigateTo("/admin/teams"))">
                View Teams
            </MudButton>
        </div>
    </div>

    <AuthorizeView Policy="@Permissions.GlobalAdminManagement">
        <Authorized>
            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudTextField @bind-Value="_search" Placeholder="Search departments..." Style="max-width: 320px;"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog">
                        Add Department
                    </MudButton>
                </div>

                @if (!FilteredDepartments.Any())
                {
                    <MudAlert Severity="Severity.Info">No departments found.</MudAlert>
                }
                else
                {
                    <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                        <MudTable Items="FilteredDepartments" T="DepartmentDto" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Parent</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh Style="text-align: right;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="dept">
                                <MudTd>@dept.DepartmentIdName</MudTd>
                                <MudTd>
                                    <MudLink Typo="Typo.body2" Color="Color.Primary" Underline="Underline.Hover"
                                             OnClick="@(() => GoToTeams(dept.DepartmentId, dept.DepartmentName))"
                                             Style="cursor: pointer;">
                                        @dept.DepartmentName
                                    </MudLink>
                                </MudTd>
                                <MudTd>@(dept.ParentDepartmentName ?? "—")</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@(dept.IsActive ? Color.Success : Color.Error)">
                                        @(dept.IsActive ? "Active" : "Inactive")
                                    </MudChip>
                                </MudTd>
                                <MudTd Style="text-align: right;">
                                    <MudTooltip Text="View teams in this department">
                                        <MudIconButton Icon="@Icons.Material.Filled.Groups" Color="Color.Info" Size="Size.Small"
                                                       OnClick="@(() => GoToTeams(dept.DepartmentId, dept.DepartmentName))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Edit department">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                                       OnClick="@(() => OpenEditDialog(dept.DepartmentId))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete department">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => DeleteDepartment(dept.DepartmentId, dept.DepartmentName))" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent><MudTablePager /></PagerContent>
                        </MudTable>
                    </MudPaper>
                }
            }
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Error">Access Denied.</MudAlert>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>

@code {
    private List<DepartmentDto> _departments = new();
    private bool _isLoading = true;
    private string _search = "";

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("Admin Dashboard", "/admin/dashboard"),
        new BreadcrumbItem("Departments", "/admin/departments", disabled: true)
    };

    private IEnumerable<DepartmentDto> FilteredDepartments => _departments
        .Where(d => string.IsNullOrWhiteSpace(_search)
            || d.DepartmentName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || (d.DepartmentIdName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            _departments = await GlobalAdminService.GetDepartmentsAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _departments = new List<DepartmentDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToTeams(int departmentId, string departmentName) =>
        Navigation.NavigateTo($"/admin/teams?departmentId={departmentId}&departmentName={Uri.EscapeDataString(departmentName)}");

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<DepartmentDialog>("Create Department",
            new DialogParameters { ["GlobalAdmin"] = true });
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task OpenEditDialog(int id)
    {
        var dialog = await DialogService.ShowAsync<DepartmentDialog>("Update Department",
            new DialogParameters { ["Id"] = id, ["GlobalAdmin"] = true });
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task DeleteDepartment(int id, string name)
    {
        if (await DialogService.ShowMessageBox("Delete Department", $"Delete \"{name}\"?", yesText: "Delete", cancelText: "Cancel") != true)
            return;

        try
        {
            if (await GlobalAdminService.DeleteDepartmentAsync(id))
            {
                Snackbar.Add("Department deleted.", Severity.Success);
                await LoadData();
            }
            else Snackbar.Add("Department not found.", Severity.Warning);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
}
