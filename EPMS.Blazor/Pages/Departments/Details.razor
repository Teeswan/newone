@page "/departments/details/{id:int}"
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager

<PageTitle>Department Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
                <div class="d-flex align-center">
                    <div Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                        <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Large" Style="color: white;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Department Details</MudText>
                        <MudText Typo="Typo.body2" Style="color: #6B7280;">View complete department information</MudText>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <MudTooltip Text="Edit this department" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="NavigateToEdit" 
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Class="rounded-lg">
                            Edit
                        </MudButton>
                    </MudTooltip>
                </div>
            </div>
            
            <MudDivider Class="mb-8" />

            @if (department == null)
            {
                <div class="text-center py-16">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading department details...</MudText>
                </div>
            }
            else
            {
                <MudPaper Elevation="0" Class="pa-6" Style="background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%); border-radius: 12px;">
                    <MudText Typo="Typo.h6" Class="mb-6" Style="font-weight: 600; color: #111827;">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" Color="Color.Primary" />
                        Basic Information
                    </MudText>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="0" Class="pa-4" Style="background: white; border-radius: 12px;">
                                <MudText Typo="Typo.caption" Style="color: #6B7280; font-weight: 500;">Department ID</MudText>
                                <MudChip Color="Color.Primary" Size="Size.Medium" T="int">@department.DepartmentId</MudChip>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="0" Class="pa-4" Style="background: white; border-radius: 12px;">
                                <MudText Typo="Typo.caption" Style="color: #6B7280; font-weight: 500;">Department Name</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@department.DepartmentName</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="0" Class="pa-4" Style="background: white; border-radius: 12px;">
                                <MudText Typo="Typo.caption" Style="color: #6B7280; font-weight: 500;">Parent Department</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">@department.ParentDepartmentName</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="0" Class="pa-4" Style="background: white; border-radius: 12px;">
                                <MudText Typo="Typo.caption" Style="color: #6B7280; font-weight: 500;">Status</MudText>
                                <MudChip Color="@(department.IsActive ? Color.Success : Color.Error)" Size="Size.Medium" T="bool" 
                                         Icon="@(department.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)">
                                    @(department.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            <MudDivider Class="my-8" />

            <div class="d-flex justify-end gap-3">
                <MudTooltip Text="Go back to departments list" Arrow="true">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" 
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Class="rounded-lg px-6">
                        Back to List
                    </MudButton>
                </MudTooltip>
            </div>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private DepartmentDto? department;

    protected override async Task OnParametersSetAsync()
    {
        department = await DepartmentService.GetDepartmentByIdAsync(Id);
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/departments/edit/{Id}");
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/departments");
    }
}
