@page "/departments/details/{id:int}"
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager

<PageTitle>Department Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Department Details</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">View complete department information</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        @if (department == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                        <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-primary">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                            Basic Information
                        </MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-2">Department ID</MudText>
                                <MudChip Color="Color.Primary" Size="Size.Medium" T="int">@department.DepartmentId</MudChip>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-2">Name</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@department.DepartmentName</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-2">Parent Department</MudText>
                                <MudText Typo="Typo.body1">@department.ParentDepartmentName</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-2">Status</MudText>
                                <MudChip Color="@(department.IsActive ? Color.Success : Color.Error)" Size="Size.Medium" T="bool" Icon="@(department.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)">
                                    @(department.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <MudDivider Class="my-8" />

        <MudButtonGroup>
            <MudTooltip Text="Edit this department" Arrow="true">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit">
                    Edit Department
                </MudButton>
            </MudTooltip>
            <MudTooltip Text="Go back to departments list" Arrow="true">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.ArrowBack">
                    Back to List
                </MudButton>
            </MudTooltip>
        </MudButtonGroup>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private DepartmentDto? department;

    protected override async Task OnParametersSetAsync()
    {
        department = await DepartmentService.GetDepartmentByIdAsync(Id);
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/departments/edit/{Id}");
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/departments");
    }
}
