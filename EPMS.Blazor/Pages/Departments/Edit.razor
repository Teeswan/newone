@page "/departments/edit/{id:int}"
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Department</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Edit Department</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Update department information</MudText>
                </div>
            </div>
            
            <MudDivider Class="mb-8" />

            @if (department == null)
            {
                <div class="text-center py-16">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading department details...</MudText>
                </div>
            }
            else
            {
                <EditForm Model="department" OnValidSubmit="HandleValidSubmit">
                    <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%); border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Color="Color.Warning" />
                            Update Department Details
                        </MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudTextField 
                                    @bind-Value="department.DepartmentName" 
                                    Label="Department Name" 
                                    Required="true"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Business"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect 
                                    @bind-Value="department.ParentDepartmentId" 
                                    Label="Parent Department"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    T="int?"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.AccountTree"
                                    Class="rounded-lg">
                                    <MudSelectItem T="int?" Value="@((int?)null)">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Class="mr-2" Color="Color.Warning" />
                                        None (Top Level)
                                    </MudSelectItem>
                                    @if (allDepartments != null)
                                    {
                                        @foreach (var dept in allDepartments.Where(d => d.DepartmentId != Id))
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)dept.DepartmentId)">@dept.DepartmentName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="department.IsActive" Label="Department is Active" 
                                            Color="Color.Primary" Size="Size.Medium" 
                                            Icon="@Icons.Material.Filled.CheckCircle" 
                                            UncheckedIcon="@Icons.Material.Filled.Cancel" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <div class="d-flex justify-end gap-3 pt-4">
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Cancel" 
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       Class="rounded-lg px-6">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save changes to this department" Arrow="true">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Class="rounded-lg px-8"
                                       Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                                Save Changes
                            </MudButton>
                        </MudTooltip>
                    </div>
                </EditForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateDepartmentRequest? department;
    private IEnumerable<DepartmentDto>? allDepartments;

    protected override async Task OnParametersSetAsync()
    {
        var deptDto = await DepartmentService.GetDepartmentByIdAsync(Id);
        if (deptDto != null)
        {
            department = new UpdateDepartmentRequest
            {
                DepartmentName = deptDto.DepartmentName,
                ParentDepartmentId = deptDto.ParentDepartmentId,
                IsActive = deptDto.IsActive
            };
        }
        allDepartments = await DepartmentService.GetAllDepartmentsAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (department != null)
        {
            try
            {
                await DepartmentService.UpdateDepartmentAsync(Id, department);
                Snackbar.Add("Department updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                NavigationManager.NavigateTo("/departments");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating department: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/departments");
    }
}
