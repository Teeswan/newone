@page "/departments/edit/{id:int}"
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Department</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Warning" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Edit Department</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">Update department information</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        @if (department == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else
        {
            <EditForm Model="department" OnValidSubmit="HandleValidSubmit">
                <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                    <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-warning">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                        Update Department Details
                    </MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField 
                                @bind-Value="department.DepartmentName" 
                                Label="Department Name" 
                                Required="true"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Business" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect 
                                @bind-Value="department.ParentDepartmentId" 
                                Label="Parent Department"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                T="int?"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.AccountTree">
                                @if (allDepartments != null)
                                {
                                    @foreach (var dept in allDepartments.Where(d => d.DepartmentId != Id))
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)dept.DepartmentId)">@dept.DepartmentName</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudCheckBox @bind-Value="department.IsActive" Label="Is Active" Color="Color.Primary" Size="Size.Medium" Icon="@Icons.Material.Filled.CheckCircle" UncheckedIcon="@Icons.Material.Filled.Cancel" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudGrid>
                    <MudItem xs="12" Class="pt-4">
                        <MudButtonGroup>
                            <MudTooltip Text="Save changes to this department" Arrow="true">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">
                                    Save Changes
                                </MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Cancel and go back to list" Arrow="true">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Cancel" StartIcon="@Icons.Material.Filled.ArrowBack">
                                    Cancel
                                </MudButton>
                            </MudTooltip>
                        </MudButtonGroup>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateDepartmentRequest? department;
    private IEnumerable<DepartmentDto>? allDepartments;

    protected override async Task OnParametersSetAsync()
    {
        var deptDto = await DepartmentService.GetDepartmentByIdAsync(Id);
        if (deptDto != null)
        {
            department = new UpdateDepartmentRequest
            {
                DepartmentName = deptDto.DepartmentName,
                ParentDepartmentId = deptDto.ParentDepartmentId,
                IsActive = deptDto.IsActive
            };
        }
        allDepartments = await DepartmentService.GetAllDepartmentsAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (department != null)
        {
            try
            {
                await DepartmentService.UpdateDepartmentAsync(Id, department);
                Snackbar.Add("Department updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                NavigationManager.NavigateTo("/departments");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating department: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/departments");
    }
}
