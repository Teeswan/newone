@page "/position-kpi/edit/{Id:int}"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Application.UseCases.PositionKpi.Commands
@using EPMS.Domain.Enums
@inject IPositionKpiBlazorService KpiService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-6">Edit Position KPI Assignment</MudText>

    <MudPaper Class="pa-6">
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudCard Elevation="0" Outlined="true" Class="pa-2 grey lighten-5">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">KPI Template Details (Read-only)</MudText>
                                <MudText Typo="Typo.h6">@_kpiName</MudText>
                                <MudText Typo="Typo.body2"><b>Category:</b> @_category</MudText>
                                <MudText Typo="Typo.body2"><b>Position:</b> @(_positionName ?? "Global")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" @bind-Value="_command.WeightPercent" Label="Weight (%)" Min="0" Max="100" Variant="Variant.Outlined" Required="true" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" @bind-Value="_command.TargetValue" Label="Standard Target" Min="0" Variant="Variant.Outlined" Required="true" />
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@(!_isValid || _processing)">
                            @if (_processing)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Processing</MudText>
                            }
                            else
                            {
                                <MudText>Save Changes</MudText>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private UpdatePositionKpiCommand _command = new();
    private string _kpiName = "";
    private string? _category;
    private string? _positionName;
    private MudForm _form = null!;
    private bool _isValid;
    private bool _processing;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var kpi = await KpiService.GetByIdAsync(Id);
            if (kpi != null)
            {
                _kpiName = kpi.KpiName;
                _category = kpi.Category;
                _positionName = kpi.PositionName;

                _command = new UpdatePositionKpiCommand
                {
                    PositionKpiId = kpi.PositionKpiId,
                    WeightPercent = kpi.WeightPercent,
                    TargetValue = kpi.TargetValue,
                    PositionId = kpi.PositionId
                };
            }
            else
            {
                Snackbar.Add("KPI assignment not found", Severity.Error);
                NavigationManager.NavigateTo("/position-kpi");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _processing = true;
        try
        {
            var success = await KpiService.UpdateAsync(Id, _command);
            if (success)
            {
                Snackbar.Add("KPI assignment updated successfully", Severity.Success);
                NavigationManager.NavigateTo("/position-kpi");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/position-kpi");
}
