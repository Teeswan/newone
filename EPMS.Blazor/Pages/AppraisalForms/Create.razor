@page "/appraisalforms/create"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalFormBlazorService AppraisalFormService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Appraisal Form</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Create New Appraisal Form</MudText>
            </MudItem>
        </MudGrid>

        <EditForm Model="@createRequest" OnValidSubmit="HandleValidSubmit">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" 
                                  Label="Form Name" 
                                  @bind-Value="createRequest.FormName" 
                                  Required="true"
                                  RequiredError="Form name is required"
                                  Variant="Variant.Outlined"
                                  Style="width: 100%" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch T="bool" 
                               Label="Is Active" 
                               @bind-Value="isActiveValue" 
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                        Create Form
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CreateAppraisalFormRequest createRequest = new();
    private bool isActiveValue { get; set; } = true;

    private async Task HandleValidSubmit()
    {
        createRequest.IsActive = isActiveValue;
        try
        {
            await AppraisalFormService.CreateAppraisalFormAsync(createRequest);
            Snackbar.Add("Appraisal form created successfully!", Severity.Success);
            NavigationManager.NavigateTo("/appraisalforms");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating appraisal form: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalforms");
    }
}