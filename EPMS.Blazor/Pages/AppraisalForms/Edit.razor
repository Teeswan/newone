@page "/appraisalforms/edit/{Id:int}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalFormBlazorService AppraisalFormService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Appraisal Form</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Edit Appraisal Form</MudText>
            </MudItem>
        </MudGrid>

        @if (updateRequest == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-3">Loading appraisal form...</MudText>
            </div>
        }
        else
        {
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string" 
                                      Label="Form Name" 
                                      @bind-Value="updateRequest.FormName" 
                                      Required="true"
                                      RequiredError="Form name is required"
                                      Variant="Variant.Outlined"
                                      Style="width: 100%" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" 
                                   Label="Is Active" 
                                   @bind-Value="isActiveValue" 
                                   Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack">
                            Cancel
                        </MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                            Save Changes
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateAppraisalFormRequest? updateRequest;
    private bool isActiveValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var form = await AppraisalFormService.GetAppraisalFormByIdAsync(Id);
        if (form != null)
        {
            updateRequest = new UpdateAppraisalFormRequest
            {
                FormName = form.FormName,
                IsActive = form.IsActive
            };
            isActiveValue = form.IsActive ?? false;
        }
        else
        {
            Snackbar.Add("Appraisal form not found.", Severity.Error);
            NavigationManager.NavigateTo("/appraisalforms");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsActive = isActiveValue;
            try
            {
                await AppraisalFormService.UpdateAppraisalFormAsync(Id, updateRequest);
                Snackbar.Add("Appraisal form updated successfully!", Severity.Success);
                NavigationManager.NavigateTo("/appraisalforms");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating appraisal form: {ex.Message}", Severity.Error);
            }
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalforms");
    }
}