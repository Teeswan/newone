@page "/appraisalforms"
@inject EPMS.Blazor.Services.IAppraisalFormBlazorService AppraisalFormService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Appraisal Forms</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4" Class="mb-0">Appraisal Forms</MudText>
            </MudItem>
            <MudItem>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add">
                    Create New
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (appraisalForms == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-3">Loading appraisal forms...</MudText>
            </div>
        }
        else if (!appraisalForms.Any())
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                No appraisal forms found. Create your first appraisal form!
            </MudAlert>
        }
        else
        {
            <MudTable Items="appraisalForms" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Form Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.FormName</MudTd>
                    <MudTd>@context.IsActive</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Href="@($"/appraisalforms/edit/{context.FormId}")" />

                        <MudIconButton Icon="@Icons.Material.Filled.List"
                                       Color="Color.Primary"
                                       Title="Manage Questions"
                                       Href="@($"/appraisalforms/{context.FormId}/manage-questions")" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                            <MudButton Color="Color.Info" OnClick="() => NavigateToDetails(context.FormId)" StartIcon="@Icons.Material.Filled.Visibility">View</MudButton>
                            <MudButton Color="Color.Warning" OnClick="() => NavigateToEdit(context.FormId)" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                            <MudButton Color="Color.Error" OnClick="() => DeleteAppraisalForm(context)" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                        </MudButtonGroup>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<EPMS.Shared.DTOs.AppraisalFormDto>? appraisalForms;

    protected override async Task OnInitializedAsync()
    {
        await LoadAppraisalForms();
    }

    private async Task LoadAppraisalForms()
    {
        try
        {
            appraisalForms = await AppraisalFormService.GetAllAppraisalFormsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading appraisal forms: {ex.Message}", Severity.Error);
            appraisalForms = new List<EPMS.Shared.DTOs.AppraisalFormDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/appraisalforms/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/appraisalforms/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/appraisalforms/edit/{id}");
    }

    private async Task DeleteAppraisalForm(EPMS.Shared.DTOs.AppraisalFormDto form)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete the appraisal form '{form.FormName}'?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<EPMS.Blazor.Layout.MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await AppraisalFormService.DeleteAppraisalFormAsync(form.FormId);
                if (success)
                {
                    Snackbar.Add("Appraisal form deleted successfully!", Severity.Success);
                    await LoadAppraisalForms();
                }
                else
                {
                    Snackbar.Add("Error deleting appraisal form.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting appraisal form: {ex.Message}", Severity.Error);
            }
        }
    }
}