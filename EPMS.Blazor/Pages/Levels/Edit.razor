@page "/levels/edit/{id}"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Level</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Warning" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Edit Level</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">Update level information</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        @if (isLoading)
        {
            <div class="d-flex flex-column justify-center my-10 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-4 text-grey">Loading level...</MudText>
            </div>
        }
        else if (levelModel == null)
        {
            <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline">
                Level not found.
            </MudAlert>
        }
        else
        {
            <EditForm Model="levelModel" OnValidSubmit="HandleUpdate">
                <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                    <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-warning">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                        Update Level Details
                    </MudText>
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Level ID" 
                                @bind-Value="levelId"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Disabled="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Badge" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Level Name" 
                                @bind-Value="levelModel.LevelName"
                                Placeholder="Enter level name"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Required="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Grade" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Description" 
                                @bind-Value="levelModel.LevelDescription"
                                Placeholder="Enter level description (optional)"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Lines="3"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Description" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudGrid>
                    <MudItem xs="12" Class="pt-4">
                        <MudButtonGroup>
                            <MudTooltip Text="Cancel and go back to list" Arrow="true">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.Close">
                                    Cancel
                                </MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Save changes to this level" Arrow="true">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Save">
                                    Save Changes
                                </MudButton>
                            </MudTooltip>
                        </MudButtonGroup>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private string levelId = string.Empty;
    private UpdateLevelRequest? levelModel;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadLevel();
    }

    private async Task LoadLevel()
    {
        try
        {
            isLoading = true;
            var level = await LevelService.GetLevelByIdAsync(Id);
            if (level != null)
            {
                levelId = level.LevelId;
                levelModel = new UpdateLevelRequest
                {
                    LevelName = level.LevelName,
                    LevelDescription = level.LevelDescription
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (levelModel == null) return;

        try
        {
            await LevelService.UpdateLevelAsync(Id, levelModel);
            Snackbar.Add("Level updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/levels");
    }
}
