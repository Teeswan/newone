@page "/levels/edit/{id}"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Level</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Edit Level</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Update level information</MudText>
                </div>
            </div>
            <MudDivider Class="mb-8" />

            @if (isLoading)
            {
                <div class="d-flex flex-column justify-center my-16 align-center">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading level...</MudText>
                </div>
            }
            else if (levelModel == null)
            {
                <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline"
                          Style="border-radius: 12px;">
                    Level not found.
                </MudAlert>
            }
            else
            {
                <EditForm Model="levelModel" OnValidSubmit="HandleUpdate">
                    <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%); border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Color="Color.Warning" />
                            Update Level Details
                        </MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudTextField 
                                    T="string"
                                    Label="Level ID" 
                                    @bind-Value="levelId"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Disabled="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Badge"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField 
                                    T="string"
                                    Label="Level Name" 
                                    @bind-Value="levelModel.LevelName"
                                    Placeholder="Enter level name"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Required="true"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Grade"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField 
                                    T="string"
                                    Label="Description" 
                                    @bind-Value="levelModel.LevelDescription"
                                    Placeholder="Enter level description (optional)"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Lines="3"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Description"
                                    Class="rounded-lg" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <div class="d-flex justify-end gap-3 pt-4">
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" 
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       Class="rounded-lg px-6">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save changes to this level" Arrow="true">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Class="rounded-lg px-8"
                                       Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                                Save Changes
                            </MudButton>
                        </MudTooltip>
                    </div>
                </EditForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private string levelId = string.Empty;
    private UpdateLevelRequest? levelModel;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadLevel();
    }

    private async Task LoadLevel()
    {
        try
        {
            isLoading = true;
            var level = await LevelService.GetLevelByIdAsync(Id);
            if (level != null)
            {
                levelId = level.LevelId;
                levelModel = new UpdateLevelRequest
                {
                    LevelName = level.LevelName,
                    LevelDescription = level.LevelDescription
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (levelModel == null) return;

        try
        {
            await LevelService.UpdateLevelAsync(Id, levelModel);
            Snackbar.Add("Level updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/levels");
    }
}
