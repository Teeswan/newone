@page "/levels/create"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Level</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Create Level</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Add a new level to your organization</MudText>
                </div>
            </div>
            <MudDivider Class="mb-8" />

            <EditForm Model="levelModel" OnValidSubmit="HandleCreate">
                <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%); border-radius: 12px;">
                    <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" Color="Color.Primary" />
                        Level Information
                    </MudText>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField 
                                T="string"
                                Label="Level ID" 
                                @bind-Value="levelModel.LevelId"
                                Placeholder="Enter level ID (e.g., L1, L2)"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Required="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Badge"
                                Class="rounded-lg" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField 
                                T="string"
                                Label="Level Name" 
                                @bind-Value="levelModel.LevelName"
                                Placeholder="Enter level name"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Required="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Grade"
                                Class="rounded-lg" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Description" 
                                @bind-Value="levelModel.LevelDescription"
                                Placeholder="Enter level description (optional)"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Lines="3"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Description"
                                Class="rounded-lg" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <div class="d-flex justify-end gap-3 pt-4">
                    <MudTooltip Text="Cancel and go back to list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" 
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   Class="rounded-lg px-6">
                            Cancel
                        </MudButton>
                    </MudTooltip>
                    <MudTooltip Text="Save and create this level" Arrow="true">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Class="rounded-lg px-8"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Create Level
                        </MudButton>
                    </MudTooltip>
                </div>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private CreateLevelRequest levelModel = new();

    private async Task HandleCreate()
    {
        try
        {
            await LevelService.CreateLevelAsync(levelModel);
            Snackbar.Add("Level created successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/levels");
    }
}
