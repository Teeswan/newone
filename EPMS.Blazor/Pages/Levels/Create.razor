@page "/levels/create"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Level</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Create Level</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">Add a new level to your organization</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        <EditForm Model="levelModel" OnValidSubmit="HandleCreate">
            <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-primary">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                    Level Information
                </MudText>
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField 
                            T="string"
                            Label="Level ID" 
                            @bind-Value="levelModel.LevelId"
                            Placeholder="Enter level ID (e.g., L1, L2)"
                            Variant="Variant.Outlined"
                            Style="width: 100%"
                            Class="mb-4"
                            Required="true"
                            Immediate="true"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Badge" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField 
                            T="string"
                            Label="Level Name" 
                            @bind-Value="levelModel.LevelName"
                            Placeholder="Enter level name"
                            Variant="Variant.Outlined"
                            Style="width: 100%"
                            Class="mb-4"
                            Required="true"
                            Immediate="true"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Grade" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField 
                            T="string"
                            Label="Description" 
                            @bind-Value="levelModel.LevelDescription"
                            Placeholder="Enter level description (optional)"
                            Variant="Variant.Outlined"
                            Style="width: 100%"
                            Class="mb-4"
                            Lines="3"
                            Immediate="true"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Description" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid>
                <MudItem xs="12" Class="pt-4">
                    <MudButtonGroup>
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.Close">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save and create this level" Arrow="true">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Save">
                                Create Level
                            </MudButton>
                        </MudTooltip>
                    </MudButtonGroup>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CreateLevelRequest levelModel = new();

    private async Task HandleCreate()
    {
        try
        {
            await LevelService.CreateLevelAsync(levelModel);
            Snackbar.Add("Level created successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/levels");
    }
}
