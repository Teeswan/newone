@page "/levels/details/{id}"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Level Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="d-flex align-center mb-4">
        <MudTooltip Text="Go back to levels list" Arrow="true">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Class="mr-2" />
        </MudTooltip>
        <MudText Typo="Typo.h5" Style="font-weight: bold; color: #1A56DB;">Level Details</MudText>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column justify-center my-10 align-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1" Class="mt-4 text-grey">Loading level details...</MudText>
        </div>
    }
    else if (level == null)
    {
        <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline">
            Level not found.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="12">
                <MudPaper Elevation="4" Class="pa-6" Rounded="true">
                    <div class="d-flex align-center mb-6">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                            <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Large" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold mb-0">Level Info</MudText>
                        </div>
                    </div>
                    
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-3 mb-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Level ID</MudText>
                                <MudChip T="string" Size="Size.Medium" Color="Color.Primary">@level.LevelId</MudChip>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-3 mb-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Level Name</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@level.LevelName</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Class="pa-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Description</MudText>
                                @if (!string.IsNullOrEmpty(level.LevelDescription))
                                {
                                    <MudText Typo="Typo.body1">@level.LevelDescription</MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body1" Class="text-grey">No description</MudText>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />

                    <MudGrid>
                        <MudItem xs="12">
                            <MudTooltip Text="Edit this level" Arrow="true">
                                <MudButton Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit" Style="width: 100%;">
                                    Edit Level
                                </MudButton>
                            </MudTooltip>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private LevelDto? level;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadLevel();
    }

    private async Task LoadLevel()
    {
        try
        {
            isLoading = true;
            level = await LevelService.GetLevelByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/levels");
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/levels/edit/{Id}");
    }
}
