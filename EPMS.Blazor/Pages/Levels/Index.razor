@page "/levels"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Levels</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: bold; color: #1A56DB;">Level Management</MudText>

<MudCard Elevation="1" Style="border-radius: 8px; border: 1px solid #E5E7EB;">
    <MudCardContent>

        @* Statistics Cards *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="6">
                <MudPaper Elevation="1" Class="pa-4" Rounded="true">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@(levels?.Count() ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Class="text-grey">Total Levels</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="6">
                <MudPaper Elevation="1" Class="pa-4" Rounded="true">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Success" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@(levels?.Count(l => !string.IsNullOrEmpty(l.LevelDescription)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Class="text-grey">With Description</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Toolbar: Search and Actions *@
        <div class="d-flex flex-wrap justify-space-between align-center mb-4 gap-4">
            <MudTextField @bind-Value="searchString" Placeholder="Search levels..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Style="max-width: 350px;"
                          Clearable="true" />

            <div class="d-flex gap-2">
                <MudTooltip Text="Refresh level list" Arrow="true">
                    <MudButton Variant="Variant.Outlined" Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshLevels">
                        Refresh
                    </MudButton>
                </MudTooltip>

                <MudTooltip Text="Add a new level" Arrow="true">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="NavigateToCreate"
                               Style="background-color: #1A56DB; font-weight: 600;">
                        Create New
                    </MudButton>
                </MudTooltip>
            </div>
        </div>

        @if (levels == null)
        {
            <div class="d-flex flex-column justify-center my-10 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-4 text-grey">Loading levels...</MudText>
            </div>
        }
        else if (!FilteredLevels.Any())
        {
            <div class="d-flex flex-column align-center my-10">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                @if (string.IsNullOrWhiteSpace(searchString))
                {
                    <MudText Typo="Typo.h6" Class="text-grey-darken-1 mb-2">No levels found</MudText>
                    <MudText Typo="Typo.body2" Class="text-grey mb-4">Get started by creating your first level</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add">
                        Create First Level
                    </MudButton>
                }
                else
                {
                    <MudText Typo="Typo.h6" Class="text-grey-darken-1 mb-2">No matching levels</MudText>
                    <MudText Typo="Typo.body2" Class="text-grey">Try adjusting your search</MudText>
                }
            </div>
        }
        else
        {
            <MudTable Items="@FilteredLevels" T="LevelDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      Elevation="0">
                <HeaderContent>
                    <MudTh Style="font-weight: 600;">Level ID</MudTh>
                    <MudTh Style="font-weight: 600;">Level Name</MudTh>
                    <MudTh Style="font-weight: 600;">Description</MudTh>
                    <MudTh Style="font-weight: 600; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Level ID">
                        <MudChip T="string" Size="Size.Medium" Color="Color.Primary">@context.LevelId</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Level Name">
                        <MudText Typo="Typo.body1" Class="fw-bold">@context.LevelName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Description">
                        @if (!string.IsNullOrEmpty(context.LevelDescription))
                        {
                            <MudText Typo="Typo.body2" Class="text-grey">@context.LevelDescription</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="text-grey">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View level details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info"
                                           Size="Size.Small" OnClick="@(() => NavigateToDetails(context.LevelId))" />
                        </MudTooltip>

                        <MudTooltip Text="Edit level" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning"
                                           Size="Size.Small" OnClick="@(() => NavigateToEdit(context.LevelId))" />
                        </MudTooltip>

                        <MudTooltip Text="Delete level" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="@(() => DeleteLevel(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private IEnumerable<LevelDto>? levels;
    private string searchString = "";

    private IEnumerable<LevelDto>? FilteredLevels
    {
        get
        {
            if (levels == null) return null;
            if (string.IsNullOrWhiteSpace(searchString)) return levels;

            return levels.Where(l =>
                l.LevelId.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                l.LevelName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrEmpty(l.LevelDescription) && l.LevelDescription.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            );
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        try
        {
            levels = await LevelService.GetAllLevelsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading levels: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            levels = new List<LevelDto>();
        }
    }

    private async Task RefreshLevels()
    {
        await LoadLevels();
        Snackbar.Add("Level list refreshed!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/levels/create");
    }

    private void NavigateToDetails(string id)
    {
        NavigationManager.NavigateTo($"/levels/details/{id}");
    }

    private void NavigateToEdit(string id)
    {
        NavigationManager.NavigateTo($"/levels/edit/{id}");
    }

    private async Task DeleteLevel(LevelDto level)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete level '{level.LevelName}'?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await LevelService.DeleteLevelAsync(level.LevelId);
                if (success)
                {
                    Snackbar.Add("Level deleted successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadLevels();
                }
                else
                {
                    Snackbar.Add("Error deleting level.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }
}
