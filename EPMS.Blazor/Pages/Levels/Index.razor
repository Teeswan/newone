@page "/levels"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Levels</PageTitle>

<MudContainer>
    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudItem>
            <MudText Typo="Typo.h4" Class="mb-0">Levels</MudText>
        </MudItem>
        <MudItem>
            <MudButton Color="Color.Primary" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add">
                Create New
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="pa-4">
        @if (levels == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!levels.Any())
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                No levels found. Create your first level!
            </MudAlert>
        }
        else
        {
            <MudTable Items="@levels" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Level ID</MudTh>
                    <MudTh>Level Name</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Level ID">@context.LevelId</MudTd>
                    <MudTd DataLabel="Level Name">@context.LevelName</MudTd>
                    <MudTd DataLabel="Description">@context.LevelDescription</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                            <MudButton Color="Color.Info" OnClick="() => NavigateToDetails(context.LevelId)" StartIcon="@Icons.Material.Filled.Visibility">View</MudButton>
                            <MudButton Color="Color.Warning" OnClick="() => NavigateToEdit(context.LevelId)" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                            <MudButton Color="Color.Error" OnClick="() => DeleteLevel(context)" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                        </MudButtonGroup>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<LevelDto>? levels;

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        try
        {
            levels = await LevelService.GetAllLevelsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading levels: {ex.Message}", Severity.Error);
            levels = new List<LevelDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/levels/create");
    }

    private void NavigateToDetails(string id)
    {
        NavigationManager.NavigateTo($"/levels/details/{id}");
    }

    private void NavigateToEdit(string id)
    {
        NavigationManager.NavigateTo($"/levels/edit/{id}");
    }

    private async Task DeleteLevel(LevelDto level)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this level?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await LevelService.DeleteLevelAsync(level.LevelId);
                if (success)
                {
                    Snackbar.Add("Level deleted successfully!", Severity.Success);
                    await LoadLevels();
                }
                else
                {
                    Snackbar.Add("Error deleting level.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting level: {ex.Message}", Severity.Error);
            }
        }
    }
}
