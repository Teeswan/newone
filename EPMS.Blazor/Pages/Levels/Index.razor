@page "/levels"
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Levels</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700; color: #111827;">
    <MudIcon Icon="@Icons.Material.Filled.Grade" Class="mr-2 mb-n1" Color="Color.Primary" />
    Level Management
</MudText>

<MudCard Elevation="2" Class="mb-4" Style="border-radius: 16px;">
    <MudCardContent Class="pa-6">
        @* Statistics Cards with beautiful gradients *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(levels?.Count() ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Total Levels</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #059669 0%, #10B981 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(levels?.Count(l => !string.IsNullOrEmpty(l.LevelDescription)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">With Description</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(levels?.Count(l => string.IsNullOrEmpty(l.LevelDescription)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Without Description</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Toolbar with improved styling *@
        <MudPaper Elevation="0" Class="pa-4 mb-6" Style="background: #F9FAFB; border-radius: 12px;">
            <div class="d-flex flex-wrap justify-space-between align-center gap-4">
                <MudTextField @bind-Value="searchString" Placeholder="Search levels by ID, name, or description..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Style="min-width: 280px;"
                              Variant="Variant.Outlined" Clearable="true" />

                <div class="d-flex gap-3">
                    <MudTooltip Text="Refresh level list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshLevels"
                                   Class="rounded-lg">
                            Refresh
                        </MudButton>
                    </MudTooltip>

                    <MudTooltip Text="Add a new level" Arrow="true">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="NavigateToCreate"
                                   Class="rounded-lg"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Create New
                        </MudButton>
                    </MudTooltip>
                </div>
            </div>
        </MudPaper>

        @if (levels == null)
        {
            <div class="d-flex flex-column justify-center my-20 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading levels...</MudText>
            </div>
        }
        else if (!FilteredLevels.Any())
        {
            <div class="text-center py-16">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Info" Class="mb-6" />
                <MudText Typo="Typo.h5" Class="fw-bold mb-3" Style="color: #374151;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "No levels found" : "No levels match your search")
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-8" Style="color: #6B7280;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "Get started by creating your first level!" : "Try adjusting your search criteria.")
                </MudText>
                @if (string.IsNullOrWhiteSpace(searchString))
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToCreate" 
                               StartIcon="@Icons.Material.Filled.Add" Size="Size.Large"
                               Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 8px;">
                        Create First Level
                    </MudButton>
                }
            </div>
        }
        else
        {
            <MudTable Items="@FilteredLevels" T="LevelDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      Elevation="1" Filter="new Func<LevelDto,bool>(d => true)"
                      Class="rounded-xl">
                <HeaderContent>
                    <MudTh Style="font-weight: 700; color: #374151;">Level ID</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Name</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Description</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Level ID">
                        <MudChip T="string" Size="Size.Medium" Color="Color.Primary">@context.LevelId</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Name">
                        <div class="d-flex align-center">
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-3">
                                @context.LevelName[0]
                            </MudAvatar>
                            <MudText Style="font-weight: 500;">@context.LevelName</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Description">
                        @if (!string.IsNullOrEmpty(context.LevelDescription))
                        {
                            <MudText Typo="Typo.body1" Style="color: #374151;">@context.LevelDescription</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color: #6B7280;">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View level details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info"
                                           Size="Size.Small" OnClick="@(() => NavigateToDetails(context.LevelId))" />
                        </MudTooltip>
                        <MudTooltip Text="Edit level" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning"
                                           Size="Size.Small" OnClick="@(() => NavigateToEdit(context.LevelId))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete level" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="@(() => DeleteLevel(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private IEnumerable<LevelDto>? levels;
    private string searchString = "";

    private IEnumerable<LevelDto>? FilteredLevels
    {
        get
        {
            if (levels == null) return null;
            if (string.IsNullOrWhiteSpace(searchString)) return levels;

            return levels.Where(l =>
                l.LevelId.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                l.LevelName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrEmpty(l.LevelDescription) && l.LevelDescription.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            );
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        try
        {
            levels = await LevelService.GetAllLevelsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading levels: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            levels = new List<LevelDto>();
        }
    }

    private async Task RefreshLevels()
    {
        await LoadLevels();
        Snackbar.Add("Level list refreshed!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/levels/create");
    }

    private void NavigateToDetails(string id)
    {
        NavigationManager.NavigateTo($"/levels/details/{id}");
    }

    private void NavigateToEdit(string id)
    {
        NavigationManager.NavigateTo($"/levels/edit/{id}");
    }

    private async Task DeleteLevel(LevelDto level)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete level '{level.LevelName}'?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await LevelService.DeleteLevelAsync(level.LevelId);
                if (success)
                {
                    Snackbar.Add("Level deleted successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadLevels();
                }
                else
                {
                    Snackbar.Add("Error deleting level.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting level: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }
}
