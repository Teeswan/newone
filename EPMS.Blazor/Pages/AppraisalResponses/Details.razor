@page "/appraisalresponses/details/{Id:long}"
@inject EPMS.Blazor.Services.IAppraisalResponseBlazorService AppraisalResponseService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Appraisal Response Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Appraisal Response Details</MudText>
            </MudItem>
        </MudGrid>

        @if (response == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-3">Loading appraisal response...</MudText>
            </div>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" Class="mb-4">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h5">Response #@response.ResponseId</MudText>
                            <MudSpacer />
                            <MudChip T="string" Color="@GetRatingColor(response.RatingValue)" Variant="Variant.Filled">
                                Rating: @response.RatingValue
                            </MudChip>
                            <MudChip T="string" Color="@(response.IsAnonymous == true ? Color.Warning : Color.Secondary)" Variant="Variant.Filled">
                                @(response.IsAnonymous == true ? "Anonymous" : "Public")
                            </MudChip>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Evaluation ID</MudText>
                                    <MudText Typo="Typo.body1" Class="mb-3">@response.EvalId</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Question ID</MudText>
                                    <MudText Typo="Typo.body1" Class="mb-3">@response.QuestionId</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Respondent ID</MudText>
                                    <MudText Typo="Typo.body1" Class="mb-3">@response.RespondentId</MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Answer</MudText>
                                    <MudPaper Elevation="0" Class="pa-3 bg-grey-lighten-5">
                                        <MudText Typo="Typo.body1">@response.AnswerText</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="justify-end">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.ArrowBack">
                                Back to List
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit">
                                Edit
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public long Id { get; set; }

    private EPMS.Shared.DTOs.AppraisalResponseDto? response;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            response = await AppraisalResponseService.GetAppraisalResponseByIdAsync((int)Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading appraisal response details: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalresponses");
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/appraisalresponses/edit/{Id}");
    }

    private Color GetRatingColor(int? rating)
    {
        if (!rating.HasValue) return Color.Secondary;
        
        return rating switch
        {
            >= 4 and <= 5 => Color.Success,
            >= 3 => Color.Warning,
            _ => Color.Error
        };
    }
}