@page "/appraisalresponses/create"
@using EPMS.Shared.Requests
@using EPMS.Domain.Enums
@inject EPMS.Blazor.Services.IAppraisalResponseBlazorService AppraisalResponseService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Appraisal Response</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Create New Appraisal Response</MudText>
            </MudItem>
        </MudGrid>

        <EditForm Model="@createRequest" OnValidSubmit="HandleValidSubmit">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" 
                                     Label="Evaluation ID" 
                                     @bind-Value="createRequest.EvalId" 
                                     Required="true"
                                     RequiredError="Evaluation ID is required"
                                     Variant="Variant.Outlined"
                                     Style="width: 100%" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" 
                                     Label="Question ID" 
                                     @bind-Value="createRequest.QuestionId" 
                                     Required="true"
                                     RequiredError="Question ID is required"
                                     Variant="Variant.Outlined"
                                     Style="width: 100%" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" 
                                     Label="Respondent ID" 
                                     @bind-Value="createRequest.RespondentId" 
                                     Required="true"
                                     RequiredError="Respondent ID is required"
                                     Variant="Variant.Outlined"
                                     Style="width: 100%" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" 
                                     Label="Respondent Employee ID" 
                                     @bind-Value="createRequest.RespondentEmployeeId" 
                                     Variant="Variant.Outlined"
                                     Style="width: 100%" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" 
                               Label="Respondent Role" 
                               @bind-Value="createRequest.RespondentRole" 
                               Required="true"
                               RequiredError="Respondent Role is required"
                               Variant="Variant.Outlined"
                               Style="width: 100%">
                        @foreach (var role in Enum.GetNames(typeof(RespondentRole)))
                        {
                            <MudSelectItem Value="@role">@role</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" 
                                  Label="Answer Text" 
                                  @bind-Value="createRequest.AnswerText" 
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Style="width: 100%" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" 
                                     Label="Rating Value" 
                                     @bind-Value="createRequest.RatingValue" 
                                     Variant="Variant.Outlined"
                                     Style="width: 100%"
                                     Min="0"
                                     Max="5" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch T="bool?" 
                               Label="Is Anonymous" 
                               @bind-Value="createRequest.IsAnonymous" 
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                        Create Response
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CreateAppraisalResponseRequest createRequest = new();
    private bool isAnonymousValue { get; set; } = false;

    private async Task HandleValidSubmit()
    {
        try
        {
            await AppraisalResponseService.CreateAppraisalResponseAsync(createRequest);
            Snackbar.Add("Appraisal response created successfully!", Severity.Success);
            NavigationManager.NavigateTo("/appraisalresponses");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating appraisal response: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalresponses");
    }
}