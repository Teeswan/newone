@page "/appraisalquestions/create"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalQuestionBlazorService AppraisalQuestionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Appraisal Question</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Create New Appraisal Question</MudText>
            </MudItem>
        </MudGrid>

        <EditForm Model="@createRequest" OnValidSubmit="HandleValidSubmit">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" 
                                  Label="Question Text" 
                                  @bind-Value="createRequest.QuestionText" 
                                  Required="true"
                                  RequiredError="Question text is required"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Style="width: 100%" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" 
                                  Label="Category" 
                                  @bind-Value="createRequest.Category" 
                                  Variant="Variant.Outlined"
                                  Style="width: 100%" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch T="bool" 
                               Label="Is Required" 
                               @bind-Value="isRequiredValue" 
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                        Create Question
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CreateAppraisalQuestionRequest createRequest = new();
    private bool isRequiredValue { get; set; } = false;

    private async Task HandleValidSubmit()
    {
        createRequest.IsRequired = isRequiredValue;
        try
        {
            await AppraisalQuestionService.CreateAppraisalQuestionAsync(createRequest);
            Snackbar.Add("Appraisal question created successfully!", Severity.Success);
            NavigationManager.NavigateTo("/appraisalquestions");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating appraisal question: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalquestions");
    }
}