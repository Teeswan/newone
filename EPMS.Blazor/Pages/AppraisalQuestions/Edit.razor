@page "/appraisalquestions/edit/{Id:int}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalQuestionBlazorService AppraisalQuestionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Appraisal Question</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Edit Appraisal Question</MudText>
            </MudItem>
        </MudGrid>

        @if (updateRequest == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-3">Loading appraisal question...</MudText>
            </div>
        }
        else
        {
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string" 
                                      Label="Question Text" 
                                      @bind-Value="updateRequest.QuestionText" 
                                      Required="true"
                                      RequiredError="Question text is required"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Style="width: 100%" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" 
                                      Label="Category" 
                                      @bind-Value="updateRequest.Category" 
                                      Variant="Variant.Outlined"
                                      Style="width: 100%" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" 
                                   Label="Is Required" 
                                   @bind-Checked="isRequiredValue" 
                                   Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack">
                            Cancel
                        </MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                            Save Changes
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateAppraisalQuestionRequest? updateRequest;
    private bool isRequiredValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var question = await AppraisalQuestionService.GetAppraisalQuestionByIdAsync(Id);
        if (question != null)
        {
            updateRequest = new UpdateAppraisalQuestionRequest
            {
                QuestionText = question.QuestionText,
                Category = question.Category,
                IsRequired = question.IsRequired
            };
            isRequiredValue = question.IsRequired ?? false;
        }
        else
        {
            Snackbar.Add("Appraisal question not found.", Severity.Error);
            NavigationManager.NavigateTo("/appraisalquestions");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsRequired = isRequiredValue;
            try
            {
                await AppraisalQuestionService.UpdateAppraisalQuestionAsync(Id, updateRequest);
                Snackbar.Add("Appraisal question updated successfully!", Severity.Success);
                NavigationManager.NavigateTo("/appraisalquestions");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating appraisal question: {ex.Message}", Severity.Error);
            }
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalquestions");
    }
}