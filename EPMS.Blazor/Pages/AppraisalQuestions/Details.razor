@page "/appraisalquestions/details/{Id:int}"
@inject EPMS.Blazor.Services.IAppraisalQuestionBlazorService AppraisalQuestionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Appraisal Question Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Class="mb-4">
            <MudItem>
                <MudText Typo="Typo.h4">Appraisal Question Details</MudText>
            </MudItem>
        </MudGrid>

        @if (question == null)
        {
            <div class="text-center py-10">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-3">Loading appraisal question...</MudText>
            </div>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" Class="mb-4">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h5" Class="truncate">@question.QuestionText</MudText>
                            <MudSpacer />
                            <MudChip T="string" Color="@(question.IsRequired == true ? Color.Primary : Color.Secondary)" Variant="Variant.Filled">
                                @(question.IsRequired == true ? "Required" : "Optional")
                            </MudChip>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Question ID</MudText>
                                    <MudText Typo="Typo.body1" Class="mb-3">@question.QuestionId</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary">Category</MudText>
                                    <MudText Typo="Typo.body1" Class="mb-3">@question.Category</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="justify-end">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.ArrowBack">
                                Back to List
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit">
                                Edit
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private EPMS.Shared.DTOs.AppraisalQuestionDto? question;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            question = await AppraisalQuestionService.GetAppraisalQuestionByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading appraisal question details: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/appraisalquestions");
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/appraisalquestions/edit/{Id}");
    }
}