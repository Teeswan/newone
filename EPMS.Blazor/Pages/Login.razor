@page "/login"
@attribute [AllowAnonymous]
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using EPMS.Client.Identity 
@using EPMS.Blazor.Services

@inject IAuthBlazorService AuthService
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<style>
    html, body, #app, .mud-layout, .main-layout, .login-main-content {
        margin: 0 !important;
        padding: 0 !important;
        height: 100% !important;
        width: 100% !important;
        box-sizing: border-box !important;
    }

    *, *::before, *::after {
        box-sizing: inherit !important;
    }

    .login-container {
        width: 100%;
        height: 100%;
        display: flex;
        background: #ffffff;
    }

    .login-left {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 24px 40px;
    }

    .login-right {
        display: none;
        width: 100%;
        background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
        padding: 60px;
        position: relative;
        overflow: hidden;
    }

    @@media (min-width: 1024px) {
        .login-left {
            width: 50%;
        }
        .login-right {
            display: flex;
            width: 50%;
            align-items: center;
            justify-content: center;
        }
    }

    .login-card {
        background: white;
        border-radius: 16px;
        padding: 40px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    }

    .card-title {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
        text-align: center;
        margin-bottom: 6px;
    }

    .card-subtitle {
        font-size: 14px;
        color: #64748b;
        text-align: center;
        margin-bottom: 32px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-size: 15px;
        transition: all 0.2s ease;
        outline: none;
        background: white;
    }

    .form-input:focus {
        border-color: #cbd5e1;
        background: #eff6ff;
    }

    .form-input::placeholder {
        color: #94a3b8;
    }

    .form-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .remember-me {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .remember-me input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: #2563eb;
    }

    .remember-me span {
        font-size: 13px;
        color: #475569;
    }

    .forgot-link {
        font-size: 13px;
        color: #2563eb;
        font-weight: 600;
        text-decoration: none;
    }

    .forgot-link:hover {
        text-decoration: underline;
    }

    .signin-btn {
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .signin-btn:hover {
        background: #1d4ed8;
    }

    .signin-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        background: #93c5fd;
    }

    .welcome-content {
        max-width: 480px;
        color: white;
        position: relative;
        z-index: 2;
    }

    .welcome-title {
        font-size: 44px;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 24px;
    }

    .welcome-desc {
        font-size: 15px;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.7;
        margin-bottom: 48px;
    }

    .dashboard-visual {
        background: #f8fafc;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .dashboard-title {
        font-size: 15px;
        font-weight: 600;
        color: #0f172a;
    }

    .dashboard-legend {
        display: flex;
        gap: 16px;
        font-size: 12px;
        color: #64748b;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .legend-dot.blue {
        background: #2563eb;
    }

    .legend-dot.light {
        background: #cbd5e1;
    }

    .chart-container {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 10px;
        height: 180px;
        padding: 0 4px;
    }

    .chart-bar {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .bar-stack {
        height: 140px;
        display: flex;
        flex-direction: column-reverse;
        border-radius: 8px;
        overflow: hidden;
        background: #e2e8f0;
    }

    .bar-bottom {
        background: #2563eb;
        min-height: 0;
    }

    .bar-label {
        font-size: 11px;
        color: #64748b;
        text-align: center;
        font-weight: 500;
    }

    .error-message {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;+
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-top: 16px;
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }
</style>

<div class="login-container">
    <div class="login-left">
        <div class="login-card">
            <h2 class="card-title">Sign In</h2>
            <p class="card-subtitle">Welcome back! Please enter your details</p>

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Email</label>
                    <input 
                        type="email" 
                        class="form-input" 
                        placeholder="Enter your email"
                        @bind="loginModel.Email" />
                    <ValidationMessage For="@(() => loginModel.Email)" class="error-message" />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div style="position: relative;">
                        <input 
                            type="@(showPassword ? "text" : "password")" 
                            class="form-input" 
                            placeholder="••••••••"
                            @bind="loginModel.Password"
                            style="padding-right: 44px;" />
                        <button 
                            type="button"
                            @onclick="TogglePasswordVisibility"
                            style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; padding: 4px;">
                            <MudIcon Icon="@(showPassword ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)" Style="color: #64748b; font-size: 20px;" />
                        </button>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" class="error-message" />
                </div>

                <div class="form-row">
                    <label class="remember-me">
                        <input type="checkbox" @bind="rememberMe" />
                        <span>Remember for 30 Days</span>
                    </label>
                    <a href="/forgot-password" class="forgot-link">Forgot password</a>
                </div>

                <button type="submit" class="signin-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" />
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>Sign in</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-message">
                        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="color: #dc2626; flex-shrink: 0;" />
                        @errorMessage
                    </div>
                }
            </EditForm>
        </div>
    </div>

    <div class="login-right">
        <div class="welcome-content">
            <h1 class="welcome-title">
                Welcome back!<br/>
                Please sign in to your<br/>
                EPMS account
            </h1>
            <p class="welcome-desc">
                Empower your team, track progress, and achieve excellence together.
                Lorem ipsum dolor sit amet, facilisi neque lectus turpis id tincidunt eget.
            </p>
            
            <div class="dashboard-visual">
                <div class="dashboard-header">
                    <div class="dashboard-title">Performance Report</div>
                    <div class="dashboard-legend">
                        <div class="legend-item">
                            <div class="legend-dot blue"></div>
                            Target
                        </div>
                        <div class="legend-item">
                            <div class="legend-dot light"></div>
                            Actual
                        </div>
                    </div>
                </div>
                <div class="chart-container">
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 70%;"></div>
                        </div>
                        <div class="bar-label">Jan</div>
                    </div>
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 65%;"></div>
                        </div>
                        <div class="bar-label">Feb</div>
                    </div>
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 80%;"></div>
                        </div>
                        <div class="bar-label">Mar</div>
                    </div>
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 75%;"></div>
                        </div>
                        <div class="bar-label">Apr</div>
                    </div>
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 85%;"></div>
                        </div>
                        <div class="bar-label">May</div>
                    </div>
                    <div class="chart-bar">
                        <div class="bar-stack">
                            <div class="bar-bottom" style="height: 90%;"></div>
                        </div>
                        <div class="bar-label">Jun</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool showPassword;
    private bool isLoading;
    private bool rememberMe;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        isLoading = true;
        
        try
        {
            var result = await AuthService.LoginAsync(loginModel);

            if (result != null)
            {
                await LocalStorage.SetItemAsync("authToken", result.Token);
                await LocalStorage.SetItemAsync("loginResponse", result);
                ((JwtAuthenticationStateProvider)AuthStateProvider).NotifyUserAuthentication(result.Token);
                
                if (result.IsFirstLogin)
                {
                    Navigation.NavigateTo("/change-password");
                    Snackbar.Add("Please change your password to continue.", Severity.Warning, config => {
                        config.Icon = Icons.Material.Outlined.Warning;
                    });
                }
                else
                {
                    Navigation.NavigateTo("/");
                    Snackbar.Add("Welcome back! Login successful.", Severity.Success, config => {
                        config.Icon = Icons.Material.Outlined.CheckCircle;
                    });
                }
            }
            else
            {
                errorMessage = "Invalid email or password. Please try again.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Server error - please check your connection and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}