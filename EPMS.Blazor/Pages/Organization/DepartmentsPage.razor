@page "/departments"
@attribute [Authorize]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using EPMS.Blazor.Dialogs
@using EPMS.Blazor.Pages.Departments
@inject IDepartmentBlazorService DepartmentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IPermissionCheckerService PermissionChecker

<PageTitle>Departments</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-8">
        <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
            <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-3" />
            All Departments
        </MudText>
        <div class="d-flex gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportToExcelAsync" Class="rounded-lg">
                Excel
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="ExportToPdfAsync" Class="rounded-lg">
                PDF
            </MudButton>
            @if (_canCreate)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload" OnClick="OpenImportDialog" Class="rounded-lg">
                    Import
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenDepartmentAddDialog" Class="rounded-lg">
                    Add Department
                </MudButton>
            }
        </div>
    </div>

    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
        <MudTextField @bind-Value="_search" Placeholder="Search departments..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
    </MudPaper>

    @if (_isLoading)
    {
        <MudPaper Elevation="2" Class="pa-6 rounded-xl">
            <MudSkeletonLoader Animated="true" SkeletonType="SkeletonType.Text" Width="100%" Height="40px" Class="mb-4" />
            <MudSkeletonLoader Animated="true" SkeletonType="SkeletonType.Text" Width="80%" Height="40px" Class="mb-4" />
            <MudSkeletonLoader Animated="true" SkeletonType="SkeletonType.Text" Width="90%" Height="40px" />
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="2" Class="pa-6 rounded-xl">
            <MudTable Items="_departments" T="DepartmentDto" Hover="true" Breakpoint="Breakpoint.Sm" Filter="new Func<DepartmentDto,bool>(Filter)" Class="rounded-lg">
                <HeaderContent>
                    <MudTh>Code</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Parent</MudTh>
                    <MudTh Style="width: 150px;">Status</MudTh>
                    <MudTh Style="width: 250px; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Code">@context.DepartmentIdName</MudTd>
                    <MudTd DataLabel="Name">@context.DepartmentName</MudTd>
                    <MudTd DataLabel="Parent">@context.ParentDepartmentName</MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Active</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">Inactive</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right; white-space: nowrap;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewDepartmentDetails(context))" Title="View Details" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToTeams(context))">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2" />
                            View Teams
                        </MudButton>
                        @if (_canEdit)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OpenDepartmentEditDialog(context))" />
                        }
                        @if (_canDelete)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteDepartment(context.DepartmentId))" />
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<DepartmentDto> _departments = new();
    private bool _isLoading = true;
    private string _search = "";
    private bool _canCreate = false;
    private bool _canEdit = false;
    private bool _canDelete = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
        await LoadDepartments();
    }

    private async Task LoadPermissions()
    {
        _canCreate = await PermissionChecker.CanCreateAsync("Departments");
        _canEdit = await PermissionChecker.CanEditAsync("Departments");
        _canDelete = await PermissionChecker.CanDeleteAsync("Departments");
    }

    private async Task LoadDepartments()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            _departments = (await DepartmentService.GetAllDepartmentsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading departments: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void NavigateToTeams(DepartmentDto dept) => Navigation.NavigateTo($"/departments/{dept.DepartmentId}/teams");
    
    private async Task ViewDepartmentDetails(DepartmentDto dept)
    {
        var parameters = new DialogParameters { ["Department"] = dept };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        DialogService.Show<DepartmentDetailsDialog>("Department Details", parameters, options);
    }

    private bool Filter(DepartmentDto dept) => 
        string.IsNullOrWhiteSpace(_search) || 
        dept.DepartmentName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        (dept.DepartmentIdName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    private async Task OpenDepartmentAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<DepartmentDialog>("Add Department", options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await Task.Delay(200);
            await LoadDepartments();
        }
    }
    
    private async Task OpenDepartmentEditDialog(DepartmentDto dept)
    {
        var parameters = new DialogParameters { ["Id"] = dept.DepartmentId };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<DepartmentDialog>("Edit Department", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await Task.Delay(200);
            await LoadDepartments();
        }
    }
    
    private async Task DeleteDepartment(int id)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this department?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var success = await DepartmentService.DeleteDepartmentAsync(id);
            if (success)
            {
                Snackbar.Add("Department deleted successfully!", Severity.Success);
                await LoadDepartments();
            }
            else
            {
                Snackbar.Add("Error deleting department.", Severity.Error);
            }
        }
    }

    private async Task OpenImportDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<ImportDepartmentDialog>("Import Departments", options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await Task.Delay(200);
            await LoadDepartments();
        }
    }

    private async Task ExportToExcelAsync()
    {
        try
        {
            var fileBytes = await DepartmentService.ExportToExcelAsync();
            await JSRuntime.InvokeVoidAsync("eval", @"
                (function() {
                    window.BlazorDownloadFile = function(filename, contentType, content) {
                        const link = document.createElement('a');
                        const fileUrl = 'data:' + contentType + ';base64,' + content;
                        link.href = fileUrl;
                        link.download = filename;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    };
                })();
            ");
            await JSRuntime.InvokeVoidAsync("BlazorDownloadFile", "Departments.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", Convert.ToBase64String(fileBytes));
            Snackbar.Add("Exported to Excel!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportToPdfAsync()
    {
        try
        {
            var fileBytes = await DepartmentService.ExportToPdfAsync();
            await JSRuntime.InvokeVoidAsync("eval", @"
                (function() {
                    window.BlazorDownloadFile = function(filename, contentType, content) {
                        const link = document.createElement('a');
                        const fileUrl = 'data:' + contentType + ';base64,' + content;
                        link.href = fileUrl;
                        link.download = filename;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    };
                })();
            ");
            await JSRuntime.InvokeVoidAsync("BlazorDownloadFile", "Departments.pdf", "application/pdf", Convert.ToBase64String(fileBytes));
            Snackbar.Add("Exported to PDF!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }
}
