@using Microsoft.AspNetCore.Components.Forms
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Upload Profile Picture</MudText>
        <InputFile OnChange="HandleFileSelected" Accept="image/*" class="my-4" />
        @if (selectedImageBytes != null)
        {
            <div class="flex justify-center my-4">
                <MudAvatar Size="Size.Large">
                    <img src="data:image/*;base64,@Convert.ToBase64String(selectedImageBytes)"
                         alt="Preview"
                         style="width: 100%; height: 100%; object-fit: cover; object-position: 50% 20%; border-radius: 50%;" />
                </MudAvatar>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Disabled="selectedImageBytes == null" Variant="Variant.Filled">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private byte[]? selectedImageBytes;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && file.Size > 0)
        {
            if (file.Size > 5 * 1024 * 1024)
            {
                Snackbar.Add("File size must be less than 5MB", Severity.Error);
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            selectedImageBytes = memoryStream.ToArray();
        }
    }

    private void Save()
    {
        MudDialog.Close(DialogResult.Ok(selectedImageBytes));
    }
}
