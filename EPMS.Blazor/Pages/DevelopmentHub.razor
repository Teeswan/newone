@page "/development-hub"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using MudBlazor
@inject IPipClientService PipService
@inject IMeetingBlazorService MeetingService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Development Hub</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-6">
        
        @* 1:1 Meetings Tab *@
        <MudTabPanel Text="1:1 Meetings" Icon="@Icons.Material.Filled.People">
            <div class="d-flex justify-space-between align-center mb-6">
                <MudText Typo="Typo.h5" Style="font-weight: 700;">1:1 Meetings</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => NavigationManager.NavigateTo("/one-on-one-meetings/create"))" Class="rounded-lg px-6 py-2 shadow-lg">
                    Schedule New
                </MudButton>
            </div>

            @if (_meetingsLoading)
            {
                <div class="text-center py-10">
                    <MudProgressCircular Indeterminate="true" />
                    <MudText Class="mt-3">Loading meetings...</MudText>
                </div>
            }
            else if (_meetings == null || !_meetings.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">No meetings found.</MudAlert>
            }
            else
            {
                <MudTable Items="@_meetings.OrderByDescending(m => m.ScheduledDateTime)" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="rounded-lg">
                    <HeaderContent>
                        <MudTh>Date & Time</MudTh>
                        <MudTh>With</MudTh>
                        <MudTh>Location</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date & Time">@context.ScheduledDateTime?.ToString("g")</MudTd>
                        <MudTd DataLabel="With">@(isManager ? context.EmployeeName : context.ManagerName)</MudTd>
                        <MudTd DataLabel="Location">@context.Location</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@GetMeetingStatusColor(context.MeetingStatus)" Size="Size.Small" Variant="Variant.Filled">
                                @context.MeetingStatus
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/one-on-one-meetings/{context.MeetingId}"))" />
                            @if (context.CanJoin && (context.MeetingStatus == "Scheduled" || context.MeetingStatus == "InProgress"))
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.VideoCall" Color="Color.Success" Size="Size.Small" OnClick="@(() => JoinMeeting(context.MeetingId))" />
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>

        @* Performance Improvement Plans Tab *@
        <MudTabPanel Text="Performance Improvement Plans" Icon="@Icons.Material.Filled.TrendingUp">
            <div class="d-flex justify-space-between align-center mb-6">
                <MudText Typo="Typo.h5" Style="font-weight: 700;">Performance Improvement Plans</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => NavigationManager.NavigateTo("/pip/create"))" Class="rounded-lg px-6 py-2 shadow-lg">
                    New PIP
                </MudButton>
            </div>

            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudSelect T="string" Label="Filter by Status" Value="@_pipStatusFilter" ValueChanged="OnPipStatusFilterChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="string" Value="@("All")">All Statuses</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Terminated")">Terminated</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Extended")">Extended</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (_pipLoading)
            {
                <div class="text-center py-10">
                    <MudProgressCircular Indeterminate="true" />
                    <MudText Class="mt-3">Loading PIPs...</MudText>
                </div>
            }
            else if (_plans == null || !_plans.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">No PIPs found.</MudAlert>
            }
            else
            {
                <MudTable Items="_plans" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="rounded-lg">
                    <HeaderContent>
                        <MudTh>Employee</MudTh>
                        <MudTh>Manager</MudTh>
                        <MudTh>Start Date</MudTh>
                        <MudTh>End Date</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Objectives</MudTh>
                        <MudTh Style="text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Employee">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Manager">@context.ManagerName</MudTd>
                        <MudTd DataLabel="Start Date">@context.StartDate.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="End Date">@context.EndDate.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="GetPipStatusColor(context.Status)" Variant="Variant.Filled" Size="Size.Small">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Objectives">
                            @if (context.Objectives.Any())
                            {
                                <MudText Typo="Typo.body2">@context.Objectives.Count(o => o.IsAchieved) / @context.Objectives.Count</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="text-muted">None</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/pip/{context.PipId}"))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/pip/edit/{context.PipId}"))" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>

    </MudTabs>
</MudContainer>

@code {
    private IEnumerable<PipPlanDto>? _plans;
    private IEnumerable<MeetingDto>? _meetings;
    private bool _pipLoading = true;
    private bool _meetingsLoading = true;
    private bool isManager = true;
    private string _pipStatusFilter = "All";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadPipData(), LoadMeetingData());
    }

    private async Task LoadPipData()
    {
        _pipLoading = true;
        try
        {
            var response = await PipService.GetAllAsync();
            if (response?.Success == true)
            {
                _plans = _pipStatusFilter == "All"
                    ? response.Data
                    : response.Data?.Where(p => p.Status == _pipStatusFilter);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading PIPs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _pipLoading = false;
        }
    }

    private async Task LoadMeetingData()
    {
        _meetingsLoading = true;
        try
        {
            _meetings = await MeetingService.GetManagerMeetingsAsync();
            isManager = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading meetings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _meetingsLoading = false;
        }
    }

    private async Task OnPipStatusFilterChanged(string? value)
    {
        _pipStatusFilter = value ?? "All";
        await LoadPipData();
    }

    private async Task JoinMeeting(int id)
    {
        try
        {
            var joinUrl = await MeetingService.JoinMeetingAsync(id);
            NavigationManager.NavigateTo(joinUrl);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error joining meeting: {ex.Message}", Severity.Error);
        }
    }

    private Color GetPipStatusColor(string status) => status.ToLower() switch
    {
        "active" => Color.Primary,
        "completed" => Color.Success,
        "terminated" => Color.Error,
        "extended" => Color.Warning,
        _ => Color.Default
    };

    private Color GetMeetingStatusColor(string? status) => status switch
    {
        "Scheduled" => Color.Primary,
        "InProgress" => Color.Info,
        "PendingConfirmation" => Color.Warning,
        "Completed" => Color.Success,
        "Rescheduled" => Color.Secondary,
        "Skipped" => Color.Error,
        _ => Color.Default
    };
}
