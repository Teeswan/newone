@page "/performanceoutcomes/details/{Id:int}"
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using EPMS.Domain.Enums
@inject IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject IPerformanceEvaluationBlazorService EvaluationService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h4">Performance Outcome Details</MudText>
            <MudChip T="string" Color="@GetStatusColor(outcome?.ApprovalStatus)">@(outcome?.ApprovalStatus ?? "N/A")</MudChip>
        </MudStack>
        <MudDivider Class="mb-6" />

        @if (outcome == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Outcome ID</MudText>
                    <MudText Typo="Typo.body1">@outcome.OutcomeId</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Employee ID</MudText>
                    <MudText Typo="Typo.body1">@outcome.EmployeeId</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Cycle ID</MudText>
                    <MudText Typo="Typo.body1">@outcome.CycleId</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Evaluation ID</MudText>
                    <MudText Typo="Typo.body1">@(outcome.EvalId?.ToString() ?? "N/A")</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Recommendation Type</MudText>
                    <MudText Typo="Typo.body1">@outcome.RecommendationType</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Old Position ID</MudText>
                    <MudText Typo="Typo.body1">@(outcome.OldPositionId?.ToString() ?? "N/A")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">New Position ID</MudText>
                    <MudText Typo="Typo.body1">@(outcome.NewPositionId?.ToString() ?? "N/A")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Old Level ID</MudText>
                    <MudText Typo="Typo.body1">@(string.IsNullOrEmpty(outcome.OldLevelId) ? "N/A" : outcome.OldLevelId)</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">New Level ID</MudText>
                    <MudText Typo="Typo.body1">@(string.IsNullOrEmpty(outcome.NewLevelId) ? "N/A" : outcome.NewLevelId)</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Effective Date</MudText>
                    <MudText Typo="Typo.body1">@(outcome.EffectiveDate?.ToString("yyyy-MM-dd") ?? "N/A")</MudText>
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-6">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToList" Class="mr-2">Back to List</MudButton>
                    @if (outcome?.EvalId.HasValue == true)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="DownloadEvaluationReport" StartIcon="@Icons.Material.Filled.Download" Class="mr-2">Download Eval RDLC</MudButton>
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="NavigateToEdit">Edit</MudButton>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private PerformanceOutcomeDto? outcome;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            outcome = await PerformanceOutcomeService.GetPerformanceOutcomeByIdAsync(Id);
            if (outcome == null)
            {
                Snackbar.Add("Performance outcome not found.", Severity.Error);
                NavigationManager.NavigateTo("/performanceoutcomes");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance outcome details: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/performanceoutcomes");
        }
    }

    private void BackToList() => NavigationManager.NavigateTo("/performanceoutcomes");
    private void NavigateToEdit() => NavigationManager.NavigateTo($"/performanceoutcomes/edit/{Id}");

    private async Task DownloadEvaluationReport()
    {
        if (outcome?.EvalId == null) return;

        try
        {
            var eval = await EvaluationService.GetPerformanceEvaluationByIdAsync(outcome.EvalId.Value);
            if (eval == null)
            {
                Snackbar.Add("Could not find related evaluation details.", Severity.Warning);
                return;
            }

            byte[] fileBytes;
            string fileName;

            switch (eval.FormType)
            {
                case AppraisalFormType.SelfAssessment:
                    fileBytes = await EvaluationService.DownloadSelfAssessmentRdlcAsync(eval.EvalId);
                    fileName = $"SelfAssessment_{eval.EmployeeName}_{DateTime.Now:yyyyMMdd}.pdf";
                    break;
                case AppraisalFormType.Feedback360:
                    fileBytes = await EvaluationService.Download360FeedbackRdlcAsync(eval.EvalId);
                    fileName = $"360Feedback_{eval.EmployeeName}_{DateTime.Now:yyyyMMdd}.pdf";
                    break;
                default:
                    fileBytes = await EvaluationService.DownloadPerformanceAppraisalRdlcAsync(eval.EvalId);
                    fileName = $"PerformanceAppraisal_{eval.EmployeeName}_{DateTime.Now:yyyyMMdd}.pdf";
                    break;
            }

            if (fileBytes != null && fileBytes.Length > 0)
            {
                var base64 = Convert.ToBase64String(fileBytes);
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64);
                Snackbar.Add("Report downloaded successfully!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error downloading report: {ex.Message}", Severity.Error);
        }
    }

    private Color GetStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "pending" => Color.Warning,
            "approved" => Color.Success,
            "rejected" => Color.Error,
            _ => Color.Default
        };
    }
}
