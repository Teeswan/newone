@page "/performanceoutcomes/create"
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject IEmployeeBlazorService EmployeeService
@inject IAppraisalCycleBlazorService CycleService
@inject IPerformanceEvaluationBlazorService EvaluationService
@inject IPositionBlazorService PositionService
@inject ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Create Performance Outcome</MudText>
        <MudDivider Class="mb-6" />

        <MudForm Model="@createRequest" @ref="@form" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Employee" @bind-Value="createRequest.EmployeeId" Required="true" Variant="Variant.Outlined">
                        @if (employees != null)
                        {
                            @foreach (var emp in employees)
                            {
                                <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Appraisal Cycle" @bind-Value="createRequest.CycleId" Required="true" Variant="Variant.Outlined">
                        @if (cycles != null)
                        {
                            @foreach (var cycle in cycles)
                            {
                                <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Evaluation" @bind-Value="createRequest.EvalId" Variant="Variant.Outlined">
                        @if (evaluations != null)
                        {
                            @foreach (var eval in evaluations)
                            {
                                <MudSelectItem T="int?" Value="@eval.EvalId">Eval ID: @eval.EvalId (@eval.EmployeeName)</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Recommendation Type" @bind-Value="createRequest.RecommendationType" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Old Position" @bind-Value="createRequest.OldPositionId" Variant="Variant.Outlined">
                        @if (positions != null)
                        {
                            @foreach (var pos in positions)
                            {
                                <MudSelectItem T="int?" Value="@pos.PositionId">@pos.PositionTitle</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="New Position" @bind-Value="createRequest.NewPositionId" Variant="Variant.Outlined">
                        @if (positions != null)
                        {
                            @foreach (var pos in positions)
                            {
                                <MudSelectItem T="int?" Value="@pos.PositionId">@pos.PositionTitle</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Old Level" @bind-Value="createRequest.OldLevelId" Variant="Variant.Outlined">
                        @if (levels != null)
                        {
                            @foreach (var level in levels)
                            {
                                <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="New Level" @bind-Value="createRequest.NewLevelId" Variant="Variant.Outlined">
                        @if (levels != null)
                        {
                            @foreach (var level in levels)
                            {
                                <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Approval Status" @bind-Value="createRequest.ApprovalStatus" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                        <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                        <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Effective Date" @bind-Date="effectiveDateValue" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Create</MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? form;
    private CreatePerformanceOutcomeRequest createRequest = new() { ApprovalStatus = "Pending" };
    private DateTime? effectiveDateValue { get; set; }

    private List<EmployeeDto>? employees;
    private List<AppraisalCycleDto>? cycles;
    private List<PerformanceEvaluationDto>? evaluations;
    private List<PositionDto>? positions;
    private List<LevelDto>? levels;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await EmployeeService.GetEmployeesAsync();
            var cyclesEnumerable = await CycleService.GetAllAppraisalCyclesAsync();
            cycles = cyclesEnumerable.ToList();
            var evalsEnumerable = await EvaluationService.GetAllPerformanceEvaluationsAsync();
            evaluations = evalsEnumerable.ToList();
            var posEnumerable = await PositionService.GetAllPositionsAsync();
            positions = posEnumerable.ToList();
            var levelsEnumerable = await LevelService.GetAllLevelsAsync();
            levels = levelsEnumerable.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading lookup data: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleValidSubmit()
    {
        await form!.Validate();
        if (form.IsValid)
        {
            if (effectiveDateValue.HasValue)
            {
                createRequest.EffectiveDate = DateOnly.FromDateTime(effectiveDateValue.Value);
            }

            try
            {
                await PerformanceOutcomeService.CreatePerformanceOutcomeAsync(createRequest);
                Snackbar.Add("Performance outcome created successfully.", Severity.Success);
                NavigationManager.NavigateTo("/performanceoutcomes");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating performance outcome: {ex.Message}", Severity.Error);
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performanceoutcomes");
}
