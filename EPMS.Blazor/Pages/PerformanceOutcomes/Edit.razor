@page "/performanceoutcomes/edit/{Id:int}"
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject IEmployeeBlazorService EmployeeService
@inject IAppraisalCycleBlazorService CycleService
@inject IPerformanceEvaluationBlazorService EvaluationService
@inject IPositionBlazorService PositionService
@inject ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Edit Performance Outcome</MudText>
        <MudDivider Class="mb-6" />

        @if (updateRequest == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudForm Model="@updateRequest" @ref="@form" ValidationDelay="0">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Employee" @bind-Value="updateRequest.EmployeeId" Required="true" Variant="Variant.Outlined">
                            @if (employees != null)
                            {
                                @foreach (var emp in employees)
                                {
                                    <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Appraisal Cycle" @bind-Value="updateRequest.CycleId" Required="true" Variant="Variant.Outlined">
                            @if (cycles != null)
                            {
                                @foreach (var cycle in cycles)
                                {
                                    <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Evaluation" @bind-Value="updateRequest.EvalId" Variant="Variant.Outlined">
                            @if (evaluations != null)
                            {
                                @foreach (var eval in evaluations)
                                {
                                    <MudSelectItem T="int?" Value="@eval.EvalId">Eval ID: @eval.EvalId (@eval.EmployeeName)</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Recommendation Type" @bind-Value="updateRequest.RecommendationType" Required="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Old Position" @bind-Value="updateRequest.OldPositionId" Variant="Variant.Outlined">
                            @if (positions != null)
                            {
                                @foreach (var pos in positions)
                                {
                                    <MudSelectItem T="int?" Value="@pos.PositionId">@pos.PositionTitle</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="New Position" @bind-Value="updateRequest.NewPositionId" Variant="Variant.Outlined">
                            @if (positions != null)
                            {
                                @foreach (var pos in positions)
                                {
                                    <MudSelectItem T="int?" Value="@pos.PositionId">@pos.PositionTitle</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Old Level" @bind-Value="updateRequest.OldLevelId" Variant="Variant.Outlined">
                            @if (levels != null)
                            {
                                @foreach (var level in levels)
                                {
                                    <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="New Level" @bind-Value="updateRequest.NewLevelId" Variant="Variant.Outlined">
                            @if (levels != null)
                            {
                                @foreach (var level in levels)
                                {
                                    <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Approval Status" @bind-Value="updateRequest.ApprovalStatus" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                            <MudSelectItem Value="@("Requires HR Review")">Requires HR Review</MudSelectItem>
                            <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                            <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Effective Date" @bind-Date="effectiveDateValue" Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Save Changes</MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private MudForm? form;
    private UpdatePerformanceOutcomeRequest? updateRequest;
    private DateTime? effectiveDateValue { get; set; }

    private List<EmployeeDto>? employees;
    private List<AppraisalCycleDto>? cycles;
    private List<PerformanceEvaluationDto>? evaluations;
    private List<PositionDto>? positions;
    private List<LevelDto>? levels;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await EmployeeService.GetEmployeesAsync();
            var cyclesEnumerable = await CycleService.GetAllAppraisalCyclesAsync();
            cycles = cyclesEnumerable.ToList();
            var evalsEnumerable = await EvaluationService.GetAllPerformanceEvaluationsAsync();
            evaluations = evalsEnumerable.ToList();
            var posEnumerable = await PositionService.GetAllPositionsAsync();
            positions = posEnumerable.ToList();
            var levelsEnumerable = await LevelService.GetAllLevelsAsync();
            levels = levelsEnumerable.ToList();

            var outcome = await PerformanceOutcomeService.GetPerformanceOutcomeByIdAsync(Id);
            if (outcome != null)
            {
                updateRequest = new UpdatePerformanceOutcomeRequest
                {
                    EmployeeId = outcome.EmployeeId,
                    CycleId = outcome.CycleId,
                    EvalId = outcome.EvalId,
                    RecommendationType = outcome.RecommendationType,
                    OldPositionId = outcome.OldPositionId,
                    NewPositionId = outcome.NewPositionId,
                    OldLevelId = outcome.OldLevelId,
                    NewLevelId = outcome.NewLevelId,
                    ApprovalStatus = outcome.ApprovalStatus,
                    EffectiveDate = outcome.EffectiveDate
                };
                if (outcome.EffectiveDate.HasValue)
                {
                    effectiveDateValue = outcome.EffectiveDate.Value.ToDateTime(TimeOnly.MinValue);
                }
            }
            else
            {
                Snackbar.Add("Performance outcome not found.", Severity.Error);
                NavigationManager.NavigateTo("/performanceoutcomes");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance outcome: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/performanceoutcomes");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null && form != null)
        {
            await form.Validate();
            if (form.IsValid)
            {
                if (effectiveDateValue.HasValue)
                {
                    updateRequest.EffectiveDate = DateOnly.FromDateTime(effectiveDateValue.Value);
                }
                try
                {
                    await PerformanceOutcomeService.UpdatePerformanceOutcomeAsync(Id, updateRequest);
                    Snackbar.Add("Performance outcome updated successfully.", Severity.Success);
                    NavigationManager.NavigateTo("/performanceoutcomes");
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error updating performance outcome: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performanceoutcomes");
}
