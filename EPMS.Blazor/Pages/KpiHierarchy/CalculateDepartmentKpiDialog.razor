@using System
@using System.Threading
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@inject IKpiHierarchyBlazorService KpiService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-3 mb-n1" />
            Department KPI Performance Entry - @DepartmentName
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center py-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!_kpis.Any())
        {
            <MudAlert Severity="Severity.Info">No KPIs found for this department. Please ensure KPIs are assigned to the department first.</MudAlert>
        }
        else
        {
            <MudTable Items="_kpis" Hover="true" Elevation="0" Dense="true" FixedHeader="true" Height="400px">
                <HeaderContent>
                    <MudTh>KPI Name</MudTh>
                    <MudTh Style="width: 100px;">Weight</MudTh>
                    <MudTh Style="width: 100px;">Target</MudTh>
                    <MudTh Style="width: 150px;">Actual Value</MudTh>
                    <MudTh Style="width: 100px;">Score</MudTh>
                    <MudTh Style="width: 100px;">Weighted</MudTh>
                </HeaderContent>
                <RowTemplate Context="kpi">
                    <MudTd>@kpi.KpiName</MudTd>
                    <MudTd>@kpi.Weight%</MudTd>
                    <MudTd>@kpi.DepartmentTarget</MudTd>
                    <MudTd>
                        <MudNumericField T="decimal" Value="@(kpi.ActualValue ?? 0)" 
                                         ValueChanged="@(v => UpdateActual(kpi, v))"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        <MudText Color="@GetScoreColor(CalculateScore(kpi))" Style="font-weight: 600;">
                            @CalculateScore(kpi).ToString("F2")%
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Style="font-weight: 600;">
                            @CalculateWeightedScore(kpi).ToString("F2")
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTFootRow>
                        <MudTd colspan="5" Style="text-align: right; font-weight: 700;">Total Department Score:</MudTd>
                        <MudTd Style="font-weight: 700;">
                            <MudText Color="Color.Primary" Typo="Typo.h6">
                                @_kpis.Sum(k => CalculateWeightedScore(k)).ToString("F2")
                            </MudText>
                        </MudTd>
                    </MudTFootRow>
                </FooterContent>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(_loading || _processing || !_kpis.Any())">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Saving...</MudText>
            }
            else
            {
                <MudText>Save Department Performance</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int DepartmentId { get; set; }
    [Parameter] public string DepartmentName { get; set; } = "";

    private List<DepartmentKpiDto> _kpis = new();
    private bool _loading = true;
    private bool _processing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadKpis();
    }

    private async Task LoadKpis()
    {
        _loading = true;
        try
        {
            // Trigger backend calculation which aggregates from teams
            var result = await KpiService.CalculateDepartmentAsync(DepartmentId);
            _kpis = result.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading Department KPIs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void UpdateActual(DepartmentKpiDto kpi, decimal value)
    {
        kpi.ActualValue = value;
        StateHasChanged();
    }

    private decimal CalculateScore(DepartmentKpiDto kpi)
    {
        if ((kpi.DepartmentTarget ?? 0) == 0) return 0;
        return ((kpi.ActualValue ?? 0) / (kpi.DepartmentTarget ?? 1)) * 100;
    }

    private decimal CalculateWeightedScore(DepartmentKpiDto kpi)
    {
        return (CalculateScore(kpi) * (kpi.Weight ?? 0)) / 100;
    }

    private Color GetScoreColor(decimal score)
    {
        if (score >= 100) return Color.Success;
        if (score >= 75) return Color.Info;
        if (score >= 50) return Color.Warning;
        return Color.Error;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _processing = true;
        try
        {
            foreach (var kpi in _kpis)
            {
                var request = new DepartmentKpiRequest
                {
                    DepartmentId = kpi.DepartmentId ?? 0,
                    CycleId = kpi.CycleId ?? 0,
                    KpiId = kpi.KpiId ?? 0,
                    DepartmentTarget = kpi.DepartmentTarget ?? 0,
                    Weight = kpi.Weight ?? 0,
                    ActualValue = kpi.ActualValue ?? 0,
                    IsActive = kpi.IsActive
                };
                await KpiService.UpdateDeptAsync(kpi.DeptKpiId, request);
            }
            
            Snackbar.Add("Department performance data saved successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
