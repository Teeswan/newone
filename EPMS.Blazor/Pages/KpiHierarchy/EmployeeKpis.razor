@page "/kpi-hierarchy/employee"
@using System
@using System.Threading
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@inject IEmployeeKpiBlazorService EmployeeKpiService
@inject IEmployeeBlazorService EmployeeService
@inject IKpiHierarchyBlazorService KpiService
@inject IAppraisalCycleBlazorService CycleService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Employee KPI Assignments</MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">
                <MudAutocomplete T="EmployeeDto" Label="Select Employee" Value="_selectedEmployee"
                                 ValueChanged="OnEmployeeChanged"
                                 SearchFunc="@SearchEmployees" ToStringFunc="@(e => e == null ? null : $"{e.FullName} ({e.EmployeeCode})")"
                                 ResetValueOnEmptyText="true" CoerceText="true" CoerceValue="true"
                                 AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" />
                
                @if (_selectedEmployee != null)
                {
                    <MudCard Class="mt-4" Elevation="0" Outlined="true">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@_selectedEmployee.FullName</MudText>
                            <MudText Typo="Typo.body2">Code: @_selectedEmployee.EmployeeCode</MudText>
                            <MudText Typo="Typo.body2">Department: @_selectedEmployee.DepartmentName</MudText>
                            <MudText Typo="Typo.body2">Position: @_selectedEmployee.PositionTitle</MudText>
                        </MudCardContent>
                    </MudCard>
                    
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                               OnClick="OpenAssignDialog" Class="mt-4" FullWidth="true">
                        Assign New KPI
                    </MudButton>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4">
                @if (_selectedEmployee == null)
                {
                    <MudAlert Severity="Severity.Info">Please select an employee to view their KPI assignments.</MudAlert>
                }
                else
                {
                    <MudTable Items="_employeeKpis" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" LoadingProgressColor="Color.Info" Elevation="0">
                        <HeaderContent>
                            <MudTh>KPI Name</MudTh>
                            <MudTh>Cycle</MudTh>
                            <MudTh>Weight (%)</MudTh>
                            <MudTh>Target</MudTh>
                            <MudTh>Date Assigned</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="KPI Name">@context.KpiName</MudTd>
                            <MudTd DataLabel="Cycle">@context.CycleName</MudTd>
                            <MudTd DataLabel="Weight (%)">@context.Weight</MudTd>
                            <MudTd DataLabel="Target">@context.TargetValue</MudTd>
                            <MudTd DataLabel="Date Assigned">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                                    @(context.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteKpi(context.EmployeeKpiId))" />
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText>No KPIs assigned to this employee.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private EmployeeDto? _selectedEmployee;
    private List<EmployeeKpiDto> _employeeKpis = new();
    private bool _loading = false;
    private List<EmployeeDto> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        _employees = await EmployeeService.GetEmployeesAsync();
    }

    private async Task<IEnumerable<EmployeeDto>> SearchEmployees(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return _employees;
        return _employees.Where(x => x.FullName.Contains(value, StringComparison.InvariantCultureIgnoreCase) || 
                                     x.EmployeeCode.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task LoadEmployeeKpis()
    {
        if (_selectedEmployee == null) return;
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await EmployeeKpiService.GetByEmployeeIdAsync(_selectedEmployee.EmployeeId);
            _employeeKpis = result.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading KPIs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OpenAssignDialog()
    {
        if (_selectedEmployee == null) return;

        var parameters = new DialogParameters { ["EmployeeId"] = _selectedEmployee.EmployeeId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<AssignEmployeeKpiDialog>("Assign KPI", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadEmployeeKpis();
        }
    }

    private async Task OpenEditDialog(EmployeeKpiDto kpi)
    {
        var parameters = new DialogParameters { ["Kpi"] = kpi };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<EditEmployeeKpiDialog>("Edit KPI Assignment", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadEmployeeKpis();
        }
    }

    private async Task DeleteKpi(int id)
    {
        bool? confirm = await DialogService.ShowMessageBox("Confirm Delete", "Are you sure you want to remove this KPI assignment?", yesText: "Delete", cancelText: "Cancel");
        if (confirm == true)
        {
            var success = await EmployeeKpiService.DeleteAsync(id);
            if (success)
            {
                Snackbar.Add("KPI removed successfully", Severity.Success);
                await LoadEmployeeKpis();
            }
            else
            {
                Snackbar.Add("Failed to remove KPI", Severity.Error);
            }
        }
    }

    private async Task OnEmployeeChanged(EmployeeDto? employee)
    {
        _selectedEmployee = employee;
        if (_selectedEmployee != null)
        {
            try 
            {
                _loading = true;
                StateHasChanged();
                await EmployeeKpiService.CalculateForEmployeeAsync(_selectedEmployee.EmployeeId);
                await LoadEmployeeKpis();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error calculating KPIs: {ex.Message}", Severity.Error);
                _employeeKpis.Clear();
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }
        else
        {
            _employeeKpis.Clear();
        }
    }
}
