@using System
@using System.Threading
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@inject IEmployeeKpiBlazorService EmployeeKpiService
@inject IKpiHierarchyBlazorService KpiHierarchyService
@inject IAppraisalCycleBlazorService CycleService
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="int" Label="Appraisal Cycle" @bind-Value="_request.CycleId" Required="true">
                        @foreach (var cycle in _cycles)
                        {
                            <MudSelectItem Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudAutocomplete T="KpiDto" Label="Select Master KPI" @bind-Value="_selectedKpi"
                                     SearchFunc="@SearchKpis" ToStringFunc="@(k => k?.KpiName)"
                                     Required="true" ResetValueOnEmptyText="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="int?" Label="Link to Team KPI (Optional)" @bind-Value="_request.TeamKpiId">
                        <MudSelectItem T="int?" Value="null">None</MudSelectItem>
                        @foreach (var tkpi in _teamKpis)
                        {
                            <MudSelectItem T="int?" Value="@tkpi.TeamKpiId">@tkpi.KpiName (@tkpi.TeamName)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField T="decimal" @bind-Value="_request.Weight" Label="Weight (%)" Min="1" Max="100" Required="true" />
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField T="decimal" @bind-Value="_request.TargetValue" Label="Target Value" Min="0" Required="true" />
                </MudItem>

                @if (EmployeeId == null)
                {
                    <MudItem xs="12">
                        <MudSelect T="int" Label="Employees" MultiSelection="true" @bind-SelectedValues="_selectedEmployeeIds" Required="true">
                            @foreach (var emp in _employees)
                            {
                                <MudSelectItem Value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudSwitch @bind-Value="_request.IsActive" Label="Is Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid || _processing">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Processing</MudText>
            }
            else
            {
                <MudText>Assign</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int? EmployeeId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _processing;
    private BulkEmployeeKpiRequest _request = new();
    private KpiDto? _selectedKpi;
    private IEnumerable<int> _selectedEmployeeIds = new HashSet<int>();

    private List<AppraisalCycleDto> _cycles = new();
    private List<KpiDto> _kpis = new();
    private List<TeamKpiDto> _teamKpis = new();
    private List<EmployeeDto> _employees = new();

    protected override async Task OnInitializedAsync()
    {
        _cycles = (await CycleService.GetAllAppraisalCyclesAsync()).ToList();
        _kpis = (await KpiHierarchyService.GetAllMasterAsync()).ToList();
        _teamKpis = (await KpiHierarchyService.GetAllTeamAsync()).ToList();
        
        if (EmployeeId == null)
        {
            _employees = (await EmployeeService.GetEmployeesAsync()).ToList();
        }
        else
        {
            _selectedEmployeeIds = new List<int> { EmployeeId.Value };
        }
    }

    private async Task<IEnumerable<KpiDto>> SearchKpis(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _kpis;
        return _kpis.Where(x => x.KpiName.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private void OnCycleChanged()
    {
        // Could filter team KPIs by cycle if available
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        if (_selectedKpi == null)
        {
            Snackbar.Add("Please select a KPI", Severity.Warning);
            return;
        }

        _processing = true;
        try
        {
            _request.KpiId = _selectedKpi.KpiId;
            _request.EmployeeIds = _selectedEmployeeIds.ToList();

            if (!_request.EmployeeIds.Any())
            {
                Snackbar.Add("Please select at least one employee", Severity.Warning);
                return;
            }

            await EmployeeKpiService.CreateBulkAsync(_request);
            Snackbar.Add("KPI assigned successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
