@page "/forgot-password"
@attribute [AllowAnonymous]
@using EPMS.Shared.Requests
@using Microsoft.AspNetCore.Authorization
@using EPMS.Blazor.Services
@using System.Text.RegularExpressions

@inject IAuthBlazorService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex justify-center align-center" Style="min-height: 100vh;">
    <MudPaper Elevation="12" Class="pa-10" Rounded="true">
        <!-- Step Indicator -->
        <MudStepper @bind-ActiveStep="currentStep" Linear="true" Class="mb-8">
            <MudStep Label="Email" Icon="@Icons.Material.Filled.Email" />
            <MudStep Label="OTP" Icon="@Icons.Material.Filled.VerifiedUser" />
            <MudStep Label="Reset Password" Icon="@Icons.Material.Filled.LockReset" />
        </MudStepper>

        <!-- Step 1: Email -->
        @if (currentStep == 0)
        {
            <div class="text-center mb-6">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mx-auto mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h3" Class="fw-bold text-primary mb-2">Reset Your Password</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">
                    Enter your email address to receive a One-Time Password
                </MudText>
            </div>

            <EditForm Model="forgotPasswordModel" OnValidSubmit="HandleSendOtp">
                <DataAnnotationsValidator />
                
                <MudTextField 
                    T="string"
                    Label="Email" 
                    @bind-Value="forgotPasswordModel.Email"
                    Placeholder="Enter your email"
                    Variant="Variant.Outlined"
                    Style="width: 100%"
                    Class="mb-6"
                    Immediate="true" />

                <MudButton 
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Style="width: 100%"
                    Size="Size.Large"
                    Class="mb-4"
                    Disabled="isLoading">
                    @if (isLoading)
                    {
                        <MudProgressCircular Color="Color.Inherit" Size="Size.Small" Class="mr-2" Indeterminate="true" />
                    }
                    else
                    {
                        <MudIcon Class="mr-2" Icon="@Icons.Material.Filled.Send" />
                    }
                    Send OTP
                </MudButton>

                <MudButton 
                    Variant="Variant.Text"
                    Color="Color.Primary"
                    Style="width: 100%"
                    OnClick="GoToLogin">
                    Back to Login
                </MudButton>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-6" Variant="Variant.Filled" Icon="@Icons.Material.Filled.ErrorOutline" Closable="true">
                        @errorMessage
                    </MudAlert>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <MudAlert Severity="Severity.Success" Class="mt-6" Variant="Variant.Filled" Icon="@Icons.Material.Filled.CheckCircle" Closable="true">
                        @successMessage
                    </MudAlert>
                }
            </EditForm>
        }

        <!-- Step 2: OTP -->
        @if (currentStep == 1)
        {
            <div class="text-center mb-6">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mx-auto mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h3" Class="fw-bold text-primary mb-2">Verify OTP</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">
                    Enter the 6-digit OTP sent to @email
                </MudText>
            </div>

            <EditForm Model="otpModel" OnValidSubmit="HandleVerifyOtp">
                <DataAnnotationsValidator />
                
                <MudTextField 
                    T="string"
                    Label="One-Time Password" 
                    @bind-Value="otpModel.Otp"
                    Placeholder="Enter 6-digit OTP"
                    Variant="Variant.Outlined"
                    Style="width: 100%"
                    Class="mb-6"
                    Immediate="true"
                    InputType="InputType.Number"
                    MaxLength="6" />

                <MudButton 
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Style="width: 100%"
                    Size="Size.Large"
                    Class="mb-4"
                    Disabled="isLoading">
                    @if (isLoading)
                    {
                        <MudProgressCircular Color="Color.Inherit" Size="Size.Small" Class="mr-2" Indeterminate="true" />
                    }
                    else
                    {
                        <MudIcon Class="mr-2" Icon="@Icons.Material.Filled.Check" />
                    }
                    Verify OTP
                </MudButton>

                <MudButton 
                    Variant="Variant.Outlined"
                    Color="Color.Secondary"
                    Style="width: 48%"
                    Class="mr-1"
                    OnClick="() => currentStep--">
                    Back
                </MudButton>

                <MudButton 
                    Variant="Variant.Text"
                    Color="Color.Primary"
                    Style="width: 48%"
                    OnClick="HandleResendOtp"
                    Disabled="isLoading">
                    Resend OTP
                </MudButton>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-6" Variant="Variant.Filled" Icon="@Icons.Material.Filled.ErrorOutline" Closable="true">
                        @errorMessage
                    </MudAlert>
                }
            </EditForm>
        }

        <!-- Step 3: Reset Password -->
        @if (currentStep == 2)
        {
            <div class="text-center mb-6">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mx-auto mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h3" Class="fw-bold text-primary mb-2">Set New Password</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">
                    Create a new secure password for your account
                </MudText>
            </div>

            <EditForm Model="resetPasswordModel" OnValidSubmit="HandleResetPassword">
                <DataAnnotationsValidator />
                
                <MudTextField 
                    T="string"
                    Label="New Password" 
                    @bind-Value="resetPasswordModel.NewPassword"
                    InputType="InputType.Password"
                    Placeholder="Enter new password"
                    Variant="Variant.Outlined"
                    Style="width: 100%"
                    Class="mb-4"
                    Immediate="true" />

                @if (!string.IsNullOrEmpty(resetPasswordModel.NewPassword))
                {
                    <MudText Typo="Typo.caption" Class="mb-2" Style="color: #4b5563;">
                        Password Strength: @GetPasswordStrengthText()
                    </MudText>
                    <MudProgressLinear Color="@GetPasswordStrengthColor()" Value="@GetPasswordStrengthValue()" Class="mb-6" />
                }

                <MudTextField 
                    T="string"
                    Label="Confirm New Password" 
                    @bind-Value="confirmPassword"
                    InputType="InputType.Password"
                    Placeholder="Confirm new password"
                    Variant="Variant.Outlined"
                    Style="width: 100%"
                    Class="mb-6"
                    Immediate="true" />

                @if (!string.IsNullOrEmpty(confirmPassword) && resetPasswordModel.NewPassword != confirmPassword)
                {
                    <MudText Typo="Typo.caption" Class="mb-6" Style="color: #ef4444;">
                        Passwords do not match
                    </MudText>
                }

                <MudButton 
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Style="width: 100%"
                    Size="Size.Large"
                    Class="mb-4"
                    Disabled="isLoading || (!string.IsNullOrEmpty(confirmPassword) && resetPasswordModel.NewPassword != confirmPassword)">
                    @if (isLoading)
                    {
                        <MudProgressCircular Color="Color.Inherit" Size="Size.Small" Class="mr-2" Indeterminate="true" />
                    }
                    else
                    {
                        <MudIcon Class="mr-2" Icon="@Icons.Material.Filled.LockReset" />
                    }
                    Reset Password
                </MudButton>

                <MudButton 
                    Variant="Variant.Outlined"
                    Color="Color.Secondary"
                    Style="width: 100%"
                    OnClick="() => currentStep--">
                    Back
                </MudButton>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-6" Variant="Variant.Filled" Icon="@Icons.Material.Filled.ErrorOutline" Closable="true">
                        @errorMessage
                    </MudAlert>
                }
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    private int currentStep = 0;
    private ForgotPasswordRequest forgotPasswordModel = new();
    private ResetPasswordRequest resetPasswordModel = new();
    private (string Email, string Otp) otpModel = (string.Empty, string.Empty);
    private string email = string.Empty;
    private string confirmPassword = string.Empty;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task HandleSendOtp()
    {
        errorMessage = null;
        successMessage = null;
        isLoading = true;
        try
        {
            var result = await AuthService.ForgotPasswordAsync(forgotPasswordModel);
            if (result != null && result.IsSuccess)
            {
                email = forgotPasswordModel.Email;
                resetPasswordModel.Email = forgotPasswordModel.Email;
                otpModel.Email = forgotPasswordModel.Email;
                successMessage = result.Message;
                Snackbar.Add("OTP sent! Check your email.", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                currentStep++;
            }
            else
            {
                errorMessage = result?.Message ?? "Failed to request OTP. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Server error: {ex.Message}";
            Console.WriteLine($"ForgotPassword Error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleResendOtp()
    {
        forgotPasswordModel.Email = email;
        await HandleSendOtp();
    }

    private async Task HandleVerifyOtp()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            resetPasswordModel.Otp = otpModel.Otp;
            currentStep++;
        }
        catch (Exception ex)
        {
            errorMessage = $"Server error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleResetPassword()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            var result = await AuthService.ResetPasswordAsync(resetPasswordModel);
            if (result != null && result.IsSuccess)
            {
                Snackbar.Add("Password reset successful! Please login.", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = result?.Message ?? "Failed to reset password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Server error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetPasswordStrengthValue()
    {
        int score = 0;
        if (resetPasswordModel.NewPassword.Length >= 8) score += 25;
        if (Regex.IsMatch(resetPasswordModel.NewPassword, @"[A-Z]")) score += 25;
        if (Regex.IsMatch(resetPasswordModel.NewPassword, @"[a-z]")) score += 25;
        if (Regex.IsMatch(resetPasswordModel.NewPassword, @"[0-9]")) score += 12;
        if (Regex.IsMatch(resetPasswordModel.NewPassword, @"[^a-zA-Z0-9]")) score += 13;
        return Math.Min(score, 100);
    }

    private string GetPasswordStrengthText()
    {
        int strength = GetPasswordStrengthValue();
        return strength switch
        {
            <= 25 => "Very Weak",
            <= 50 => "Weak",
            <= 75 => "Medium",
            _ => "Strong"
        };
    }

    private Color GetPasswordStrengthColor()
    {
        int strength = GetPasswordStrengthValue();
        return strength switch
        {
            <= 25 => Color.Error,
            <= 50 => Color.Warning,
            <= 75 => Color.Info,
            _ => Color.Success
        };
    }
}
