@page "/pip/create"
@using EPMS.Blazor.Services
@using EPMS.Shared.Requests
@using EPMS.Shared.Validation
@inject IPipClientService PipService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Performance Improvement Plan</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
            <MudItem>
                <MudText Typo="Typo.h4">Create New PIP</MudText>
            </MudItem>
            <MudItem>
                <MudButton Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => NavigationManager.NavigateTo("/pip"))">
                    ← Back to List
                </MudButton>
            </MudItem>
        </MudGrid>

        <EditForm Model="_request" OnValidSubmit="HandleSubmit">
            <MudCard Class="mb-6">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Plan Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="int" Label="Employee ID" @bind-Value="_request.EmployeeId" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="int" Label="Manager ID" @bind-Value="_request.ManagerId" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Start Date" @bind-Date="_startDate" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="End Date" @bind-Date="_endDate" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Overall Goal" @bind-Value="_request.OverallGoal" Variant="Variant.Outlined" Lines="4" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-6">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Objectives</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small" OnClick="AddObjective" StartIcon="@Icons.Material.Filled.Add">
                            Add Objective
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (!_request.Objectives.Any())
                    {
                        <MudAlert Severity="Severity.Info">Add at least one objective to define improvement targets.</MudAlert>
                    }
                    else
                    {
                        @for (var i = 0; i < _request.Objectives.Count; i++)
                        {
                            var index = i;
                            <MudPaper Class="pa-4 mb-4" Elevation="0">
                                <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudItem>
                                        <MudText Typo="Typo.subtitle1"><strong>Objective @(index + 1)</strong></MudText>
                                    </MudItem>
                                    <MudItem>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => RemoveObjective(index)" />
                                    </MudItem>
                                </MudGrid>
                                <MudTextField Label="Objective Description" @bind-Value="_request.Objectives[index].ObjectiveDescription" Variant="Variant.Outlined" Lines="3" Class="mb-2" FullWidth="true" Required="true" />
                                <MudTextField Label="Success Criteria" @bind-Value="_request.Objectives[index].SuccessCriteria" Variant="Variant.Outlined" Lines="2" FullWidth="true" />
                            </MudPaper>
                        }
                    }
                </MudCardContent>
            </MudCard>

            @if (_errors.Any())
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    <MudList T="string" Dense="true">
                        @foreach (var error in _errors)
                        {
                            <MudListItem T="string">@error</MudListItem>
                        }
                    </MudList>
                </MudAlert>
            }

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => NavigationManager.NavigateTo("/pip"))" Class="mr-3">
                        Cancel
                    </MudButton>
                    <MudButton Type="submit" Color="Color.Primary" Variant="Variant.Filled" Disabled="_submitting" StartIcon="@(_submitting ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.Check)">
                        @(_submitting ? "Creating..." : "Create PIP")
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private DateTime? _startDate;
    private DateTime? _endDate;

    private CreatePipPlanRequest _request = new()
    {
        Objectives = new List<CreatePipObjectiveRequest>
        {
            new CreatePipObjectiveRequest()
        }
    };

    private List<string> _errors = new();
    private bool _submitting;

    protected override void OnInitialized()
    {
        _startDate = DateTime.Today;
        _endDate = DateTime.Today.AddMonths(1);
    }

    private void AddObjective()
    {
        _request.Objectives.Add(new CreatePipObjectiveRequest { PipId = 0 });
    }

    private void RemoveObjective(int index)
    {
        if (_request.Objectives.Count > 1)
            _request.Objectives.RemoveAt(index);
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _errors.Clear();

        if (_startDate.HasValue)
        {
            _request.StartDate = DateOnly.FromDateTime(_startDate.Value);
        }

        if (_endDate.HasValue)
        {
            _request.EndDate = DateOnly.FromDateTime(_endDate.Value);
        }

        var validator = new CreatePipPlanValidator();
        var result = await validator.ValidateAsync(_request);
        if (!result.IsValid)
        {
            _errors = result.Errors.Select(e => e.ErrorMessage).ToList();
            _submitting = false;
            return;
        }

        var response = await PipService.CreatePipAsync(_request);
        if (response?.Success == true)
        {
            Snackbar.Add("PIP created successfully!", Severity.Success);
            NavigationManager.NavigateTo("/pip/" + response.Data!.PipId);
        }
        else
        {
            _errors = response?.Errors ?? new List<string> { "Failed to create PIP." };
            Snackbar.Add(_errors.FirstOrDefault() ?? "Failed to create PIP.", Severity.Error);
        }

        _submitting = false;
    }
}
