@page "/pip/{PipId:int}"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@inject IPipClientService PipService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>PIP Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <div class="text-center py-10">
            <MudProgressCircular Indeterminate="true" />
            <MudText Class="mt-3">Loading...</MudText>
        </div>
    }
    else if (_plan is null)
    {
        <MudAlert Severity="Severity.Error">PIP not found.</MudAlert>
    }
    else
    {
        <MudPaper Elevation="2" Class="pa-6 mb-6">
            <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudItem>
                    <MudText Typo="Typo.h4">PIP – @_plan.EmployeeName</MudText>
                    <MudText Typo="Typo.subtitle1" Class="text-muted">Managed by @_plan.ManagerName</MudText>
                </MudItem>
                <MudItem>
                    <MudChip T="string" Color="GetStatusColor(_plan.Status)" Variant="Variant.Filled" Class="mr-3">@_plan.Status</MudChip>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="@(() => NavigationManager.NavigateTo("/pip/edit/" + PipId))" StartIcon="@Icons.Material.Filled.Edit" Class="mr-2">
                        Edit
                    </MudButton>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => NavigationManager.NavigateTo("/pip"))" StartIcon="@Icons.Material.Filled.ArrowBack">
                        Back
                    </MudButton>
                </MudItem>
            </MudGrid>

            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="text-muted">Duration</MudText>
                            <MudText Typo="Typo.h5">@_plan.StartDate.ToString("dd MMM") – @_plan.EndDate.ToString("dd MMM yyyy")</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="text-muted">Objectives Achieved</MudText>
                            <MudText Typo="Typo.h5">
                                @_plan.Objectives.Count(o => o.IsAchieved) / @_plan.Objectives.Count
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="text-muted">Meetings Held</MudText>
                            <MudText Typo="Typo.h5">@_plan.Meetings.Count</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(_plan.OverallGoal))
            {
                <MudCard Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Overall Goal</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body1">@_plan.OverallGoal</MudText>
                    </MudCardContent>
                </MudCard>
            }
        </MudPaper>

        <MudPaper Elevation="2" Class="pa-6 mb-4">
            <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudItem>
                    <MudText Typo="Typo.h5">Objectives</MudText>
                </MudItem>
                <MudItem>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="ShowAddObjective" StartIcon="@Icons.Material.Filled.Add">
                        Add Objective
                    </MudButton>
                </MudItem>
            </MudGrid>

            @foreach (var obj in _plan.Objectives)
            {
                <PipObjectiveCard Objective="obj"
                                  OnUpdate="HandleObjectiveUpdate"
                                  OnDelete="HandleObjectiveDelete" />
            }

            @if (!_plan.Objectives.Any())
            {
                <MudAlert Severity="Severity.Info">No objectives yet. Add your first objective!</MudAlert>
            }
        </MudPaper>

        <MudPaper Elevation="2" Class="pa-6">
            <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudItem>
                    <MudText Typo="Typo.h5">Review Meetings</MudText>
                </MudItem>
                <MudItem>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="ShowScheduleMeeting" StartIcon="@Icons.Material.Filled.Add">
                        Schedule Meeting
                    </MudButton>
                </MudItem>
            </MudGrid>

            @foreach (var meeting in _plan.Meetings.OrderBy(m => m.MeetingDate))
            {
                <PipMeetingCard Meeting="meeting"
                               OnUpdate="HandleMeetingUpdate"
                               OnDelete="HandleMeetingDelete" />
            }

            @if (!_plan.Meetings.Any())
            {
                <MudAlert Severity="Severity.Info">No meetings scheduled yet.</MudAlert>
            }
        </MudPaper>

        @if (_showAddObjective)
        {
            <MudDialog>
                <DialogContent>
                    <MudText Typo="Typo.h6" Class="mb-4">Add Objective</MudText>
                    <MudForm Model="_newObjective">
                        <MudTextField Label="Objective Description" @bind-Value="_newObjective.ObjectiveDescription" Variant="Variant.Outlined" Lines="3" Class="mb-3" FullWidth="true" />
                        <MudTextField Label="Success Criteria" @bind-Value="_newObjective.SuccessCriteria" Variant="Variant.Outlined" Lines="2" FullWidth="true" />
                    </MudForm>
                </DialogContent>
                <DialogActions>
                    <MudButton OnClick="() => _showAddObjective = false">Cancel</MudButton>
                    <MudButton Color="Color.Primary" OnClick="SubmitObjective">Add Objective</MudButton>
                </DialogActions>
            </MudDialog>
        }

        @if (_showScheduleMeeting)
        {
            <MudDialog>
                <DialogContent>
                    <MudText Typo="Typo.h6" Class="mb-4">Schedule Meeting</MudText>
                    <MudForm Model="_newMeeting">
                        <MudDatePicker Label="Meeting Date" @bind-Date="_meetingDateOnly" Variant="Variant.Outlined" Class="mb-3" FullWidth="true" />
                        <MudSelect T="string" Label="Progress Status" @bind-Value="_newMeeting.ProgressStatus" Variant="Variant.Outlined" Class="mb-3" FullWidth="true">
                            <MudSelectItem T="string" Value="@("On Track")">On Track</MudSelectItem>
                            <MudSelectItem T="string" Value="@("At Risk")">At Risk</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Behind Schedule")">Behind Schedule</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                        </MudSelect>
                        <MudTextField Label="Discussion Points" @bind-Value="_newMeeting.DiscussionPoints" Variant="Variant.Outlined" Lines="3" Class="mb-3" FullWidth="true" />
                        <MudTextField Label="Next Steps" @bind-Value="_newMeeting.NextSteps" Variant="Variant.Outlined" Lines="2" FullWidth="true" />
                    </MudForm>
                </DialogContent>
                <DialogActions>
                    <MudButton OnClick="() => _showScheduleMeeting = false">Cancel</MudButton>
                    <MudButton Color="Color.Primary" OnClick="SubmitMeeting">Schedule Meeting</MudButton>
                </DialogActions>
            </MudDialog>
        }
    }
</MudContainer>

@code {
    [Parameter] public int PipId { get; set; }

    private PipPlanDto? _plan;
    private bool _loading = true;
    private bool _showAddObjective;
    private bool _showScheduleMeeting;
    private DateTime? _meetingDateOnly;

    private CreatePipObjectiveRequest _newObjective = new();
    private CreatePipMeetingRequest _newMeeting = new()
    {
        ProgressStatus = "On Track"
    };

    protected override async Task OnParametersSetAsync() => await LoadPlan();

    private async Task LoadPlan()
    {
        _loading = true;
        try
        {
            var response = await PipService.GetByIdAsync(PipId);
            _plan = response?.Data;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading PIP: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowAddObjective()
    {
        _newObjective = new CreatePipObjectiveRequest { PipId = PipId };
        _showAddObjective = true;
    }

    private void ShowScheduleMeeting()
    {
        _meetingDateOnly = DateTime.Now.AddDays(7);
        _newMeeting = new CreatePipMeetingRequest
        {
            PipId = PipId,
            ProgressStatus = "On Track"
        };
        _showScheduleMeeting = true;
    }

    private async Task SubmitObjective()
    {
        var response = await PipService.AddObjectiveAsync(_newObjective);
        if (response?.Success == true)
        {
            _showAddObjective = false;
            Snackbar.Add("Objective added!", Severity.Success);
            await LoadPlan();
        }
        else
        {
            Snackbar.Add(response?.Message ?? "Failed to add objective.", Severity.Error);
        }
    }

    private async Task SubmitMeeting()
    {
        if (_meetingDateOnly.HasValue)
        {
            _newMeeting.MeetingDate = _meetingDateOnly.Value.Date.Add(new TimeSpan(10, 0, 0));
        }

        var response = await PipService.AddMeetingAsync(_newMeeting);
        if (response?.Success == true)
        {
            _showScheduleMeeting = false;
            Snackbar.Add("Meeting scheduled!", Severity.Success);
            await LoadPlan();
        }
        else
        {
            Snackbar.Add(response?.Message ?? "Failed to schedule meeting.", Severity.Error);
        }
    }

    private async Task HandleObjectiveUpdate(UpdatePipObjectiveRequest request)
    {
        await PipService.UpdateObjectiveAsync(request);
        Snackbar.Add("Objective updated!", Severity.Success);
        await LoadPlan();
    }

    private async Task HandleObjectiveDelete(int objectiveId)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Delete Objective?",
            "Are you sure you want to delete this objective?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await PipService.DeleteObjectiveAsync(objectiveId);
            Snackbar.Add("Objective deleted!", Severity.Success);
            await LoadPlan();
        }
    }

    private async Task HandleMeetingUpdate(UpdatePipMeetingRequest request)
    {
        await PipService.UpdateMeetingAsync(request);
        Snackbar.Add("Meeting updated!", Severity.Success);
        await LoadPlan();
    }

    private async Task HandleMeetingDelete(int meetingId)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Delete Meeting?",
            "Are you sure you want to delete this meeting?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await PipService.DeleteMeetingAsync(meetingId);
            Snackbar.Add("Meeting deleted!", Severity.Success);
            await LoadPlan();
        }
    }

    private Color GetStatusColor(string status) => status.ToLower() switch
    {
        "active" => Color.Primary,
        "completed" => Color.Success,
        "terminated" => Color.Error,
        "extended" => Color.Warning,
        _ => Color.Default
    };
}
