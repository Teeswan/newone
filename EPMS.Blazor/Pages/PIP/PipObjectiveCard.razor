@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests

<MudPaper Class="pa-4 mb-4" Elevation="2">
    @if (!_editing)
    {
        <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudItem>
                <MudChip T="string" Color="@(Objective.IsAchieved ? Color.Success : Color.Secondary)" Variant="Variant.Filled" Size="Size.Small">
                    @(Objective.IsAchieved ? "✓ Achieved" : "Pending")
                </MudChip>
            </MudItem>
            <MudItem>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="StartEdit" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => OnDelete.InvokeAsync(Objective.ObjectiveId)" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.body1" Class="mb-2">@Objective.ObjectiveDescription</MudText>

        @if (!string.IsNullOrEmpty(Objective.SuccessCriteria))
        {
            <MudText Typo="Typo.caption" Class="text-muted mb-2">
                <strong>Success Criteria:</strong> @Objective.SuccessCriteria
            </MudText>
        }

        @if (!string.IsNullOrEmpty(Objective.ReviewComments))
        {
            <MudText Typo="Typo.caption" Class="text-muted">
                <strong>Review Notes:</strong> @Objective.ReviewComments
            </MudText>
        }
    }
    else
    {
        <MudForm Model="_editRequest">
            <MudGrid Class="mb-3">
                <MudItem xs="12">
                    <MudCheckBox T="bool" Label="Mark as Achieved" @bind-Checked="_editRequest.IsAchieved" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Success Criteria" @bind-Value="_editRequest.SuccessCriteria" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Review Comments" @bind-Value="_editRequest.ReviewComments" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" OnClick="CancelEdit" Class="mr-2">
                        Cancel
                    </MudButton>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" OnClick="SaveEdit">
                        Save
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    }
</MudPaper>

@code {
    [Parameter] public PipObjectiveDto Objective { get; set; } = null!;
    [Parameter] public EventCallback<UpdatePipObjectiveRequest> OnUpdate { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private bool _editing;
    private UpdatePipObjectiveRequest _editRequest = new();

    private void StartEdit()
    {
        _editRequest = new UpdatePipObjectiveRequest
        {
            ObjectiveId = Objective.ObjectiveId,
            IsAchieved = Objective.IsAchieved,
            ReviewComments = Objective.ReviewComments,
            SuccessCriteria = Objective.SuccessCriteria
        };
        _editing = true;
    }

    private void CancelEdit() => _editing = false;

    private async Task SaveEdit()
    {
        await OnUpdate.InvokeAsync(_editRequest);
        _editing = false;
    }
}
