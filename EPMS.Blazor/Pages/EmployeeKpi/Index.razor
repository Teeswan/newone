@page "/employee-kpi"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IEmployeeKpiBlazorService EmpKpiService
@inject IAppraisalCycleBlazorService CycleService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudText Typo="Typo.h4" Class="mb-4">Employee KPI Assignments</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Import & Templates</MudText>
                <MudStack Row="true">
                    <MudFileUpload T="IBrowserFile" FilesChanged="UploadFile" Accept=".xlsx">
                        <ActivatorContent>
                            <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.UploadFile">
                                Bulk Import Assignments
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadTemplate">
                        Download Template
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
             <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Filters</MudText>
                <MudStack Row="true">
                    <MudNumericField @bind-Value="_employeeId" Label="Employee ID" Variant="Variant.Outlined" Min="1" />
                    <MudSelect T="int" Label="Appraisal Cycle" @bind-Value="_cycleId" Variant="Variant.Outlined">
                        @foreach (var cycle in _cycles)
                        {
                            <MudSelectItem Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAssignments" Class="mt-2">Search</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_assignments != null && _assignments.Any())
{
    <MudTable Items="@_assignments" Hover="true" Bordered="true" Striped="true" Class="mb-4">
        <HeaderContent>
            <MudTh>KPI Name (Snapshot)</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Weight (%)</MudTh>
            <MudTh>Target</MudTh>
            <MudTh>Actual</MudTh>
            <MudTh>Score</MudTh>
            <MudTh>Weighted Score</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.KpiNameSnapshot</MudTd>
            <MudTd>@context.CategorySnapshot</MudTd>
            <MudTd>@context.WeightPercent%</MudTd>
            <MudTd>@context.TargetValue @context.UnitSnapshot</MudTd>
            <MudTd>
                <MudNumericField Value="@context.ActualValue" 
                                 ValueChanged="@((decimal? v) => UpdateActual(context.AssignmentId, v))" 
                                 Label="Actual" 
                                 Variant="Variant.Text" 
                                 Margin="Margin.Dense" />
            </MudTd>
            <MudTd>@context.KpiScore%</MudTd>
            <MudTd>@context.WeightedScore</MudTd>
            <MudTd>@context.Status</MudTd>
        </RowTemplate>
    </MudTable>

    @if (_summary != null)
    {
        <MudPaper Class="pa-4" Style="background-color: var(--mud-palette-background-grey)">
            <MudText Typo="Typo.h6">Performance Summary</MudText>
            <MudGrid>
                <MudItem xs="4">
                    <MudText>Total Performance Score: <b>@_summary.TotalPerformanceScore</b></MudText>
                </MudItem>
                <MudItem xs="4">
                    <MudText>Rating: <b>@_summary.Rating</b></MudText>
                </MudItem>
                <MudItem xs="4">
                    <MudText>Assignments: <b>@_summary.Assignments.Count</b></MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
}
else if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_employeeId > 0 && _cycleId > 0)
{
    <MudAlert Severity="Severity.Info">No assignments found for this employee and cycle.</MudAlert>
}

@code {
    private int _employeeId;
    private int _cycleId;
    private IEnumerable<AppraisalCycleDto> _cycles = new List<AppraisalCycleDto>();
    private IEnumerable<EmployeeKpiAssignmentDto>? _assignments;
    private KpiScoreSummaryDto? _summary;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _cycles = await CycleService.GetAllAppraisalCyclesAsync();
        if (_cycles.Any()) _cycleId = _cycles.First().CycleId;
    }

    private async Task LoadAssignments()
    {
        if (_employeeId <= 0 || _cycleId <= 0)
        {
            Snackbar.Add("Please enter Employee ID and select a Cycle", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            _assignments = await EmpKpiService.GetAssignmentsAsync(_employeeId, _cycleId);
            _summary = await EmpKpiService.GetScoreSummaryAsync(_employeeId, _cycleId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task UpdateActual(int assignmentId, decimal? value)
    {
        if (value == null) return;

        var command = new EPMS.Application.UseCases.KpiAssignment.Commands.EnterActualValueCommand(assignmentId, value.Value, null);
        var result = await EmpKpiService.EnterActualAsync(command);

        if (result != null)
        {
            _summary = result;
            Snackbar.Add("Actual value updated", Severity.Success);
            // Refresh list to show new scores
            _assignments = await EmpKpiService.GetAssignmentsAsync(_employeeId, _cycleId);
        }
    }

    private async Task DownloadTemplate()
    {
        var bytes = await EmpKpiService.DownloadTemplateAsync();
        await JSRuntime.InvokeVoidAsync("saveAsFile", "Employee_KPI_Import_Template.xlsx", Convert.ToBase64String(bytes));
    }

    private async Task UploadFile(IBrowserFile file)
    {
        if (file == null) return;

        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var result = await EmpKpiService.BulkImportExcelAsync(stream, file.Name);

        if (result != null)
        {
            Snackbar.Add($"Import complete: {result.Imported} success, {result.Rejected} failed.", 
                        result.Rejected > 0 ? Severity.Warning : Severity.Success);
            if (_employeeId > 0) await LoadAssignments();
        }
    }
}
