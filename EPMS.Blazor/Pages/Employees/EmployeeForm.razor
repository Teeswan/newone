@using EPMS.Shared.Requests
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using System.ComponentModel.DataAnnotations
@inject IDepartmentBlazorService DeptService
@inject IPositionBlazorService PosService
@inject IEmployeeBlazorService EmployeeService
@inject ITeamBlazorService TeamService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEdit? Icons.Material.Filled.Edit : Icons.Material.Filled.PersonAdd)" Class="mr-3 mb-n1" />
            @(IsEdit ? "Update Employee Profile" : "Register New Employee")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <div class="d-flex justify-center align-center my-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Class="ml-3">Loading details...</MudText>
            </div>
        }
        else
        {
            <MudForm @ref="form">
                <MudGrid Spacing="2">
                @* --- Basic Section --- *@
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.EmployeeCode" Label="Employee Code" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                  Required="true" RequiredError="Code is required!" Placeholder="e.g. EMP-001"
                                  Validation="@(new Func<string, Task<string?>>(ValidateEmployeeCode))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FullName" Label="Full Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Name is required!" />
                </MudItem>

                @* --- Identification & Contact --- *@
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.NrcNumber" Label="NRC Number" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="12/YAKANA(N)123456" 
                                  Validation="@(new Func<string, string>(v => string.IsNullOrEmpty(v) || System.Text.RegularExpressions.Regex.IsMatch(v, @"^\d{1,2}/[A-Za-z]+\([A-Za-z]+\)\d{6}$") ? null : "Invalid NRC format (e.g. 12/ABCDEF(N)123456)"))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Email" 
                                  Validation="@(new EmailAddressAttribute {ErrorMessage = "Invalid email address"})" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Phone" Label="Phone Number" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                  Validation="@(new Func<string, string>(v => string.IsNullOrEmpty(v) || System.Text.RegularExpressions.Regex.IsMatch(v, @"^[0-9+ ]{7,15}$") ? null : "Invalid phone number"))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Employment Status" @bind-Value="Model.EmploymentStatus" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Employment status is required!">
                        <MudSelectItem Value="@("Permanent")">Permanent</MudSelectItem>
                        <MudSelectItem Value="@("Contract")">Contract</MudSelectItem>
                        <MudSelectItem Value="@("Probation")">Probation</MudSelectItem>
                        <MudSelectItem Value="@("Intern")">Intern</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* --- Organization Section --- *@
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Department" @bind-Value="Model.DepartmentId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Department is required!">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select Department</MudSelectItem>
                        @foreach (var dept in departments)
                        {
                            <MudSelectItem T="int?" Value="@((int?)dept.DepartmentId)">@dept.DepartmentName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Position" @bind-Value="Model.PositionId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Position is required!">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select Position</MudSelectItem>
                        @foreach (var pos in positions)
                        {
                            <MudSelectItem T="int?" Value="@((int?)pos.PositionId)">@pos.PositionTitle</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* --- Dates & Finance --- *@
                <MudItem xs="12" sm="4">
                    <MudDatePicker Label="Join Date" @bind-Date="Model.JoinDate" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" Required="true" RequiredError="Join date is required!" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker Label="Date of Birth" @bind-Date="Model.DateOfBirth" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                  Editable="true" Validation="@(new Func<DateTime?, string?>(ValidateDateOfBirth))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="Model.CurrentSalary" Label="Salary (MMK)" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Format="N0" Min="0" />
                </MudItem>

                @* --- Hierarchy & Address --- *@
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" Label="Reports To (Manager)" @bind-Value="Model.ReportsTo" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="int?" Value="@((int?)null)">None (Top Level)</MudSelectItem>
                        @foreach (var emp in allEmployees.Where(x => x.EmployeeId != EmployeeId))
                        {
                            <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">@emp.FullName (@emp.PositionTitle)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" Label="Teams" MultiSelection="true" @bind-SelectedValues="selectedTeamIds" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var team in allTeams)
                        {
                            <MudSelectItem T="int" Value="@team.TeamId">@team.TeamName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Address" Label="Home Address" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="bool" Label="Employee Status" @bind-Value="IsActive" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                        <MudSelectItem Value="true">Active</MudSelectItem>
                        <MudSelectItem Value="false">Inactive</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="px-10">SAVE</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public int EmployeeId { get; set; }

    private CreateEmployeeRequest Model { get; set; } = new();
    private bool IsActive { get; set; } = true;
    private bool isLoading = true;
    private MudForm form = null!;
    private string? originalEmployeeCode;
    private System.ComponentModel.DataAnnotations.EmailAddressAttribute EmailAddressAttribute = new();


    private IEnumerable<DepartmentDto> departments = new List<DepartmentDto>();
    private IEnumerable<PositionDto> positions = new List<PositionDto>();
    private List<EmployeeDto> allEmployees = new List<EmployeeDto>();
    private IEnumerable<TeamDto> allTeams = new List<TeamDto>();
    private IEnumerable<int> selectedTeamIds { get; set; } = new List<int>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            
            // Load dropdown data first
            var deptData = await DeptService.GetAllDepartmentsAsync();
            var posData = await PosService.GetAllPositionsAsync();
            var empData = await EmployeeService.GetEmployeesAsync();
            var teamData = await TeamService.GetAllTeamsAsync();

            departments = deptData ?? new List<DepartmentDto>();
            positions = posData ?? new List<PositionDto>();
            allEmployees = empData ?? new List<EmployeeDto>();
            allTeams = teamData ?? new List<TeamDto>();

            if (IsEdit && EmployeeId > 0)
            {
                var employee = await EmployeeService.GetEmployeeDetailsAsync(EmployeeId);
                if (employee != null)
                {
                    originalEmployeeCode = employee.EmployeeCode;
                    
                    // Populate the Model with values from the fetched employee
                    Model.EmployeeCode = employee.EmployeeCode;
                    Model.FullName = employee.FullName;
                    Model.Email = employee.Email;
                    Model.DepartmentId = employee.DepartmentId;
                    Model.PositionId = employee.PositionId;
                    Model.ReportsTo = employee.ReportsTo;
                    Model.JoinDate = employee.JoinDate;
                    Model.CurrentSalary = employee.CurrentSalary;
                    Model.Phone = employee.Phone;
                    Model.Address = employee.Address;
                    Model.DateOfBirth = employee.DateOfBirth;
                    Model.EmploymentStatus = employee.EmploymentStatus;
                    Model.NrcNumber = employee.NrcNumber;
                    
                    selectedTeamIds = employee.TeamIds ?? new List<int>();
                    IsActive = employee.IsActive ?? false;
                    
                    // Force a UI refresh to ensure dropdowns pick up the newly set IDs
                    StateHasChanged();
                }
                else
                {
                    Snackbar.Add("Could not load employee details.", Severity.Error);
                    MudDialog.Cancel();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading data: " + ex.Message, Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<string?> ValidateEmployeeCode(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return null;
        
        // If editing and code hasn't changed, it's valid
        if (IsEdit && code.Equals(originalEmployeeCode, StringComparison.OrdinalIgnoreCase))
            return null;

        var isUnique = await EmployeeService.IsEmployeeCodeUniqueAsync(code);
        return isUnique ? null : "Employee code must be unique!";
    }

    private string? ValidateDateOfBirth(DateTime? dob)
    {
        if (dob == null) return null;
        
        var minAge = 18;
        if (dob.Value > DateTime.Today.AddYears(-minAge))
            return $"Employee must be at least {minAge} years old.";
            
        return null;
    }

    private async Task Submit()
    {
        if (form == null) return;

        await form.Validate();
        if (form.IsValid)
        {
            try 
            {
                if (IsEdit)
                {
                    // Create a clean request object from the current Model state
                    var updateRequest = new UpdateEmployeeRequest
                    {
                        EmployeeCode = Model.EmployeeCode,
                        FullName = Model.FullName,
                        Email = Model.Email,
                        DepartmentId = Model.DepartmentId,
                        PositionId = Model.PositionId,
                        ReportsTo = Model.ReportsTo,
                        JoinDate = Model.JoinDate,
                        CurrentSalary = Model.CurrentSalary,
                        Phone = Model.Phone,
                        Address = Model.Address,
                        DateOfBirth = Model.DateOfBirth,
                        EmploymentStatus = Model.EmploymentStatus,
                        NrcNumber = Model.NrcNumber,
                        IsActive = IsActive,
                        TeamIds = selectedTeamIds?.ToList() ?? new List<int>()
                    };
                    MudDialog.Close(DialogResult.Ok(updateRequest));
                }
                else
                {
                    Model.IsActive = IsActive;
                    Model.TeamIds = selectedTeamIds?.ToList() ?? new List<int>();
                    MudDialog.Close(DialogResult.Ok(Model));
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Submission error: " + ex.Message, Severity.Error);
            }
        }
    }

    void Cancel() => MudDialog.Cancel();
}