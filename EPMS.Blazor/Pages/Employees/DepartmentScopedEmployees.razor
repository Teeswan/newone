@page "/employees/department-scoped"
@attribute [Authorize]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@inject IEmployeeBlazorService EmployeeService
@inject IPermissionCheckerService PermissionChecker
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>My Department Colleagues</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
                <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-3 mb-2" Color="Color.Primary" />
                My Department Colleagues
            </MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mt-1">
                Read-only: employees who belong to teams in your department
            </MudText>
        </div>
    </div>

    @if (_accessDenied)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            You do not have department-scoped access. Assign <strong>Department Scoped Management</strong> to your position.
        </MudAlert>
    }
    else if (_isLoading)
    {
        <MudPaper Elevation="2" Class="pa-6 rounded-xl">
            <MudSkeleton Animation="Animation.Wave" Height="40px" Class="mb-4" />
            <MudSkeleton Animation="Animation.Wave" Height="40px" Class="mb-4" />
            <MudSkeleton Animation="Animation.Wave" Height="40px" />
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
            <MudTextField @bind-Value="_search" Placeholder="Search colleagues..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
        </MudPaper>

        @if (_employees.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No employees found on teams in your department. Assign employees to teams under your department.
            </MudAlert>
        }
        else
        {
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                <MudTable Items="_employees" T="EmployeeDto" Hover="true" Breakpoint="Breakpoint.Sm"
                          Filter="new Func<EmployeeDto,bool>(Filter)" Class="rounded-lg">
                    <HeaderContent>
                        <MudTh>Code</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>Team</MudTh>
                        <MudTh>Position</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Code">@context.EmployeeCode</MudTd>
                        <MudTd DataLabel="Name">@context.FullName</MudTd>
                        <MudTd DataLabel="Team">@context.TeamName</MudTd>
                        <MudTd DataLabel="Position">@context.PositionTitle</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.IsActive == true ? Color.Success : Color.Error)">
                                @(context.IsActive == true ? "Active" : "Inactive")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                           Title="View profile (read-only)"
                                           OnClick="@(() => Navigation.NavigateTo($"/employees/department-scoped/details/{context.EmployeeId}"))" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private List<EmployeeDto> _employees = new();
    private bool _isLoading = true;
    private bool _accessDenied;
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        if (!await PermissionChecker.HasDepartmentScopedManagementAsync())
        {
            _accessDenied = true;
            _isLoading = false;
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            _employees = await EmployeeService.GetDepartmentScopedViewableEmployeesAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _accessDenied = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading colleagues: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool Filter(EmployeeDto employee) =>
        string.IsNullOrWhiteSpace(_search) ||
        employee.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        employee.EmployeeCode.Contains(_search, StringComparison.OrdinalIgnoreCase);
}
