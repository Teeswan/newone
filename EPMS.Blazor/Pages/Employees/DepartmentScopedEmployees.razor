@page "/employees/department-scoped"
@attribute [Authorize(Policy = Permissions.DepartmentScopedManagement)]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Department Team Members</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3 mb-2" Color="Color.Primary" />
                Department Team Members
            </MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mt-1">
                Step 2 of 2 — Read-only colleagues on your department's teams
                @if (_filterTeamId.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2" OnClose="ClearTeamFilter">
                        Filtered by team
                    </MudChip>
                }
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Navigation.NavigateTo("/teams/department-scoped"))">
            Back to Teams
        </MudButton>
    </div>

    <AuthorizeView Policy="@Permissions.DepartmentScopedManagement">
        <Authorized>
            @if (_isLoading)
            {
                <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                    <MudSkeleton Animation="Animation.Wave" Height="40px" Class="mb-4" />
                    <MudSkeleton Animation="Animation.Wave" Height="40px" />
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
                    <MudTextField @bind-Value="_search" Placeholder="Search colleagues..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                </MudPaper>

                @if (!FilteredEmployees.Any())
                {
                    <MudAlert Severity="Severity.Info">
                        No employees found. Assign members to teams from the Teams page.
                    </MudAlert>
                    <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => Navigation.NavigateTo("/teams/department-scoped"))">
                        Go to Teams
                    </MudButton>
                }
                else
                {
                    <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                        <MudTable Items="FilteredEmployees" T="EmployeeDto" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Team</MudTh>
                                <MudTh>Position</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh Style="text-align: right;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="employee">
                                <MudTd>@employee.EmployeeCode</MudTd>
                                <MudTd>@employee.FullName</MudTd>
                                <MudTd>@employee.TeamName</MudTd>
                                <MudTd>@employee.PositionTitle</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(employee.IsActive == true ? Color.Success : Color.Error)">
                                        @(employee.IsActive == true ? "Active" : "Inactive")
                                    </MudChip>
                                </MudTd>
                                <MudTd Style="text-align: right;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                                   Title="View profile"
                                                   OnClick="@(() => Navigation.NavigateTo($"/employees/department-scoped/details/{employee.EmployeeId}"))" />
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager />
                            </PagerContent>
                        </MudTable>
                    </MudPaper>
                }
            }
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                Assign <strong>Department Scoped Management</strong> to your position.
            </MudAlert>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>

@code {
    private List<EmployeeDto> _employees = new();
    private bool _isLoading = true;
    private string _search = "";
    private int? _filterTeamId;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Department Teams", "/teams/department-scoped"),
        new BreadcrumbItem("Team Members", "/employees/department-scoped", disabled: true)
    };

    private IEnumerable<EmployeeDto> FilteredEmployees => _employees
        .Where(e => !_filterTeamId.HasValue || e.TeamId == _filterTeamId.Value)
        .Where(e => string.IsNullOrWhiteSpace(_search)
            || e.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || e.EmployeeCode.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        ParseTeamFilterFromUri();
        await LoadData();
    }

    protected override void OnParametersSet() => ParseTeamFilterFromUri();

    private void ParseTeamFilterFromUri()
    {
        var queryIndex = Navigation.Uri.IndexOf('?', StringComparison.Ordinal);
        if (queryIndex < 0)
        {
            _filterTeamId = null;
            return;
        }

        foreach (var part in Navigation.Uri[(queryIndex + 1)..].Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0].Equals("teamId", StringComparison.OrdinalIgnoreCase)
                && int.TryParse(Uri.UnescapeDataString(kv[1]), out var teamId))
            {
                _filterTeamId = teamId;
                return;
            }
        }

        _filterTeamId = null;
    }

    private void ClearTeamFilter() => Navigation.NavigateTo("/employees/department-scoped");

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            _employees = await EmployeeService.GetDepartmentScopedViewableEmployeesAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _employees = new List<EmployeeDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading colleagues: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
