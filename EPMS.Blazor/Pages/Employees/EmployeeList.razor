@page "/employees"
@attribute [Authorize]
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@inject IEmployeeBlazorService EmployeeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700; color: #111827;">
    <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Class="mr-2 mb-n1" Color="Color.Primary" />
    Employee Management
</MudText>

<MudCard Elevation="2" Class="mb-4" Style="border-radius: 12px;">
    <MudCardContent Class="pa-6">
        @* Statistics Cards with better styling *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(Employees?.Count ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Total Employees</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #059669 0%, #10B981 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(Employees?.Count(e => e.IsActive ?? false) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Active Employees</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #DC2626 0%, #EF4444 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(Employees?.Count(e => !(e.IsActive ?? false)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Inactive Employees</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(Employees?.Count(e => !string.IsNullOrEmpty(e.ManagerName)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">With Manager</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Toolbar with improved styling *@
        <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
            <div class="d-flex flex-wrap justify-space-between align-center gap-4">
                <MudTextField @bind-Value="searchString" Placeholder="Search by name, code, position, or department..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Style="min-width: 300px;"
                              Variant="Variant.Outlined" Clearable="true" />

                <div class="d-flex gap-3">
                    <MudFileUpload T="IBrowserFile" FilesChanged="ImportExcel" Accept=".xlsx">
                        <ActivatorContent>
                            <MudTooltip Text="Import employees from Excel" Arrow="true">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.UploadFile"
                                           Class="rounded-lg">
                                    Import
                                </MudButton>
                            </MudTooltip>
                        </ActivatorContent>
                    </MudFileUpload>

                    <MudMenu StartIcon="@Icons.Material.Filled.Download" Label="Export" Color="Color.Secondary" 
                             Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                             Class="rounded-lg">
                        <MudMenuItem OnClick="ExportExcel" Icon="@Icons.Custom.FileFormats.FileExcel" 
                                     IconColor="Color.Success">
                            <MudText Class="ml-2">Export to Excel</MudText>
                        </MudMenuItem>
                        <MudMenuItem OnClick="ExportPdf" Icon="@Icons.Custom.FileFormats.FilePdf" 
                                     IconColor="Color.Error">
                            <MudText Class="ml-2">Export to PDF</MudText>
                        </MudMenuItem>
                    </MudMenu>

                    <MudTooltip Text="Refresh employee list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshEmployees"
                                   Class="rounded-lg">
                            Refresh
                        </MudButton>
                    </MudTooltip>

                    <MudTooltip Text="Add a new employee" Arrow="true">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PersonAdd"
                                   OnClick="OpenAddDialog"
                                   Class="rounded-lg"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Add Employee
                        </MudButton>
                    </MudTooltip>
                </div>
            </div>
        </MudPaper>

        @if (Employees == null)
        {
            <div class="d-flex flex-column justify-center my-16 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-6 text-grey-darken-1" Style="font-weight: 500;">Loading employees...</MudText>
            </div>
        }
        else
        {
            <MudTable Items="@Employees" T="EmployeeDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      Elevation="1" Filter="new Func<EmployeeDto,bool>(FilterFunc)"
                      Class="rounded-xl"
                      MultiSelection="true"
                      @bind-SelectedItems="SelectedEmployees">
                <HeaderContent>
                    <MudTh Style="font-weight: 700; color: #374151;">Employee Code</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Full Name</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Department</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Team</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Position</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: center;">Reports To</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: center;">Status</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Employee Code" Style="font-weight: 500;">@context.EmployeeCode</MudTd>
                    <MudTd DataLabel="Full Name">
                        <div class="d-flex align-center">
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-3">
                                @context.FullName[0]
                            </MudAvatar>
                            <MudText Style="font-weight: 500;">@context.FullName</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Department">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                            @context.DepartmentName
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Team">
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">
                            @context.TeamName
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Position">@context.PositionTitle</MudTd>
                    <MudTd DataLabel="Reports To" Style="text-align: center;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            @(context.ManagerName ?? "No Manager")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status" Style="text-align: center;">
                        @if (context.IsActive ?? false)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled" 
                                     Icon="@Icons.Material.Filled.CheckCircle">Active</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Cancel">Inactive</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info"
                                           Size="Size.Small" OnClick="@(() => ViewDetails(context.EmployeeId))" />
                        </MudTooltip>
                        <MudTooltip Text="Edit employee" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning"
                                           Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete employee" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="@(() => DeleteEmployee(context.EmployeeId))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private List<EmployeeDto>? Employees;
    private HashSet<EmployeeDto> SelectedEmployees = new();
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        Employees = await EmployeeService.GetEmployeesAsync();
        StateHasChanged();
    }

    private async Task RefreshEmployees()
    {
        await LoadEmployees();
        Snackbar.Add("Employee list refreshed!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
    }

    // 1. Create Logic (Open Dialog)
    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EmployeeForm>("Add New Employee", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateEmployeeRequest request)
        {
            try
            {
                var success = await EmployeeService.CreateEmployeeAsync(request);
                if (success)
                {
                    Snackbar.Add("Employee created successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadEmployees();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    // 2. Update Logic (Open Dialog with Data)
    private async Task OpenEditDialog(EmployeeDto employee)
    {
        var parameters = new DialogParameters { ["IsEdit"] = true, ["EmployeeId"] = employee.EmployeeId };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<EmployeeForm>("Update Employee", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is UpdateEmployeeRequest request)
        {
            var success = await EmployeeService.UpdateEmployeeAsync(employee.EmployeeId, request);
            if (success)
            {
                Snackbar.Add("Employee updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                await LoadEmployees();
            }
        }
    }

    // 3. Delete Logic (Confirmation)
    private async Task DeleteEmployee(int id)
    {
        bool? confirm = await DialogService.ShowMessageBox("Warning",
            "Are you sure you want to delete this employee? This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            var success = await EmployeeService.DeleteEmployeeAsync(id);
            if (success)
            {
                Snackbar.Add("Employee deleted!", Severity.Info, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                await LoadEmployees();
            }
        }
    }

    private void ViewDetails(int id) => Navigation.NavigateTo($"/employees/details/{id}");

    private async Task ExportExcel()
    {
        try
        {
            var bytes = await EmployeeService.ExportToExcelAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Employees.xlsx", Convert.ToBase64String(bytes));
            Snackbar.Add("Excel exported successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ExportPdf()
    {
        try
        {
            var bytes = await EmployeeService.ExportToPdfAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Employees.pdf", Convert.ToBase64String(bytes));
            Snackbar.Add("PDF exported successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ImportExcel(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            Snackbar.Add("Starting import...", Severity.Info, config => { config.Icon = Icons.Material.Filled.UploadFile; });
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var count = await EmployeeService.ImportFromExcelAsync(ms, file.Name);
            Snackbar.Add($"Successfully imported {count} employees!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private bool FilterFunc(EmployeeDto element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (element.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.EmployeeCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        
        var statusText = (element.IsActive ?? false) ? "Active" : "Inactive";
        if (statusText.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        
        if (!string.IsNullOrEmpty(element.ManagerName) && element.ManagerName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrEmpty(element.PositionTitle) && element.PositionTitle.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrEmpty(element.DepartmentName) && element.DepartmentName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrEmpty(element.TeamName) && element.TeamName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        
        return false;
    }
}
