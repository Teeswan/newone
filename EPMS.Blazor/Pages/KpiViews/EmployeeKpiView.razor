@page "/kpi-views/employee"
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@using EPMS.Application.UseCases.KpiAssignment.Commands
@using EPMS.Domain.Enums
@inject IEmployeeKpiBlazorService EmpKpiService
@inject IAppraisalCycleBlazorService CycleService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">Employee KPI Management View</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudNumericField @bind-Value="_employeeId" Label="Employee ID" Variant="Variant.Outlined" Min="1" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="int" Label="Appraisal Cycle" @bind-Value="_cycleId" Variant="Variant.Outlined">
                @foreach (var cycle in _cycles)
                {
                    <MudSelectItem Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadData" FullWidth="true" Style="height: 56px;">Search</MudButton>
            @if (_employeeId > 0 && _cycleId > 0)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" FullWidth="true" Style="height: 56px;">Add Ad-hoc</MudButton>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_assignments != null && _assignments.Any())
{
    <MudTable Items="@_assignments" Hover="true" Bordered="true" Striped="true" Class="mb-4" T="EmployeeKpiAssignmentDto">
        <HeaderContent>
            <MudTh>KPI Name</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Weight (%)</MudTh>
            <MudTh>Target</MudTh>
            <MudTh>Actual</MudTh>
            <MudTh>Score (%)</MudTh>
            <MudTh>Weighted Score</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate Context="item">
            <MudTd DataLabel="KPI Name">@item.KpiNameSnapshot</MudTd>
            <MudTd DataLabel="Category">@item.CategorySnapshot</MudTd>
            <MudTd DataLabel="Weight (%)">@item.WeightPercent%</MudTd>
            <MudTd DataLabel="Target">@item.TargetValue @item.UnitSnapshot</MudTd>
            <MudTd DataLabel="Actual">@item.ActualValue</MudTd>
            <MudTd DataLabel="Score (%)">@item.KpiScore%</MudTd>
            <MudTd DataLabel="Weighted Score">@item.WeightedScore</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(item.Status)" Size="Size.Small">@item.Status.ToString()</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenEditDialog(item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteAssignment(item.AssignmentId))" />
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>

    @if (_summary != null)
    {
        <MudPaper Class="pa-4" Style="background-color: var(--mud-palette-background-grey)">
            <MudText Typo="Typo.h6" GutterBottom="true">Performance Summary</MudText>
            <MudGrid>
                <MudItem xs="12" sm="3">
                    <MudField Label="Total Performance Score" Variant="Variant.Outlined">@_summary.TotalPerformanceScore</MudField>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudField Label="Rating" Variant="Variant.Outlined">@_summary.Rating (@_summary.PerformanceLabel)</MudField>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudField Label="Promotion Eligibility" Variant="Variant.Outlined">@_summary.PromotionEligibility</MudField>
                </MudItem>
                <MudItem xs="12" sm="3" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick="FinaliseAssignments">Lock All</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
}
else if (_employeeId > 0 && _cycleId > 0 && !_loading)
{
    <MudAlert Severity="Severity.Info">No data found for this selection.</MudAlert>
}

@code {
    private int _employeeId;
    private int _cycleId;
    private IEnumerable<AppraisalCycleDto> _cycles = new List<AppraisalCycleDto>();
    private IEnumerable<EmployeeKpiAssignmentDto>? _assignments;
    private KpiScoreSummaryDto? _summary;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _cycles = await CycleService.GetAllAppraisalCyclesAsync();
        if (_cycles.Any()) _cycleId = _cycles.First().CycleId;
    }

    private async Task LoadData()
    {
        if (_employeeId <= 0 || _cycleId <= 0)
        {
            Snackbar.Add("Please select Employee and Cycle", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            _assignments = await EmpKpiService.GetAssignmentsAsync(_employeeId, _cycleId);
            _summary = await EmpKpiService.GetScoreSummaryAsync(_employeeId, _cycleId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters { ["EmployeeId"] = _employeeId, ["CycleId"] = _cycleId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<KpiAssignmentDialog>("Add Ad-hoc KPI", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task OpenEditDialog(EmployeeKpiAssignmentDto item)
    {
        var parameters = new DialogParameters { ["Assignment"] = item };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<KpiAssignmentDialog>("Edit KPI Assignment", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteAssignment(int id)
    {
        bool? confirm = await DialogService.ShowMessageBox("Confirm Delete", "Are you sure you want to delete this KPI assignment?", yesText: "Delete", cancelText: "Cancel");
        if (confirm == true)
        {
            var success = await EmpKpiService.DeleteAsync(id);
            if (success)
            {
                Snackbar.Add("KPI assignment deleted", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Failed to delete KPI assignment", Severity.Error);
            }
        }
    }

    private async Task FinaliseAssignments()
    {
        bool? confirm = await DialogService.ShowMessageBox("Confirm Lock", "Locking will finalize all assignments for this employee in this cycle. Continue?", yesText: "Lock", cancelText: "Cancel");
        if (confirm == true)
        {
            var command = new FinaliseKpiAssignmentCommand(_employeeId, _cycleId, null);
            var success = await EmpKpiService.FinaliseAsync(command);
            if (success)
            {
                Snackbar.Add("KPI assignments locked", Severity.Success);
                await LoadData();
            }
        }
    }

    private MudBlazor.Color GetStatusColor(KpiAssignmentStatus status) => status switch
    {
        KpiAssignmentStatus.Draft => MudBlazor.Color.Default,
        KpiAssignmentStatus.Active => MudBlazor.Color.Primary,
        KpiAssignmentStatus.Submitted => MudBlazor.Color.Info,
        KpiAssignmentStatus.Locked => MudBlazor.Color.Success,
        _ => MudBlazor.Color.Default
    };

    private MudBlazor.Color GetScoreColor(decimal score)
    {
        if (score >= 86) return MudBlazor.Color.Success;
        if (score >= 71) return MudBlazor.Color.Info;
        if (score >= 60) return MudBlazor.Color.Warning;
        return MudBlazor.Color.Error;
    }
}
