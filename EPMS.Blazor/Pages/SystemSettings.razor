@page "/system-settings"
@using MudBlazor
@using EPMS.Blazor.Services
@inject IAuthBlazorService AuthService
@inject ISnackbar Snackbar

<PageTitle>System Settings</PageTitle>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">System Settings</MudText>
                <MudText Typo="Typo.body2" Class="text-muted">Configure global system settings</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudTextField 
            @bind-Value="newDefaultPassword"
            Label="New Default Password"
            Type="InputType.Password"
            Variant="Variant.Outlined"
            Class="mt-4"
            Clearable="true"
            Adornment="Adornment.End"
            AdornmentIcon="@Icons.Material.Filled.VisibilityOff"
            AdornmentIconColor="Color.Secondary"
            OnAdornmentClick="TogglePasswordVisibility"
            InputType="showPassword ? InputType.Text : InputType.Password" />

        <MudButton 
            Variant="Variant.Filled" 
            Color="Color.Primary"
            OnClick="UpdateSettings"
            Disabled="isLoading"
            Class="mt-4">
            @if (isLoading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Updating...</MudText>
            }
            else
            {
                <MudText>Update Default Password</MudText>
            }
        </MudButton>

        <MudButton 
            Variant="Variant.Outlined" 
            Color="Color.Secondary"
            OnClick="BulkInitializeAccounts"
            Disabled="isLoading"
            Class="mt-4 ms-2">
            @if (isLoading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Initializing...</MudText>
            }
            else
            {
                <MudText>Initialize All Employee Accounts</MudText>
            }
        </MudButton>
    </MudCardContent>
</MudCard>

@code {
    private string newDefaultPassword = string.Empty;
    private bool showPassword = false;
    private bool isLoading = false;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task UpdateSettings()
    {
        if (string.IsNullOrWhiteSpace(newDefaultPassword))
        {
            Snackbar.Add("Please enter a new password", Severity.Warning);
            return;
        }

        isLoading = true;
        try
        {
            var result = await AuthService.UpdateSystemSettingsAsync(newDefaultPassword);
            if (result)
            {
                Snackbar.Add("Default password updated successfully!", Severity.Success);
                newDefaultPassword = string.Empty;
            }
            else
            {
                Snackbar.Add("Failed to update settings", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BulkInitializeAccounts()
    {
        isLoading = true;
        try
        {
            var result = await AuthService.BulkCreateAccountsAsync();
            if (result != null)
            {
                Snackbar.Add(result.Message, Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to initialize accounts", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
