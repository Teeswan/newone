@page "/teams"
@inject EPMS.Blazor.Services.ITeamBlazorService TeamService
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Teams</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700; color: #111827;">
    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2 mb-n1" Color="Color.Primary" />
    Team Management
</MudText>

<MudCard Elevation="2" Class="mb-4" Style="border-radius: 16px;">
    <MudCardContent Class="pa-6">
        @* Statistics Cards with beautiful gradients *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@FilteredTeams.Count()</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Total Teams</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #059669 0%, #10B981 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@FilteredTeams.Count(t => t.ManagerId.HasValue)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">With Manager</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #DC2626 0%, #EF4444 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@FilteredTeams.Count(t => !t.ManagerId.HasValue)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Without Manager</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@FilteredTeams.Select(t => t.DepartmentId).Distinct().Count()</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Departments</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Toolbar with improved styling *@
        <MudPaper Elevation="0" Class="pa-4 mb-6" Style="background: #F9FAFB; border-radius: 12px;">
            <div class="d-flex flex-wrap justify-space-between align-center gap-4">
                <MudTextField @bind-Value="searchString" Placeholder="Search teams by name, manager, or department..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Style="min-width: 280px;"
                              Variant="Variant.Outlined" Clearable="true" />

                <div class="d-flex flex-wrap gap-3">
                    <MudFileUpload T="IBrowserFile" FilesChanged="ImportExcel" Accept=".xlsx">
                        <ActivatorContent>
                            <MudTooltip Text="Import teams from Excel" Arrow="true">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.UploadFile"
                                           Class="rounded-lg">
                                    Import
                                </MudButton>
                            </MudTooltip>
                        </ActivatorContent>
                    </MudFileUpload>

                    <MudMenu StartIcon="@Icons.Material.Filled.Download" Label="Export" Color="Color.Secondary" 
                             Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                             Class="rounded-lg">
                        <MudMenuItem OnClick="ExportToExcel" Icon="@Icons.Custom.FileFormats.FileExcel" 
                                     IconColor="Color.Success">
                            <MudText Class="ml-2">Export to Excel</MudText>
                        </MudMenuItem>
                        <MudMenuItem OnClick="ExportToPdf" Icon="@Icons.Custom.FileFormats.FilePdf" 
                                     IconColor="Color.Error">
                            <MudText Class="ml-2">Export to PDF</MudText>
                        </MudMenuItem>
                    </MudMenu>

                    <MudTooltip Text="Refresh team list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="LoadTeams"
                                   Class="rounded-lg">
                            Refresh
                        </MudButton>
                    </MudTooltip>

                    <MudTooltip Text="Create new team" Arrow="true">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="NavigateToCreate"
                                   Class="rounded-lg"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Create New
                        </MudButton>
                    </MudTooltip>

                    @if (selectedTeams.Any())
                    {
                        <MudTooltip Text="Delete selected teams" Arrow="true">
                            <MudButton Variant="Variant.Filled" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="DeleteSelected"
                                       Class="rounded-lg">
                                Delete (@selectedTeams.Count)
                            </MudButton>
                        </MudTooltip>
                    }
                </div>
            </div>
        </MudPaper>

        @if (teams == null)
        {
            <div class="d-flex flex-column justify-center my-20 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading teams...</MudText>
            </div>
        }
        else if (!FilteredTeams.Any())
        {
            <div class="text-center py-16">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Info" Class="mb-6" />
                <MudText Typo="Typo.h5" Class="fw-bold mb-3" Style="color: #374151;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "No teams found" : "No teams match your search")
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-8" Style="color: #6B7280;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "Get started by creating your first team!" : "Try adjusting your search criteria.")
                </MudText>
                @if (string.IsNullOrWhiteSpace(searchString))
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToCreate" 
                               StartIcon="@Icons.Material.Filled.Add" Size="Size.Large"
                               Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 8px;">
                        Create First Team
                    </MudButton>
                }
            </div>
        }
        else
        {
            <MudTable Items="@FilteredTeams" T="TeamDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      MultiSelection="true" @bind-SelectedItems="selectedTeams" SelectOnRowClick="false"
                      Elevation="1" Filter="new Func<TeamDto,bool>(d => true)"
                      Class="rounded-xl">
                <HeaderContent>
                    <MudTh Style="font-weight: 700; color: #374151;"></MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Team ID</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Name</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Manager</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Department</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd></MudTd>
                    <MudTd DataLabel="Team ID" Style="font-weight: 500;">@context.TeamId</MudTd>
                    <MudTd DataLabel="Name">
                        <div class="d-flex align-center">
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-3">
                                @context.TeamName[0]
                            </MudAvatar>
                            <MudText Style="font-weight: 500;">@context.TeamName</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Manager">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            @(context.ManagerName ?? "None")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Department">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            @(context.DepartmentName ?? "None")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" 
                                           Size="Size.Small" OnClick="@(() => NavigateToDetails(context.TeamId))" />
                        </MudTooltip>
                        <MudTooltip Text="Edit team" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" 
                                           Size="Size.Small" OnClick="@(() => NavigateToEdit(context.TeamId))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete team" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" 
                                           Size="Size.Small" OnClick="@(() => DeleteTeam(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private IEnumerable<TeamDto>? teams;
    private HashSet<TeamDto> selectedTeams = new();
    private string searchString = "";

    private IEnumerable<TeamDto> FilteredTeams
    {
        get
        {
            if (teams == null)
                return Enumerable.Empty<TeamDto>();

            if (string.IsNullOrWhiteSpace(searchString))
                return teams;

            return teams.Where(t =>
                t.TeamName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (t.ManagerName != null && t.ManagerName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) ||
                (t.DepartmentName != null && t.DepartmentName.Contains(searchString, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private bool AreAllTeamsSelected => teams != null && selectedTeams.Count == teams.Count();

    private void ToggleAllTeams(bool value)
    {
        if (teams == null)
            return;
        if (value)
        {
            selectedTeams = new HashSet<TeamDto>(teams);
        }
        else
        {
            selectedTeams.Clear();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTeams();
    }

    private async Task LoadTeams()
    {
        try
        {
            teams = await TeamService.GetAllTeamsAsync();
            Snackbar.Add("Teams refreshed successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; config.VisibleStateDuration = 2000; });
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading teams: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            teams = new List<TeamDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/teams/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/teams/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/teams/edit/{id}");
    }

    private async Task DeleteTeam(TeamDto team)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this team?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await TeamService.DeleteTeamAsync(team.TeamId);
                if (success)
                {
                    Snackbar.Add("Team deleted successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting team.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting team: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task DeleteSelected()
    {
        if (!selectedTeams.Any())
        {
            return;
        }

        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete {selectedTeams.Count} selected teams?" },
            { "ButtonText", "Delete All" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            int deletedCount = 0;
            try
            {
                foreach (var team in selectedTeams.ToList())
                {
                    var success = await TeamService.DeleteTeamAsync(team.TeamId);
                    if (success)
                    {
                        deletedCount++;
                    }
                }

                if (deletedCount > 0)
                {
                    Snackbar.Add($"Successfully deleted {deletedCount} teams!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    selectedTeams.Clear();
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting teams.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting teams: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task ImportExcel(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var count = await TeamService.ImportFromExcelAsync(ms, true, "", false);
            Snackbar.Add($"Successfully imported {count} teams!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            await LoadTeams();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var fileBytes = await TeamService.ExportToExcelAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.xlsx", Convert.ToBase64String(fileBytes));
            Snackbar.Add("Excel file downloaded successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to Excel: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ExportToPdf()
    {
        try
        {
            var fileBytes = await TeamService.ExportToPdfAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.pdf", Convert.ToBase64String(fileBytes));
            Snackbar.Add("PDF file downloaded successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to PDF: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }
}
