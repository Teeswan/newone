@page "/teams"
@inject EPMS.Blazor.Services.ITeamBlazorService TeamService
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Teams</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: bold; color: #1A56DB;">Team Management</MudText>

<MudCard Elevation="1" Style="border-radius: 8px; border: 1px solid #E5E7EB;">
    <MudCardContent>
        @* Toolbar: Search and Actions *@
        <div class="d-flex flex-wrap justify-space-between align-center mb-4 gap-4">
            <MudTextField @bind-Value="searchString" Placeholder="Search teams..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Style="max-width: 350px;" />

            <div class="d-flex gap-2">
                <MudFileUpload T="IBrowserFile" FilesChanged="ImportExcel" Accept=".xlsx">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.FileUpload">
                            Import Excel
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>

                <MudMenu StartIcon="@Icons.Material.Filled.Download" Label="Export" Color="Color.Secondary" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                    <MudMenuItem OnClick="ExportToExcel" Icon="@Icons.Custom.FileFormats.FileExcel" IconColor="Color.Success">Excel</MudMenuItem>
                    <MudMenuItem OnClick="ExportToPdf" Icon="@Icons.Custom.FileFormats.FilePdf" IconColor="Color.Error">PDF</MudMenuItem>
                </MudMenu>

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToCreate"
                           Style="background-color: #1A56DB; font-weight: 600;">
                    Create New
                </MudButton>

                @if (selectedTeams.Any())
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="DeleteSelected">
                        Delete Selected (@selectedTeams.Count)
                    </MudButton>
                }

                <MudButton Variant="Variant.Outlined" Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadTeams">
                    Refresh
                </MudButton>
            </div>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="p-4" Style="border-radius: 6px;">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Size="Size.Large" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@FilteredTeams.Count()</MudText>
                            <MudText Typo="Typo.body2" Class="text-grey">Total Teams</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="p-4" Style="border-radius: 6px;">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Success" Size="Size.Large" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@FilteredTeams.Count(t => t.ManagerId.HasValue)</MudText>
                            <MudText Typo="Typo.body2" Class="text-grey">With Manager</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="p-4" Style="border-radius: 6px;">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.PersonOff" Color="Color.Error" Size="Size.Large" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@FilteredTeams.Count(t => !t.ManagerId.HasValue)</MudText>
                            <MudText Typo="Typo.body2" Class="text-grey">Without Manager</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="p-4" Style="border-radius: 6px;">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Domain" Color="Color.Warning" Size="Size.Large" Class="mr-3" />
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold">@FilteredTeams.Select(t => t.DepartmentId).Distinct().Count()</MudText>
                            <MudText Typo="Typo.body2" Class="text-grey">Departments</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (teams == null)
        {
            <div class="d-flex justify-center my-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!FilteredTeams.Any())
        {
            <div class="text-center py-12">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                <MudText Typo="Typo.h5" Class="fw-bold mb-2 text-grey">
                    @(string.IsNullOrWhiteSpace(searchString) ? "No teams found" : "No teams match your search")
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-6 text-grey">
                    @(string.IsNullOrWhiteSpace(searchString) ? "Get started by creating your first team!" : "Try adjusting your search criteria.")
                </MudText>
                @if (string.IsNullOrWhiteSpace(searchString))
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add" Size="Size.Large">
                        Create First Team
                    </MudButton>
                }
            </div>
        }
        else
        {
            <MudTable Items="@FilteredTeams" T="TeamDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      MultiSelection="true" @bind-SelectedItems="selectedTeams" SelectOnRowClick="false"
                      Elevation="0" Filter="new Func<TeamDto,bool>(d => true)">
                <HeaderContent>
                    <MudTh Style="font-weight: 600;"></MudTh>
                    <MudTh Style="font-weight: 600;">Team ID</MudTh>
                    <MudTh Style="font-weight: 600;">Name</MudTh>
                    <MudTh Style="font-weight: 600;">Manager</MudTh>
                    <MudTh Style="font-weight: 600;">Department</MudTh>
                    <MudTh Style="font-weight: 600; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd></MudTd>
                    <MudTd DataLabel="Team ID">@context.TeamId</MudTd>
                    <MudTd DataLabel="Name">@context.TeamName</MudTd>
                    <MudTd DataLabel="Manager">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                            @(context.ManagerName ?? "None")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Department">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">
                            @(context.DepartmentName ?? "None")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => NavigateToDetails(context.TeamId))" />
                        </MudTooltip>
                        <MudTooltip Text="Edit team" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => NavigateToEdit(context.TeamId))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete team" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTeam(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private IEnumerable<TeamDto>? teams;
    private HashSet<TeamDto> selectedTeams = new();
    private string searchString = "";

    private IEnumerable<TeamDto> FilteredTeams
    {
        get
        {
            if (teams == null)
                return Enumerable.Empty<TeamDto>();

            if (string.IsNullOrWhiteSpace(searchString))
                return teams;

            return teams.Where(t =>
                t.TeamName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (t.ManagerName != null && t.ManagerName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) ||
                (t.DepartmentName != null && t.DepartmentName.Contains(searchString, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private bool AreAllTeamsSelected => teams != null && selectedTeams.Count == teams.Count();

    private void ToggleAllTeams(bool value)
    {
        if (teams == null)
            return;
        if (value)
        {
            selectedTeams = new HashSet<TeamDto>(teams);
        }
        else
        {
            selectedTeams.Clear();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTeams();
    }

    private async Task LoadTeams()
    {
        try
        {
            teams = await TeamService.GetAllTeamsAsync();
            Snackbar.Add("Teams refreshed successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; config.VisibleStateDuration = 2000; });
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading teams: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            teams = new List<TeamDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/teams/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/teams/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/teams/edit/{id}");
    }

    private async Task DeleteTeam(TeamDto team)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this team?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await TeamService.DeleteTeamAsync(team.TeamId);
                if (success)
                {
                    Snackbar.Add("Team deleted successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting team.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting team: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task DeleteSelected()
    {
        if (!selectedTeams.Any())
        {
            return;
        }

        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete {selectedTeams.Count} selected teams?" },
            { "ButtonText", "Delete All" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            int deletedCount = 0;
            try
            {
                foreach (var team in selectedTeams.ToList())
                {
                    var success = await TeamService.DeleteTeamAsync(team.TeamId);
                    if (success)
                    {
                        deletedCount++;
                    }
                }

                if (deletedCount > 0)
                {
                    Snackbar.Add($"Successfully deleted {deletedCount} teams!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    selectedTeams.Clear();
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting teams.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting teams: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task ImportExcel(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var count = await TeamService.ImportFromExcelAsync(ms, true, "", false);
            Snackbar.Add($"Successfully imported {count} teams!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            await LoadTeams();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var fileBytes = await TeamService.ExportToExcelAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.xlsx", Convert.ToBase64String(fileBytes));
            Snackbar.Add("Excel file downloaded successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to Excel: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task ExportToPdf()
    {
        try
        {
            var fileBytes = await TeamService.ExportToPdfAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.pdf", Convert.ToBase64String(fileBytes));
            Snackbar.Add("PDF file downloaded successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to PDF: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }
}
