@page "/teams"
@inject EPMS.Blazor.Services.ITeamBlazorService TeamService
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Teams</PageTitle>

<MudContainer>
    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudItem>
            <MudText Typo="Typo.h4" Class="mb-0">Teams</MudText>
        </MudItem>
        <MudItem>
            <MudButtonGroup Variant="Variant.Filled">
                <MudButton Color="Color.Primary" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add">
                    Create New
                </MudButton>
                @if (selectedTeams.Any())
                {
                    <MudButton Color="Color.Error" OnClick="DeleteSelected" StartIcon="@Icons.Material.Filled.Delete">
                        Delete Selected (@selectedTeams.Count)
                    </MudButton>
                }
                <MudButton Color="Color.Success" OnClick="ExportToExcel" StartIcon="@Icons.Material.Filled.Download">
                    Export Excel
                </MudButton>
                <MudButton Color="Color.Secondary" OnClick="ExportToPdf" StartIcon="@Icons.Material.Filled.PictureAsPdf">
                    Export PDF
                </MudButton>
                <MudButton Color="Color.Info" OnClick="ShowImportDialog" StartIcon="@Icons.Material.Filled.Upload">
                    Import Excel
                </MudButton>
            </MudButtonGroup>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="pa-4">
        @if (teams == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!teams.Any())
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                No teams found. Create your first team!
            </MudAlert>
        }
        else
        {
            <MudTable Items="@teams" Hover="true" Breakpoint="Breakpoint.Sm" MultiSelection="true" @bind-SelectedItems="selectedTeams" SelectOnRowClick="false">
                <HeaderContent>
                    <MudTh>
                        <MudCheckBox T="bool" Checked="@AreAllTeamsSelected" CheckedChanged="@((bool value) => ToggleAllTeams(value))" Size="Size.Small" />
                    </MudTh>
                    <MudTh>Team ID</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Manager</MudTh>
                    <MudTh>Department</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd></MudTd>
                    <MudTd DataLabel="Team ID">@context.TeamId</MudTd>
                    <MudTd DataLabel="Name">@context.TeamName</MudTd>
                    <MudTd DataLabel="Manager">@context.ManagerName ?? "None"</MudTd>
                    <MudTd DataLabel="Department">@context.DepartmentName ?? "None"</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                            <MudButton Color="Color.Info" OnClick="() => NavigateToDetails(context.TeamId)" StartIcon="@Icons.Material.Filled.Visibility">View</MudButton>
                            <MudButton Color="Color.Warning" OnClick="() => NavigateToEdit(context.TeamId)" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                            <MudButton Color="Color.Error" OnClick="() => DeleteTeam(context)" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                        </MudButtonGroup>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<TeamDto>? teams;
    private HashSet<TeamDto> selectedTeams = new();

    private bool AreAllTeamsSelected => teams != null && selectedTeams.Count == teams.Count();

    private void ToggleAllTeams(bool value)
    {
        if (teams == null)
            return;
        if (value)
        {
            selectedTeams = new HashSet<TeamDto>(teams);
        }
        else
        {
            selectedTeams.Clear();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTeams();
    }

    private async Task LoadTeams()
    {
        try
        {
            teams = await TeamService.GetAllTeamsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading teams: {ex.Message}", Severity.Error);
            teams = new List<TeamDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/teams/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/teams/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/teams/edit/{id}");
    }

    private async Task DeleteTeam(TeamDto team)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this team?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await TeamService.DeleteTeamAsync(team.TeamId);
                if (success)
                {
                    Snackbar.Add("Team deleted successfully!", Severity.Success);
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting team.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting team: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteSelected()
    {
        if (!selectedTeams.Any())
        {
            return;
        }

        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete {selectedTeams.Count} selected teams?" },
            { "ButtonText", "Delete All" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            int deletedCount = 0;
            try
            {
                foreach (var team in selectedTeams.ToList())
                {
                    var success = await TeamService.DeleteTeamAsync(team.TeamId);
                    if (success)
                    {
                        deletedCount++;
                    }
                }

                if (deletedCount > 0)
                {
                    Snackbar.Add($"Successfully deleted {deletedCount} teams!", Severity.Success);
                    selectedTeams.Clear();
                    await LoadTeams();
                }
                else
                {
                    Snackbar.Add("Error deleting teams.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting teams: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var fileBytes = await TeamService.ExportToExcelAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.xlsx", Convert.ToBase64String(fileBytes));
            Snackbar.Add("Excel file downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to Excel: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportToPdf()
    {
        try
        {
            var fileBytes = await TeamService.ExportToPdfAsync();
            await JSRuntime.InvokeVoidAsync("saveAsFile", "Teams.pdf", Convert.ToBase64String(fileBytes));
            Snackbar.Add("PDF file downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task ShowImportDialog()
    {
        Snackbar.Add("Opening import dialog...", Severity.Info);
        var dialog = DialogService.Show<ImportTeamDialog>("Import Teams");
        var result = await dialog.Result;
        
        if (!result.Canceled)
        {
            await LoadTeams();
        }
    }
}
