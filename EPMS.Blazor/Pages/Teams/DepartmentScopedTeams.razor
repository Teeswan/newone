@page "/teams/department-scoped"
@attribute [Authorize(Policy = Permissions.DepartmentScopedManagement)]
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using EPMS.Blazor.Dialogs
@inject ITeamBlazorService TeamService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>My Department Teams</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    <div class="d-flex flex-wrap justify-space-between align-center mb-6 gap-4">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: #111827;">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-3 mb-2" Color="Color.Primary" />
                My Department Teams
            </MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mt-1">
                Step 1 of 2 — Manage teams in your department
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                   OnClick="@(() => Navigation.NavigateTo("/employees/department-scoped"))">
            View Employees
        </MudButton>
    </div>

    <AuthorizeView Policy="@Permissions.DepartmentScopedManagement">
        <Authorized>
            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else if (_teams.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">No teams in your department yet.</MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                         OnClick="@(() => Navigation.NavigateTo("/employees/department-scoped"))">
                    Continue to Employees
                </MudButton>
            }
            else
            {
                <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                    <MudTable Items="_teams" T="TeamDto" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Code</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Manager</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh Style="text-align: right;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="team">
                            <MudTd>@team.TeamIdName</MudTd>
                            <MudTd>
                                <MudLink Typo="Typo.body2" Color="Color.Primary" Underline="Underline.Hover"
                                         OnClick="@(() => GoToTeamEmployees(team.TeamId))"
                                         Style="cursor: pointer;">
                                    @team.TeamName
                                </MudLink>
                            </MudTd>
                            <MudTd>@(team.ManagerName ?? "—")</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(team.IsActive ? Color.Success : Color.Error)">
                                    @(team.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudTd>
                            <MudTd Style="text-align: right;">
                                <MudTooltip Text="View team members">
                                    <MudIconButton Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Small"
                                                   OnClick="@(() => GoToTeamEmployees(team.TeamId))" />
                                </MudTooltip>
                                <MudTooltip Text="Edit team">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialog(team))" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            }
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Error">
                Assign <strong>Department Scoped Management</strong> to your position.
            </MudAlert>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>

@code {
    private List<TeamDto> _teams = new();
    private bool _isLoading = true;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new BreadcrumbItem("My Department Teams", "/teams/department-scoped", disabled: true)
    };

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _isLoading = true;
            _teams = await TeamService.GetDepartmentScopedManageableTeamsAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _teams = new List<TeamDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToTeamEmployees(int teamId) =>
        Navigation.NavigateTo($"/employees/department-scoped?teamId={teamId}");

    private async Task OpenEditDialog(TeamDto team)
    {
        var parameters = new DialogParameters
        {
            ["Id"] = team.TeamId,
            ["DepartmentScoped"] = true
        };
        var dialog = await DialogService.ShowAsync<TeamDialog>("Update Team", parameters);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadData();
            Snackbar.Add("Team updated.", Severity.Success);
        }
    }
}
