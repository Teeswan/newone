@page "/teams/edit/{id:int}"
@inject EPMS.Blazor.Services.ITeamBlazorService TeamService
@inject EPMS.Blazor.Services.IDepartmentBlazorService DepartmentService
@inject EPMS.Blazor.Services.IEmployeeBlazorService EmployeeService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Team</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Edit Team</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Update team information</MudText>
                </div>
            </div>
            <MudDivider Class="mb-8" />

            @if (team == null)
            {
                <div class="text-center py-16">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading team details...</MudText>
                </div>
            }
            else
            {
                <EditForm Model="team" OnValidSubmit="HandleValidSubmit">
                    <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%); border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Color="Color.Warning" />
                            Update Team Details
                        </MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudTextField 
                                    @bind-Value="team.TeamName" 
                                    Label="Team Name" 
                                    Required="true"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Groups"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect 
                                    @bind-Value="team.ManagerId" 
                                    Label="Manager"
                                    Required="false"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    T="int?"
                                    Clearable="true"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Person"
                                    Class="rounded-lg">
                                    <MudSelectItem T="int?" Value="@((int?)null)">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Class="mr-2" Color="Color.Warning" />
                                        None (No Manager)
                                    </MudSelectItem>
                                    @if (employees != null)
                                    {
                                        @foreach (var emp in employees)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect 
                                    @bind-Value="team.DepartmentId" 
                                    Label="Department"
                                    Required="true"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    T="int?"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Domain"
                                    Class="rounded-lg">
                                    @if (departments != null)
                                    {
                                        @foreach (var dept in departments)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)dept.DepartmentId)">@dept.DepartmentName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <div class="d-flex justify-end gap-3 pt-4">
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Cancel" 
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       Class="rounded-lg px-6">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save changes to this team" Arrow="true">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Class="rounded-lg px-8"
                                       Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                                Save Changes
                            </MudButton>
                        </MudTooltip>
                    </div>
                </EditForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateTeamRequest? team;
    private IEnumerable<DepartmentDto>? departments;
    private IEnumerable<EmployeeDto>? employees;

    protected override async Task OnParametersSetAsync()
    {
        var teamDto = await TeamService.GetTeamByIdAsync(Id);
        if (teamDto != null)
        {
            team = new UpdateTeamRequest
            {
                TeamName = teamDto.TeamName,
                ManagerId = teamDto.ManagerId,
                DepartmentId = teamDto.DepartmentId
            };
        }
        departments = await DepartmentService.GetAllDepartmentsAsync();
        employees = await EmployeeService.GetEmployeesAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (team != null)
        {
            try
            {
                await TeamService.UpdateTeamAsync(Id, team);
                Snackbar.Add("Team updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                NavigationManager.NavigateTo("/teams");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating team: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/teams");
    }
}
