@page "/performanceevaluations"
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IReportBlazorService ReportService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h4">Performance Evaluations</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NavigateToCreate">
            Create New
        </MudButton>
    </MudStack>

    <MudTable Items="@performanceEvaluations" Hover="true" Bordered="true" Striped="true" Loading="@loading" Class="mb-4">
        <HeaderContent>
            <MudTh>Eval ID</MudTh>
            <MudTh>Employee</MudTh>
            <MudTh>Cycle</MudTh>
            <MudTh>Form</MudTh>
            <MudTh>Self Rating</MudTh>
            <MudTh>Manager Rating</MudTh>
            <MudTh>Final Score</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Eval ID">@context.EvalId</MudTd>
            <MudTd DataLabel="Employee">@context.EmployeeName</MudTd>
            <MudTd DataLabel="Cycle">@context.CycleName</MudTd>
            <MudTd DataLabel="Form">@context.FormName</MudTd>
            <MudTd DataLabel="Self Rating">
                <MudRating SelectedValue="@(context.SelfRating ?? 0)" ReadOnly="true" MaxValue="5" />
            </MudTd>
            <MudTd DataLabel="Manager Rating">
                <MudRating SelectedValue="@(context.ManagerRating ?? 0)" ReadOnly="true" MaxValue="5" />
            </MudTd>
            <MudTd DataLabel="Final Score">
                <MudText Color="Color.Primary" Style="font-weight: bold;">@context.FinalRatingScore?.ToString("N2")%</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align:right">
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => NavigateToDetails(context.EvalId))">Details</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => NavigateToEdit(context.EvalId))">Edit</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeletePerformanceEvaluation(context.EvalId))">Delete</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf" OnClick="@(() => Download360Report(context.EvalId))">360° Feedback Report (RDLC)</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf" OnClick="@(() => DownloadAppraisalReport(context.EvalId))">Appraisal Report (RDLC)</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf" OnClick="@(() => DownloadSelfAssessmentReport(context.EvalId))">Self-Assessment Report (RDLC)</MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No performance evaluations found.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private IEnumerable<PerformanceEvaluationDto>? performanceEvaluations;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPerformanceEvaluations();
    }

    private async Task LoadPerformanceEvaluations()
    {
        loading = true;
        try
        {
            performanceEvaluations = await PerformanceEvaluationService.GetAllPerformanceEvaluationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance evaluations: {ex.Message}", Severity.Error);
            performanceEvaluations = new List<PerformanceEvaluationDto>();
        }
        finally
        {
            loading = false;
        }
    }

    private void NavigateToCreate() => NavigationManager.NavigateTo("/performanceevaluations/create");
    private void NavigateToDetails(int id) => NavigationManager.NavigateTo($"/performanceevaluations/details/{id}");
    private void NavigateToEdit(int id) => NavigationManager.NavigateTo($"/performanceevaluations/edit/{id}");

    private async Task DeletePerformanceEvaluation(int evalId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirm Delete",
            "Are you sure you want to delete this performance evaluation?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            var success = await PerformanceEvaluationService.DeletePerformanceEvaluationAsync(evalId);
            if (success)
            {
                Snackbar.Add("Performance evaluation deleted successfully.", Severity.Success);
                await LoadPerformanceEvaluations();
            }
            else
            {
                Snackbar.Add("Error deleting performance evaluation.", Severity.Error);
            }
        }
    }

    private async Task Download360Report(int evalId)
    {
        try
        {
            var pdfBytes = await ReportService.Generate360FeedbackRdlcAsync(evalId);
            await ReportService.DownloadPdfAsync(pdfBytes, $"360Feedback_RDLC_{evalId}.pdf");
            Snackbar.Add("360° Feedback report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadAppraisalReport(int evalId)
    {
        try
        {
            var pdfBytes = await ReportService.GeneratePerformanceAppraisalRdlcAsync(evalId);
            await ReportService.DownloadPdfAsync(pdfBytes, $"PerformanceAppraisal_RDLC_{evalId}.pdf");
            Snackbar.Add("Performance Appraisal report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadSelfAssessmentReport(int evalId)
    {
        try
        {
            var pdfBytes = await ReportService.GenerateSelfAssessmentRdlcAsync(evalId);
            await ReportService.DownloadPdfAsync(pdfBytes, $"SelfAssessment_RDLC_{evalId}.pdf");
            Snackbar.Add("Self-Assessment report downloaded successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
    }

    private Color GetStatusColor(EPMS.Domain.Enums.PerformanceEvaluationStatus status)
    {
        return status switch
        {
            EPMS.Domain.Enums.PerformanceEvaluationStatus.Draft => Color.Default,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.SelfSubmitted => Color.Primary,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.ManagerReviewed => Color.Info,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.Finalized => Color.Success,
            _ => Color.Default
        };
    }
}
