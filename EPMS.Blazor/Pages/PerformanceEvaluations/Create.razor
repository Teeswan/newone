@page "/performanceevaluations/create"
@using EPMS.Shared.Requests
@using EPMS.Domain.Enums
@using EPMS.Blazor.Services
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Create Performance Evaluation</MudText>
        <MudDivider Class="mb-6" />

        <MudForm Model="@createRequest" @ref="@form" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Employee ID" @bind-Value="createRequest.EmployeeId" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Cycle ID" @bind-Value="createRequest.CycleId" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Form ID" @bind-Value="createRequest.FormId" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="PerformanceEvaluationStatus?" Label="Status" @bind-Value="createRequest.Status" Variant="Variant.Outlined">
                        @foreach (PerformanceEvaluationStatus status in Enum.GetValues(typeof(PerformanceEvaluationStatus)))
                        {
                            <MudSelectItem T="PerformanceEvaluationStatus?" Value="@status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Self Rating" @bind-Value="createRequest.SelfRating" Variant="Variant.Outlined" Min="0" Max="5" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Manager Rating" @bind-Value="createRequest.ManagerRating" Variant="Variant.Outlined" Min="0" Max="5" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Self Comments" @bind-Value="createRequest.SelfComments" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Manager Comments" @bind-Value="createRequest.ManagerComments" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Final Rating Score" @bind-Value="createRequest.FinalRatingScore" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    <MudCheckBox T="bool" @bind-Value="isFinalizedValue" Label="Is Finalized" Color="Color.Primary" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Create</MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? form;
    private CreatePerformanceEvaluationRequest createRequest = new() { Status = PerformanceEvaluationStatus.Draft };
    private bool isFinalizedValue { get; set; } = false;

    private async Task HandleValidSubmit()
    {
        await form!.Validate();
        if (form.IsValid)
        {
            createRequest.IsFinalized = isFinalizedValue;
            if (isFinalizedValue)
            {
                createRequest.FinalizedAt = DateTime.Now;
            }

            try
            {
                await PerformanceEvaluationService.CreatePerformanceEvaluationAsync(createRequest);
                Snackbar.Add("Performance evaluation created successfully.", Severity.Success);
                NavigationManager.NavigateTo("/performanceevaluations");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating performance evaluation: {ex.Message}", Severity.Error);
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performanceevaluations");
}
