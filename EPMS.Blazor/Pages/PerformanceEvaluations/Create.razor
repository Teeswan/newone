@page "/performanceevaluations/create"
@using EPMS.Shared.Requests
@using EPMS.Domain.Enums
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IEmployeeBlazorService EmployeeService
@inject IAppraisalCycleBlazorService CycleService
@inject IAppraisalFormBlazorService FormService
@inject IFormQuestionBlazorService FormQuestionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Create @(evaluationType.HasValue ? GetTypeName(evaluationType.Value) : "Performance Evaluation")</MudText>
        <MudDivider Class="mb-6" />

        <MudForm Model="@createRequest" @ref="@form" ValidationDelay="0">
            <MudGrid>
                <!-- Header Info Section (Matches RDLC Layout) -->
                <MudItem xs="12">
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Employee Information</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" Label="Employee Name" Value="createRequest.EmployeeId" ValueChanged="@(v => OnEmployeeChanged(v))" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                                    @if (employees != null)
                                    {
                                        @foreach (var emp in GetFilterEmployeesByContext())
                                        {
                                            <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Employee ID" Value="@selectedEmployee?.EmployeeCode" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Current Position" Value="@selectedEmployee?.PositionTitle" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Label="Department" Value="@selectedEmployee?.DepartmentName" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" Label="Appraisal Cycle" Value="createRequest.CycleId" ValueChanged="@(v => OnCycleChanged(v))" Required="true" Variant="Variant.Outlined">
                                    @if (cycles != null)
                                    {
                                        @foreach (var cycle in cycles)
                                        {
                                            <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudDatePicker Label="Assessment Date" @bind-Date="createRequest.FinalizedAt" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudTextField Label="Effective Date" Value="@effectiveDateDisplay" ReadOnly="true" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int" Label="Appraisal Form" Value="createRequest.FormId" ValueChanged="@(v => OnFormChanged(v))" Required="true" Variant="Variant.Outlined">
                                    @if (forms != null)
                                    {
                                        @foreach (var formItem in forms)
                                        {
                                            <MudSelectItem T="int" Value="@formItem.FormId">@formItem.FormName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="PerformanceEvaluationStatus?" Label="Evaluation Status" @bind-Value="createRequest.Status" Variant="Variant.Outlined">
                                    @foreach (PerformanceEvaluationStatus status in Enum.GetValues(typeof(PerformanceEvaluationStatus)))
                                    {
                                        <MudSelectItem T="PerformanceEvaluationStatus?" Value="@status">@status</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <!-- Evaluation Ratings Section -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h5" Class="mb-4">Evaluator Ratings</MudText>
                    
                    @if (GetUniqueEvaluators().Any())
                    {
                        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
                            @foreach (var evaluator in GetUniqueEvaluators())
                            {
                                <MudTabPage Text="@($"{GetEmployeeName(evaluator.Id)} ({evaluator.Role})")">
                                    <MudTable Items="@GetResponsesForEvaluator(evaluator.Id, evaluator.Role)" Hover="true" Elevation="0" Dense="true">
                                        <HeaderContent>
                                            <MudTh Style="width: 50px">No</MudTh>
                                            <MudTh>Category</MudTh>
                                            <MudTh>Criteria</MudTh>
                                            <MudTh Style="width: 250px">Rating (1-5)</MudTh>
                                            <MudTh>Comments</MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="resp">
                                            <MudTd>@GetQuestionSortOrder(resp.QuestionId)</MudTd>
                                            <MudTd>@GetQuestionCategory(resp.QuestionId)</MudTd>
                                            <MudTd>@GetQuestionText(resp.QuestionId)</MudTd>
                                            <MudTd>
                                                <MudRating SelectedValue="@(resp.RatingValue ?? 0)" SelectedValueChanged="@(v => resp.RatingValue = v)" MaxValue="5" />
                                                <MudText Typo="Typo.caption" Class="ml-2">@(resp.RatingValue > 0 ? resp.RatingValue.ToString() : "None")</MudText>
                                            </MudTd>
                                            <MudTd>
                                                <MudTextField @bind-Value="resp.AnswerText" Placeholder="Comments..." Variant="Variant.Text" />
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                    <div class="d-flex justify-end mt-2">
                                        <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveEvaluator(evaluator.Id, evaluator.Role))">Remove Evaluator</MudButton>
                                    </div>
                                </MudTabPage>
                            }
                        </MudTabs>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">Please select an employee and form to load questions, then add evaluators.</MudAlert>
                    }

                    @if (evaluationType != AppraisalFormType.SelfAssessment)
                    {
                        <div class="mt-4 d-flex align-center gap-4">
                            <MudSelect T="int?" Label="Select Evaluator" @bind-Value="newEvaluatorId" Variant="Variant.Outlined" Dense="true" Style="max-width: 300px">
                                @if (employees != null)
                                {
                                    @foreach (var emp in employees)
                                    {
                                        <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                            <MudSelect T="string" Label="Role" @bind-Value="newEvaluatorRole" Variant="Variant.Outlined" Dense="true" Style="max-width: 150px">
                                <MudSelectItem Value="@("Self")">Self</MudSelectItem>
                                <MudSelectItem Value="@("Manager")">Manager</MudSelectItem>
                                <MudSelectItem Value="@("Peer")">Peer</MudSelectItem>
                                <MudSelectItem Value="@("Subordinate")">Subordinate</MudSelectItem>
                                <MudSelectItem Value="@("External")">External</MudSelectItem>
                            </MudSelect>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="AddNewEvaluator">Add Evaluator</MudButton>
                        </div>
                    }
                </MudItem>

                <MudItem xs="12">
                    <MudExpansionPanels>
                        <MudExpansionPanel Text="Final Summary & Comments">
                            <MudGrid>
                                @if (evaluationType != AppraisalFormType.Feedback360)
                                {
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="createRequest.SelfRating" Label="Total Self Rating" ReadOnly="true" Variant="Variant.Outlined" HelperText="Auto-calculated from ratings" />
                                    </MudItem>
                                    @if (evaluationType != AppraisalFormType.SelfAssessment)
                                    {
                                        <MudItem xs="12" sm="3">
                                            <MudNumericField @bind-Value="createRequest.ManagerRating" Label="Total Manager Rating" ReadOnly="true" Variant="Variant.Outlined" HelperText="Auto-calculated from ratings" />
                                        </MudItem>
                                    }
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="createRequest.FinalRatingScore" Label="Final Score (%)" ReadOnly="true" Variant="Variant.Outlined" HelperText="Auto-calculated (Manager total / Max)" />
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="3">
                                    <MudCheckBox @bind-Value="isFinalizedValue" Label="Finalize & Lock?" Color="Color.Primary" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="createRequest.SelfComments" Label="Employee Overall Remarks" Lines="3" Variant="Variant.Outlined" />
                                </MudItem>
                                @if (evaluationType != AppraisalFormType.SelfAssessment)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="createRequest.ManagerComments" Label="Appraiser Overall Remarks" Lines="3" Variant="Variant.Outlined" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Create Evaluation</MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? Type { get; set; }

    private AppraisalFormType? evaluationType => Type.HasValue ? (AppraisalFormType)Type.Value : null;

    private MudForm? form;
    private CreatePerformanceEvaluationRequest createRequest = new() { Status = PerformanceEvaluationStatus.Draft, FinalizedAt = DateTime.Now };
    private bool isFinalizedValue { get; set; } = false;

    private List<EmployeeDto>? employees;
    private List<AppraisalCycleDto>? cycles;
    private List<AppraisalFormDto>? forms;
    private List<FormQuestionDto>? formQuestions;

    private EmployeeDto? selectedEmployee;
    private EmployeeDto? currentUserEmployee;
    private string? effectiveDateDisplay;

    private int? newEvaluatorId;
    private string newEvaluatorRole = "Peer";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await EmployeeService.GetEmployeesAsync();
            
            // Get current user's employee info
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var empIdClaim = user.FindFirst("EmployeeId")?.Value;
            if (int.TryParse(empIdClaim, out int empId))
            {
                currentUserEmployee = employees.FirstOrDefault(e => e.EmployeeId == empId);
            }

            var cyclesEnumerable = await CycleService.GetAllAppraisalCyclesAsync();
            cycles = cyclesEnumerable.ToList();
            var formsEnumerable = await FormService.GetAllAppraisalFormsAsync();
            
            if (evaluationType.HasValue)
            {
                forms = formsEnumerable.Where(f => f.FormType == evaluationType.Value).ToList();
            }
            else
            {
                forms = formsEnumerable.ToList();
            }

            // Auto-select current employee for Self-Assessment
            if (evaluationType == AppraisalFormType.SelfAssessment && currentUserEmployee != null)
            {
                await OnEmployeeChanged(currentUserEmployee.EmployeeId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading lookup data: {ex.Message}", Severity.Error);
        }
    }

    private IEnumerable<EmployeeDto> GetFilterEmployeesByContext()
    {
        if (employees == null || currentUserEmployee == null) return Enumerable.Empty<EmployeeDto>();

        var userLevel = ParseLevel(currentUserEmployee.LevelId);

        return evaluationType switch
        {
            AppraisalFormType.SelfAssessment => 
                // Self-Assessment: L02 – L09
                (userLevel >= 2 && userLevel <= 9) 
                    ? employees.Where(e => e.EmployeeId == currentUserEmployee.EmployeeId) 
                    : Enumerable.Empty<EmployeeDto>(),

            AppraisalFormType.PerformanceAppraisal => 
                // Performance Appraisal: L02 – L06 (Managers submit for direct reports)
                (userLevel >= 2 && userLevel <= 6) 
                    ? employees.Where(e => e.ReportsTo == currentUserEmployee.EmployeeId) 
                    : Enumerable.Empty<EmployeeDto>(),

            AppraisalFormType.Feedback360 => 
                // 360-Feedback: L02 – L08
                (userLevel >= 2 && userLevel <= 8)
                    ? employees
                    : Enumerable.Empty<EmployeeDto>(),

            AppraisalFormType.CalibrationReview =>
                // Calibration/Review: L01 – L04
                (userLevel >= 1 && userLevel <= 4)
                    ? employees
                    : Enumerable.Empty<EmployeeDto>(),

            _ => employees
        };
    }

    private int ParseLevel(string? levelId)
    {
        if (string.IsNullOrEmpty(levelId)) return 99;
        var numericPart = new string(levelId.Where(char.IsDigit).ToArray());
        return int.TryParse(numericPart, out int level) ? level : 99;
    }

    private async Task OnEmployeeChanged(int? empId)
    {
        createRequest.EmployeeId = empId;
        selectedEmployee = employees?.FirstOrDefault(e => e.EmployeeId == empId);
        createRequest.Responses.Clear(); // Clear previous evaluators/questions

        if (empId.HasValue && selectedEmployee != null)
        {
            if (evaluationType == AppraisalFormType.SelfAssessment)
            {
                // Self assessment is only by the employee themselves
                AddEvaluatorFeedback(selectedEmployee.EmployeeId, "Self");
            }
            else if (evaluationType == AppraisalFormType.PerformanceAppraisal)
            {
                // Auto-add manager (the current user)
                if (currentUserEmployee != null)
                {
                    AddEvaluatorFeedback(currentUserEmployee.EmployeeId, "Manager");
                }
                
                // Also add the employee themselves for their self-reflection part of the appraisal if needed
                AddEvaluatorFeedback(selectedEmployee.EmployeeId, "Self");
            }
            else if (evaluationType == AppraisalFormType.Feedback360)
            {
                // 360 Feedback: Auto-add self and manager as starting point
                AddEvaluatorFeedback(selectedEmployee.EmployeeId, "Self");
                if (selectedEmployee.ReportsTo.HasValue)
                {
                    AddEvaluatorFeedback(selectedEmployee.ReportsTo.Value, "Manager");
                }

                // Add peers (same level)
                var peers = employees?.Where(e => e.LevelId == selectedEmployee.LevelId && e.EmployeeId != selectedEmployee.EmployeeId).Take(2);
                if (peers != null)
                {
                    foreach (var peer in peers)
                    {
                        AddEvaluatorFeedback(peer.EmployeeId, "Peer");
                    }
                }

                // Add subordinates (those who report to this employee)
                var subordinates = employees?.Where(e => e.ReportsTo == selectedEmployee.EmployeeId).Take(2);
                if (subordinates != null)
                {
                    foreach (var sub in subordinates)
                    {
                        AddEvaluatorFeedback(sub.EmployeeId, "Subordinate");
                    }
                }
            }
            else if (evaluationType == AppraisalFormType.CalibrationReview)
            {
                // Calibration: Senior Manager (current user) is the evaluator
                if (currentUserEmployee != null)
                {
                    AddEvaluatorFeedback(currentUserEmployee.EmployeeId, "Manager");
                }
            }
        }
        StateHasChanged();
    }

    private void OnCycleChanged(int? cycleId)
    {
        createRequest.CycleId = cycleId;
        var cycle = cycles?.FirstOrDefault(c => c.CycleId == cycleId);
        effectiveDateDisplay = cycle?.EndDate.ToString("yyyy-MM-dd") ?? "N/A";
    }

    private string GetTypeName(AppraisalFormType type) => type switch
    {
        AppraisalFormType.PerformanceAppraisal => "Performance Appraisal",
        AppraisalFormType.SelfAssessment => "Self Assessment",
        AppraisalFormType.Feedback360 => "360 Feedback",
        AppraisalFormType.CalibrationReview => "Calibration & Review",
        _ => "Performance Evaluation"
    };

    private async Task OnFormChanged(int formId)
    {
        createRequest.FormId = formId;
        try
        {
            var questions = await FormQuestionService.GetByFormIdAsync(formId);
            formQuestions = questions.OrderBy(q => q.Category).ThenBy(q => q.SortOrder).ToList();
            
            // Re-populate responses for existing evaluators with new questions
            var uniqueEvaluators = GetUniqueEvaluators();
            createRequest.Responses.Clear();

            foreach (var eval in uniqueEvaluators)
            {
                foreach (var q in formQuestions)
                {
                    createRequest.Responses.Add(new CreateAppraisalResponseRequest
                    {
                        RespondentEmployeeId = eval.Id,
                        RespondentRole = eval.Role,
                        QuestionId = q.QuestionId
                    });
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading form questions: {ex.Message}", Severity.Error);
        }
    }

    private IEnumerable<(int Id, string Role)> GetUniqueEvaluators()
    {
        return createRequest.Responses
            .Where(r => r.RespondentEmployeeId.HasValue)
            .Select(r => (r.RespondentEmployeeId!.Value, r.RespondentRole))
            .Distinct();
    }

    private IEnumerable<CreateAppraisalResponseRequest> GetResponsesForEvaluator(int id, string role)
    {
        return createRequest.Responses.Where(r => r.RespondentEmployeeId == id && r.RespondentRole == role);
    }

    private string GetEmployeeName(int id) => employees?.FirstOrDefault(e => e.EmployeeId == id)?.FullName ?? "Unknown";
    private string GetQuestionText(int? id) => formQuestions?.FirstOrDefault(q => q.QuestionId == id)?.QuestionText ?? "Unknown Question";
    private string GetQuestionCategory(int? id) => formQuestions?.FirstOrDefault(q => q.QuestionId == id)?.Category ?? "Uncategorized";
    private int GetQuestionSortOrder(int? id) => formQuestions?.FirstOrDefault(q => q.QuestionId == id)?.SortOrder ?? 0;

    private void RemoveEvaluator(int id, string role)
    {
        createRequest.Responses.RemoveAll(r => r.RespondentEmployeeId == id && r.RespondentRole == role);
    }

    private void AddNewEvaluator()
    {
        if (!newEvaluatorId.HasValue)
        {
            Snackbar.Add("Please select an employee to add as an evaluator.", Severity.Warning);
            return;
        }

        var targetEmp = employees?.FirstOrDefault(e => e.EmployeeId == newEvaluatorId);
        if (targetEmp == null) return;

        var targetLevel = ParseLevel(targetEmp.LevelId);

        // Validation based on requirements
        if (newEvaluatorRole == "External" && targetLevel != 3)
        {
            Snackbar.Add("Only Level 03 employees can be added as External Consultants.", Severity.Warning);
            return;
        }

        if (GetUniqueEvaluators().Any(e => e.Id == newEvaluatorId && e.Role == newEvaluatorRole))
        {
            Snackbar.Add("This evaluator with this role is already added.", Severity.Warning);
            return;
        }

        AddEvaluatorFeedback(newEvaluatorId.Value, newEvaluatorRole);
        newEvaluatorId = null; // Reset for next add
        StateHasChanged();
    }

    private void AddEvaluatorFeedback(int employeeId, string role)
    {
        if (formQuestions != null && formQuestions.Any())
        {
            foreach (var q in formQuestions)
            {
                if (!createRequest.Responses.Any(r => r.RespondentEmployeeId == employeeId && r.QuestionId == q.QuestionId))
                {
                    createRequest.Responses.Add(new CreateAppraisalResponseRequest
                    {
                        RespondentEmployeeId = employeeId,
                        RespondentRole = role,
                        QuestionId = q.QuestionId
                    });
                }
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        await form!.Validate();
        if (form.IsValid)
        {
            createRequest.IsFinalized = isFinalizedValue;
            // Only set FinalizedAt to Now if it wasn't set by the user via the date picker
            if (isFinalizedValue && createRequest.FinalizedAt == null)
            {
                createRequest.FinalizedAt = DateTime.Now;
            }

            try
            {
                await PerformanceEvaluationService.CreatePerformanceEvaluationAsync(createRequest);
                Snackbar.Add("Performance evaluation created successfully.", Severity.Success);
                NavigationManager.NavigateTo("/performance-hub");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating performance evaluation: {ex.Message}", Severity.Error);
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performance-hub");
}
