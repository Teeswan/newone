@page "/performanceevaluations/details/{Id:int}"
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IReportBlazorService ReportService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (eval == null)
    {
        <MudPaper Class="pa-8" Elevation="3">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-0 mb-6" Elevation="3" Style="overflow: hidden;">
            <div style="background-color: #FDE9D9; padding: 16px; border-bottom: 1px solid #e0e0e0;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h5" Style="font-weight: bold;">@GetTypeName(eval.FormType)</MudText>
                    <MudChip T="string" Color="@GetStatusColor(eval.Status)" Variant="Variant.Filled">@eval.Status.ToString()</MudChip>
                </MudStack>
            </div>

            <div class="pa-8">
                <MudGrid>
                    <!-- Employee Info Section -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="text-align: center; font-weight: bold;">ACE Data Systems Ltd.,</MudText>
                        <MudSimpleTable Style="width: 100%" Bordered="true" Dense="true">
                            <tbody>
                                <tr>
                                    <td style="width: 200px; font-weight: bold; background-color: #f5f5f5;">Employee Name :</td>
                                    <td>@eval.EmployeeName</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Employee ID :</td>
                                    <td>@eval.EmployeeCode</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Current Position :</td>
                                    <td>@eval.PositionTitle</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Department :</td>
                                    <td>@eval.DepartmentName</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Assessment Date :</td>
                                    <td>@eval.FinalizedAt?.ToString("yyyy-MM-dd")</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Manager Name :</td>
                                    <td>@eval.ManagerName</td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f5f5f5;">Finalized Status :</td>
                                    <td>
                                        @if (eval.IsFinalized == true)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-1" />
                                            <span>Finalized on @eval.FinalizedAt?.ToString("g")</span>
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Pending" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                                            <span>Pending Finalization</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudItem>

                    <!-- Evaluation Ratings Section -->
                    <MudItem xs="12" Class="mt-6">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: bold;">Evaluation Ratings</MudText>
                        @if (eval.Responses != null && eval.Responses.Any())
                        {
                            <MudTable Items="@GetDisplayResponses()" Hover="true" Bordered="true" Elevation="0" Dense="true">
                                <HeaderContent>
                                    <MudTh Style="width: 50px">No</MudTh>
                                    <MudTh>Source</MudTh>
                                    <MudTh>Assessment Subject</MudTh>
                                    <MudTh Style="width: 150px">Rating</MudTh>
                                    <MudTh>Comments</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="resp">
                                    <MudTd>@resp.SortOrder</MudTd>
                                    <MudTd>@resp.RespondentRole</MudTd>
                                    <MudTd>@resp.QuestionText</MudTd>
                                    <MudTd>
                                        <MudRating SelectedValue="@(resp.RatingValue ?? 0)" ReadOnly="true" MaxValue="5" />
                                    </MudTd>
                                    <MudTd>@resp.AnswerText</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">No ratings recorded for this evaluation.</MudAlert>
                        }
                    </MudItem>

                    <!-- Remarks Section -->
                    <MudItem xs="12" Class="mt-6">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudPaper Outlined="true" Class="pa-4">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-weight: bold;">Employee Overall Remarks</MudText>
                                    <MudText Typo="Typo.body1" Class="mt-2">@(string.IsNullOrEmpty(eval.SelfComments) ? "No remarks." : eval.SelfComments)</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudPaper Outlined="true" Class="pa-4">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-weight: bold;">Appraiser Overall Remarks</MudText>
                                    <MudText Typo="Typo.body1" Class="mt-2">@(string.IsNullOrEmpty(eval.ManagerComments) ? "No remarks." : eval.ManagerComments)</MudText>
                                </MudPaper>
                            </MudItem>
                            @if (!string.IsNullOrEmpty(eval.CalibrationComments))
                            {
                                <MudItem xs="12">
                                    <MudPaper Outlined="true" Class="pa-4" Style="background-color: #fff9f0; border: 1px solid #ffb74d;">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Warning" Style="font-weight: bold;">Senior Management Calibration Comments</MudText>
                                        <MudText Typo="Typo.body1" Class="mt-2">@eval.CalibrationComments</MudText>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudItem>

                    <!-- Calculation Section -->
                    <MudItem xs="12" Class="mt-6">
                        <MudGrid>
                            <MudItem xs="12" sm="8">
                                <MudSimpleTable Bordered="true" Dense="true">
                                    <thead>
                                        <tr>
                                            <th style="font-weight: bold; text-align: center; background-color: #f5f5f5;">Assessment Source</th>
                                            <th style="font-weight: bold; text-align: center; background-color: #f5f5f5;">Weight</th>
                                            <th style="font-weight: bold; text-align: center; background-color: #f5f5f5;">Calculated Score</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (eval.FormType == EPMS.Domain.Enums.AppraisalFormType.PerformanceAppraisal)
                                        {
                                            <tr>
                                                <td style="text-align: center;">
                                                    Manager Review
                                                    <MudTooltip Text="Weights reflect organizational policy to balance supervisor oversight and self-growth.">
                                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" Class="ml-1" />
                                                    </MudTooltip>
                                                </td>
                                                <td style="text-align: center;">80%</td>
                                                <td rowspan="2" style="text-align: center; vertical-align: middle;">
                                                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: bold;">@eval.FinalRatingScore?.ToString("N2")%</MudText>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="text-align: center;">Self Assessment</td>
                                                <td style="text-align: center;">20%</td>
                                            </tr>
                                        }
                                        else if (eval.FormType == EPMS.Domain.Enums.AppraisalFormType.Feedback360)
                                        {
                                            <tr>
                                                <td style="text-align: center;">
                                                    360° Multi-Source
                                                    <MudTooltip Text="360° scores are calculated as an equal weighted average across all multi-directional sources.">
                                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" Class="ml-1" />
                                                    </MudTooltip>
                                                </td>
                                                <td style="text-align: center;">Equal Weighted Average</td>
                                                <td style="text-align: center; vertical-align: middle;">
                                                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: bold;">@eval.FinalRatingScore?.ToString("N2")%</MudText>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td style="text-align: center;">Self Assessment</td>
                                                <td style="text-align: center;">100%</td>
                                                <td style="text-align: center; vertical-align: middle;">
                                                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: bold;">@eval.FinalRatingScore?.ToString("N2")%</MudText>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudPaper Outlined="true" Class="pa-4 d-flex flex-column align-center justify-center" Style="height: 100%;">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Self Rating Total</MudText>
                                    <MudText Typo="Typo.h6">@eval.SelfRating</MudText>
                                    <MudDivider Class="my-2" Style="width: 100%" />
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Manager Rating Total</MudText>
                                    <MudText Typo="Typo.h6">@eval.ManagerRating</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </MudItem>

                    <!-- Explanation Section -->
                    <MudItem xs="12" Class="mt-6">
                        <MudText Typo="Typo.h6" Class="mb-2" Style="font-weight: bold;">Score Explanation</MudText>
                        <MudSimpleTable Bordered="true" Dense="true">
                            <thead>
                                <tr>
                                    <th style="width: 100px; font-weight: bold; text-align: center; background-color: #f5f5f5;">Score</th>
                                    <th style="font-weight: bold; text-align: center; background-color: #f5f5f5;">Explanation</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="text-align: center;">86-100</td>
                                    <td><b>Outstanding:</b> Performance exceptional and far exceeds expectations.</td>
                                </tr>
                                <tr>
                                    <td style="text-align: center;">71-85</td>
                                    <td><b>Good:</b> Performance is consistent. Clearly meets essential requirements of job.</td>
                                </tr>
                                <tr>
                                    <td style="text-align: center;">60-70</td>
                                    <td><b>Meet requirement:</b> Performance is satisfactory. Meets requirements of the job.</td>
                                </tr>
                                <tr>
                                    <td style="text-align: center;">40-59</td>
                                    <td><b>Need Improvement:</b> Performance is inconsistent. Meets requirements occasionally.</td>
                                </tr>
                                <tr>
                                    <td style="text-align: center;">00-39</td>
                                    <td><b>Unsatisfactory:</b> Performance does not meet the minimum requirement.</td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end mt-8 gap-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToList">Back to List</MudButton>
                        
                        @if (eval.Status == EPMS.Domain.Enums.PerformanceEvaluationStatus.Draft && eval.EmployeeId == currentUserEmployee?.EmployeeId)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitSelf">Submit Self-Assessment</MudButton>
                        }
                        
                        @if (eval.Status == EPMS.Domain.Enums.PerformanceEvaluationStatus.SelfSubmitted && eval.ManagerName?.Contains(currentUserEmployee?.FullName ?? "___") == true)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SubmitManager">Complete Manager Review</MudButton>
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="DownloadReport">Download Report</MudButton>
                        
                        <AuthorizeView Permissions="@EPMS.Shared.Constants.Permissions.PerformanceEvaluations.Manage">
                            @if (eval.Status == EPMS.Domain.Enums.PerformanceEvaluationStatus.Finalized)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ReopenEvaluation" StartIcon="@Icons.Material.Filled.LockOpen">Re-open Review</MudButton>
                            }
                        </AuthorizeView>

                        @if (eval.Status != EPMS.Domain.Enums.PerformanceEvaluationStatus.Finalized)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                        }
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private PerformanceEvaluationDto? eval;
    private EmployeeDto? currentUserEmployee;
    private bool isExternalConsultant;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var empIdClaim = user.FindFirst("EmployeeId")?.Value;

            eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
            if (eval == null)
            {
                Snackbar.Add("Performance evaluation not found.", Severity.Error);
                NavigationManager.NavigateTo("/performanceevaluations");
                return;
            }

            if (int.TryParse(empIdClaim, out int empId))
            {
                // In a real scenario, we'd fetch the level from the user's employee record
                // For this validation check, we'll implement a safety check on responses
                
                // 1. External Consultants (L03) should only see 360 Feedback
                // 2. They should only see responses if they are the respondent OR if it's a 360 form they are invited to
                // For now, we filter the responses they can see if they are not the subject or manager
                
                bool isSubject = eval.EmployeeId == empId;
                bool isManager = eval.ManagerName != null && eval.ManagerName.Contains(user.Identity?.Name ?? "___"); // Rough check

                // If not subject/manager, filter responses to only show their own contribution if they are an external consultant
                if (!isSubject && !isManager)
                {
                    // Filter responses: if there's any 'External' role response for this user, they only see that
                    var myResponses = eval.Responses.Where(r => r.RespondentId == empId).ToList();
                    if (myResponses.Any())
                    {
                        eval.Responses = myResponses;
                        // Hide overall comments as well for external consultants
                        eval.ManagerComments = "HIDDEN (Restricted Access)";
                        eval.SelfComments = "HIDDEN (Restricted Access)";
                        eval.FinalRatingScore = null;
                        eval.SelfRating = null;
                        eval.ManagerRating = null;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance evaluation details: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/performanceevaluations");
        }
    }

    private void BackToList() => NavigationManager.NavigateTo("/performanceevaluations");
    private void NavigateToEdit() => NavigationManager.NavigateTo($"/performanceevaluations/edit/{Id}");

    private async Task SubmitSelf()
    {
        var success = await PerformanceEvaluationService.SubmitSelfAssessmentAsync(Id);
        if (success)
        {
            Snackbar.Add("Self-assessment submitted successfully!", Severity.Success);
            await OnInitializedAsync();
        }
    }

    private async Task SubmitManager()
    {
        var success = await PerformanceEvaluationService.SubmitManagerReviewAsync(Id);
        if (success)
        {
            Snackbar.Add("Manager review completed successfully!", Severity.Success);
            await OnInitializedAsync();
        }
    }

    private async Task ReopenEvaluation()
    {
        var success = await PerformanceEvaluationService.ReopenPerformanceEvaluationAsync(Id);
        if (success)
        {
            Snackbar.Add("Evaluation re-opened successfully.", Severity.Success);
            await OnInitializedAsync();
        }
    }

    private List<AppraisalResponseDto> GetDisplayResponses()
    {
        if (eval?.Responses == null) return new List<AppraisalResponseDto>();

        // For 360 Feedback, we want to maintain anonymity for Peer and Subordinate roles 
        // when the viewer is the subject (the employee being evaluated).
        // However, the Manager should be able to see who said what for coaching purposes.
        
        // Let's implement a policy: 
        // 1. If the viewer is the subject, Peer/Subordinate roles are shown as "Anonymous Peer/Subordinate".
        // 2. Otherwise, show full details.

        var currentUserId = 0; // In a real app, get from authState
        // For now, let's assume we want to protect anonymity for everyone viewing the ratings table 
        // except maybe HR or the Appraiser.

        return eval.Responses.Select(r => new AppraisalResponseDto
        {
            ResponseId = r.ResponseId,
            EvalId = r.EvalId,
            QuestionId = r.QuestionId,
            QuestionText = r.QuestionText,
            RespondentId = r.RespondentId,
            RespondentName = (r.RespondentRole == "Peer" || r.RespondentRole == "Subordinate") ? "Anonymous" : r.RespondentName,
            RespondentRole = r.RespondentRole,
            RatingValue = r.RatingValue,
            AnswerText = (r.RespondentRole == "Peer" || r.RespondentRole == "Subordinate") ? "Comments hidden for anonymity" : r.AnswerText,
            SortOrder = r.SortOrder
        }).ToList();
    }

    private string GetTypeName(EPMS.Domain.Enums.AppraisalFormType type) => type switch
    {
        EPMS.Domain.Enums.AppraisalFormType.PerformanceAppraisal => "Performance Appraisal Form",
        EPMS.Domain.Enums.AppraisalFormType.SelfAssessment => "Employee Self-assessment Form",
        EPMS.Domain.Enums.AppraisalFormType.Feedback360 => "360° Feedback Form",
        _ => "Performance Evaluation Form"
    };

    private async Task DownloadReport()
    {
        if (eval == null) return;
        try
        {
            byte[] pdfBytes;
            string fileName;

            switch (eval.FormType)
            {
                case EPMS.Domain.Enums.AppraisalFormType.PerformanceAppraisal:
                    pdfBytes = await ReportService.GeneratePerformanceAppraisalRdlcAsync(eval.EvalId);
                    fileName = $"PerformanceAppraisal_{eval.EmployeeName}_{eval.EvalId}.pdf";
                    break;
                case EPMS.Domain.Enums.AppraisalFormType.Feedback360:
                    pdfBytes = await ReportService.Generate360FeedbackRdlcAsync(eval.EvalId);
                    fileName = $"360Feedback_{eval.EmployeeName}_{eval.EvalId}.pdf";
                    break;
                case EPMS.Domain.Enums.AppraisalFormType.SelfAssessment:
                default:
                    pdfBytes = await ReportService.GenerateSelfAssessmentRdlcAsync(eval.EvalId);
                    fileName = $"SelfAssessment_{eval.EmployeeName}_{eval.EvalId}.pdf";
                    break;
            }

            await ReportService.DownloadPdfAsync(pdfBytes, fileName);
            Snackbar.Add("Report downloaded successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error downloading report: {ex.Message}", Severity.Error);
        }
    }

    private Color GetStatusColor(EPMS.Domain.Enums.PerformanceEvaluationStatus status)
    {
        return status switch
        {
            EPMS.Domain.Enums.PerformanceEvaluationStatus.Draft => Color.Default,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.SelfSubmitted => Color.Primary,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.ManagerReviewed => Color.Info,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.AwaitingCalibration => Color.Warning,
            EPMS.Domain.Enums.PerformanceEvaluationStatus.Finalized => Color.Success,
            _ => Color.Default
        };
    }
}
