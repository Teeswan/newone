@page "/performanceevaluations/details/{Id:int}"
@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (eval == null)
    {
        <MudPaper Class="pa-8" Elevation="3">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-0 mb-6" Elevation="3" Style="overflow: hidden;">
            <div style="background-color: #FDE9D9; padding: 16px; border-bottom: 1px solid #e0e0e0;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h5" Style="font-weight: bold;">Performance Evaluation</MudText>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">@eval.Status.ToString()</MudChip>
                </MudStack>
            </div>

            <div class="pa-8">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.body1">Employee: @eval.EmployeeName</MudText>
                        <MudText Typo="Typo.body1">Status: @eval.Status</MudText>
                        <MudText Typo="Typo.body2">Creator: @eval.CreatedByName</MudText>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end mt-8 gap-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToList">Back to List</MudButton>

                        @if (eval.Status != EPMS.Domain.Enums.PerformanceEvaluationStatus.Finalized && eval.CreatedByEmployeeId == currentEmployeeId)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="FinalizeEvaluation" StartIcon="@Icons.Material.Filled.Lock">Check & Finalize</MudButton>
                        }
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    [Inject] private IPerformanceEvaluationBlazorService PerformanceEvaluationService { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [Parameter]
    public int Id { get; set; }

    private PerformanceEvaluationDto? eval;
    private int? currentEmployeeId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var empIdClaim = user.FindFirst("EmployeeId")?.Value;
        if (int.TryParse(empIdClaim, out int empId))
        {
            currentEmployeeId = empId;
        }

        eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
    }

    private void BackToList() => NavigationManager.NavigateTo("/performanceevaluations");

    private async Task FinalizeEvaluation()
    {
        var success = await PerformanceEvaluationService.FinalizePerformanceEvaluationAsync(Id);
        if (success)
        {
            Snackbar.Add("Evaluation checked, locked and finalized successfully!", Severity.Success);
            eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
        }
        else
        {
            Snackbar.Add("Failed to finalize evaluation.", Severity.Error);
        }
    }
}
