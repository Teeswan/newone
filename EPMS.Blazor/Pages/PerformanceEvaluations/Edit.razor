@page "/performanceevaluations/edit/{Id:int}"
@using EPMS.Shared.Requests
@using EPMS.Domain.Enums
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IEmployeeBlazorService EmployeeService
@inject IAppraisalCycleBlazorService CycleService
@inject IAppraisalFormBlazorService FormService
@inject IFormQuestionBlazorService FormQuestionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Edit Performance Evaluation</MudText>
        <MudDivider Class="mb-6" />

        @if (updateRequest == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            @if (isReadOnlyForUser)
            {
                <MudAlert Severity="Severity.Info" Class="mb-6">This evaluation is currently in the <b>@updateRequest.Status</b> phase and is read-only for your role.</MudAlert>
            }

            <MudForm Model="@updateRequest" @ref="@form" ValidationDelay="0" ReadOnly="@isReadOnlyForUser">
                <MudGrid>
                    <!-- Header Info Section (Matches RDLC Layout) -->
                    <MudItem xs="12">
                        <MudPaper Outlined="true" Class="pa-4 mb-4">
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Employee Information</MudText>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudSelect T="int?" Label="Employee Name" Value="updateRequest.EmployeeId" ValueChanged="@(v => OnEmployeeChanged(v))" Required="true" Variant="Variant.Outlined" ReadOnly="true">
                                        @if (employees != null)
                                        {
                                            @foreach (var emp in employees)
                                            {
                                                <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Employee ID" Value="@selectedEmployee?.EmployeeCode" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Current Position" Value="@selectedEmployee?.PositionTitle" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField Label="Department" Value="@selectedEmployee?.DepartmentName" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudSelect T="int?" Label="Appraisal Cycle" Value="updateRequest.CycleId" ValueChanged="@(v => OnCycleChanged(v))" Required="true" Variant="Variant.Outlined">
                                        @if (cycles != null)
                                        {
                                            @foreach (var cycle in cycles)
                                            {
                                                <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudDatePicker Label="Assessment Date" @bind-Date="updateRequest.FinalizedAt" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudTextField Label="Effective Date" Value="@effectiveDateDisplay" ReadOnly="true" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12">
                        <MudPaper Outlined="true" Class="pa-4 mb-4">
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudSelect T="int" Label="Appraisal Form" @bind-Value="updateRequest.FormId" Required="true" Variant="Variant.Outlined">
                                        @if (forms != null)
                                        {
                                            @foreach (var formItem in forms)
                                            {
                                                <MudSelectItem T="int" Value="@formItem.FormId">@formItem.FormName</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudSelect T="PerformanceEvaluationStatus?" Label="Evaluation Status" @bind-Value="updateRequest.Status" Variant="Variant.Outlined">
                                        @foreach (PerformanceEvaluationStatus status in Enum.GetValues(typeof(PerformanceEvaluationStatus)))
                                        {
                                            <MudSelectItem T="PerformanceEvaluationStatus?" Value="@status">@status</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <!-- Evaluation Ratings Section -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.h5" Class="mb-4">Evaluator Ratings</MudText>
                        
                        @if (GetUniqueEvaluators().Any())
                        {
                            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
                                @foreach (var evaluator in GetUniqueEvaluators())
                                {
                                    <MudTabPage Text="@($"{evaluator.Name} ({evaluator.Role})")">
                                        <MudTable Items="@GetResponsesForEvaluator(evaluator.Id, evaluator.Role)" Hover="true" Elevation="0" Dense="true">
                                            <HeaderContent>
                                                <MudTh Style="width: 50px">No</MudTh>
                                                <MudTh>Category</MudTh>
                                                <MudTh>Criteria</MudTh>
                                                <MudTh Style="width: 250px">Rating (1-5)</MudTh>
                                                <MudTh>Comments</MudTh>
                                            </HeaderContent>
                                            <RowTemplate Context="resp">
                                                <MudTd>@resp.SortOrder</MudTd>
                                                <MudTd>@resp.QuestionCategory</MudTd>
                                                <MudTd>@resp.QuestionText</MudTd>
                                                <MudTd>
                                                    <MudRating SelectedValue="@(resp.RatingValue ?? 0)" SelectedValueChanged="@(v => resp.RatingValue = v)" MaxValue="5" ReadOnly="@isReadOnlyForUser" />
                                                    <MudText Typo="Typo.caption" Class="ml-2">@(resp.RatingValue > 0 ? resp.RatingValue.ToString() : "None")</MudText>
                                                </MudTd>
                                                <MudTd>
                                                    <MudTextField @bind-Value="resp.AnswerText" Placeholder="Comments..." Variant="Variant.Text" ReadOnly="@isReadOnlyForUser" />
                                                </MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                        @if (!isReadOnlyForUser)
                                        {
                                            <div class="d-flex justify-end mt-2">
                                                <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveEvaluator(evaluator.Id, evaluator.Role))">Remove Evaluator</MudButton>
                                            </div>
                                        }
                                    </MudTabPage>
                                }
                            </MudTabs>
                        }

                        @if (!isReadOnlyForUser)
                        {
                            <div class="mt-4 d-flex align-center gap-4">
                                <MudSelect T="int?" Label="Select Evaluator" @bind-Value="newEvaluatorId" Variant="Variant.Outlined" Dense="true" Style="max-width: 300px">
                                    @if (employees != null)
                                    {
                                        @foreach (var emp in employees)
                                        {
                                            <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                                <MudSelect T="string" Label="Role" @bind-Value="newEvaluatorRole" Variant="Variant.Outlined" Dense="true" Style="max-width: 150px">
                                    <MudSelectItem Value="@("Self")">Self</MudSelectItem>
                                    <MudSelectItem Value="@("Manager")">Manager</MudSelectItem>
                                    <MudSelectItem Value="@("Peer")">Peer</MudSelectItem>
                                    <MudSelectItem Value="@("Subordinate")">Subordinate</MudSelectItem>
                                    <MudSelectItem Value="@("External")">External</MudSelectItem>
                                </MudSelect>
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="AddNewEvaluator">Add Evaluator</MudButton>
                            </div>
                        }
                    </MudItem>

                    <MudItem xs="12">
                        <MudExpansionPanels>
                            <MudExpansionPanel Text="Final Summary & Comments">
                                <MudGrid>
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="updateRequest.SelfRating" Label="Total Self Rating" ReadOnly="true" Variant="Variant.Outlined" />
                                    </MudItem>
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="updateRequest.ManagerRating" Label="Total Manager Rating" ReadOnly="true" Variant="Variant.Outlined" />
                                    </MudItem>
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="updateRequest.FinalRatingScore" Label="Final Score (%)" ReadOnly="true" Variant="Variant.Outlined" />
                                    </MudItem>
                                    <MudItem xs="12" sm="3">
                                        <MudCheckBox @bind-Value="isFinalizedValue" Label="Finalize & Lock?" Color="Color.Primary" ReadOnly="@isReadOnlyForUser" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="updateRequest.SelfComments" Label="Employee Overall Remarks" Lines="3" Variant="Variant.Outlined" ReadOnly="@isReadOnlyForUser" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="updateRequest.ManagerComments" Label="Appraiser Overall Remarks" Lines="3" Variant="Variant.Outlined" ReadOnly="@isReadOnlyForUser" />
                                    </MudItem>
                                    
                                    @if (updateRequest.Status == PerformanceEvaluationStatus.AwaitingCalibration || updateRequest.Status == PerformanceEvaluationStatus.Finalized || currentUserLevel <= 4)
                                    {
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="updateRequest.CalibrationComments" 
                                                          Label="Senior Management Calibration Comments" 
                                                          Lines="3" 
                                                          Variant="Variant.Outlined" 
                                                          ReadOnly="@(currentUserLevel > 4)" 
                                                          HelperText="Document rationale for score adjustments or normalization." />
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    </MudItem>

                    @if (!isReadOnlyForUser)
                    {
                        <MudItem xs="12" Class="d-flex justify-end mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Save Changes</MudButton>
                        </MudItem>
                    }
                    else
                    {
                        <MudItem xs="12" Class="d-flex justify-end mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel">Back to List</MudButton>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private MudForm? form;
    private UpdatePerformanceEvaluationRequest? updateRequest;
    private bool isFinalizedValue { get; set; } = false;
    private List<AppraisalResponseDto>? evalResponses;

    private List<EmployeeDto>? employees;
    private List<AppraisalCycleDto>? cycles;
    private List<AppraisalFormDto>? forms;
    private List<FormQuestionDto>? formQuestions;

    private EmployeeDto? selectedEmployee;
    private string? effectiveDateDisplay;

    private int? newEvaluatorId;
    private string newEvaluatorRole = "Peer";

    private int currentUserLevel = 99;
    private int currentEmployeeId = 0;
    private bool isReadOnlyForUser = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get current user info
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var empIdClaim = user.FindFirst("EmployeeId")?.Value;
            
            employees = await EmployeeService.GetEmployeesAsync();
            
            if (int.TryParse(empIdClaim, out int empId))
            {
                currentEmployeeId = empId;
                var currentEmp = employees.FirstOrDefault(e => e.EmployeeId == empId);
                currentUserLevel = ParseLevel(currentEmp?.LevelId);
            }

            var cyclesEnumerable = await CycleService.GetAllAppraisalCyclesAsync();
            cycles = cyclesEnumerable.ToList();
            var formsEnumerable = await FormService.GetAllAppraisalFormsAsync();
            forms = formsEnumerable.ToList();

            var eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
            if (eval != null)
            {
                updateRequest = new UpdatePerformanceEvaluationRequest
                {
                    EmployeeId = eval.EmployeeId,
                    CycleId = eval.CycleId,
                    FormId = eval.FormId,
                    Status = eval.Status,
                    SelfRating = eval.SelfRating,
                    ManagerRating = eval.ManagerRating,
                    SelfComments = eval.SelfComments,
                    ManagerComments = eval.ManagerComments,
                    CalibrationComments = eval.CalibrationComments,
                    FinalRatingScore = eval.FinalRatingScore,
                    IsFinalized = eval.IsFinalized,
                    FinalizedAt = eval.FinalizedAt
                };
                isFinalizedValue = eval.IsFinalized ?? false;
                evalResponses = eval.Responses;

                // Set initial lookup values
                selectedEmployee = employees?.FirstOrDefault(e => e.EmployeeId == eval.EmployeeId);
                var cycle = cycles?.FirstOrDefault(c => c.CycleId == eval.CycleId);
                effectiveDateDisplay = cycle?.EndDate.ToString("yyyy-MM-dd") ?? "N/A";
                
                // Determine Read-Only state
                // 1. Finalized is read-only for everyone except maybe Re-open logic (handled in Details)
                if (eval.Status == PerformanceEvaluationStatus.Finalized)
                {
                    isReadOnlyForUser = true;
                }
                // 2. Awaiting Calibration is read-only for Managers (L05-L19) but editable for Senior Managers (L02-L04)
                else if (eval.Status == PerformanceEvaluationStatus.AwaitingCalibration && currentUserLevel > 4)
                {
                    isReadOnlyForUser = true;
                }
                // 3. Self-Submitted is read-only for the Subject
                else if (eval.Status == PerformanceEvaluationStatus.SelfSubmitted && eval.EmployeeId == currentEmployeeId)
                {
                    isReadOnlyForUser = true;
                }

                // Load form questions for reference
                var questions = await FormQuestionService.GetByFormIdAsync(eval.FormId);
                formQuestions = questions.OrderBy(q => q.Category).ThenBy(q => q.SortOrder).ToList();
            }
            else
            {
                Snackbar.Add("Performance evaluation not found.", Severity.Error);
                NavigationManager.NavigateTo("/performanceevaluations");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance evaluation: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/performanceevaluations");
        }
    }

    private IEnumerable<(int Id, string Role, string Name)> GetUniqueEvaluators()
    {
        if (evalResponses == null) return Enumerable.Empty<(int, string, string)>();

        return evalResponses
            .Where(r => r.RespondentId.HasValue)
            .Select(r => (r.RespondentId!.Value, r.RespondentRole ?? "Unknown", r.RespondentName ?? "Unknown"))
            .Distinct();
    }

    private IEnumerable<AppraisalResponseDto> GetResponsesForEvaluator(int id, string role)
    {
        return evalResponses?.Where(r => r.RespondentId == id && r.RespondentRole == role) ?? Enumerable.Empty<AppraisalResponseDto>();
    }

    private void OnEmployeeChanged(int? empId)
    {
        if (updateRequest != null)
        {
            updateRequest.EmployeeId = empId;
            selectedEmployee = employees?.FirstOrDefault(e => e.EmployeeId == empId);
        }
    }

    private void OnCycleChanged(int? cycleId)
    {
        if (updateRequest != null)
        {
            updateRequest.CycleId = cycleId;
            var cycle = cycles?.FirstOrDefault(c => c.CycleId == cycleId);
            effectiveDateDisplay = cycle?.EndDate.ToString("yyyy-MM-dd") ?? "N/A";
        }
    }

    private int ParseLevel(string? levelId)
    {
        if (string.IsNullOrEmpty(levelId)) return 99;
        var numericPart = new string(levelId.Where(char.IsDigit).ToArray());
        return int.TryParse(numericPart, out int level) ? level : 99;
    }

    private void AddNewEvaluator()
    {
        if (newEvaluatorId.HasValue)
        {
            var targetEmp = employees?.FirstOrDefault(e => e.EmployeeId == newEvaluatorId);
            if (targetEmp == null) return;

            var targetLevel = ParseLevel(targetEmp.LevelId);

            // Validation based on requirements
            if (newEvaluatorRole == "External" && targetLevel != 3)
            {
                Snackbar.Add("Only Level 03 employees can be added as External Consultants.", Severity.Warning);
                return;
            }

            AddEvaluatorFeedback(newEvaluatorId.Value, newEvaluatorRole);
            newEvaluatorId = null;
        }
        else
        {
            Snackbar.Add("Please select an employee to add as evaluator.", Severity.Warning);
        }
    }

    private void AddEvaluatorFeedback(int employeeId, string role)
    {
        if (evalResponses == null) evalResponses = new List<AppraisalResponseDto>();
        if (formQuestions == null) return;

        // Check if already added
        if (evalResponses.Any(r => r.RespondentId == employeeId && r.RespondentRole == role))
        {
            Snackbar.Add("This evaluator with this role is already added.", Severity.Info);
            return;
        }

        var evaluator = employees?.FirstOrDefault(e => e.EmployeeId == employeeId);
        foreach (var q in formQuestions)
        {
            evalResponses.Add(new AppraisalResponseDto
            {
                ResponseId = 0, // Mark as new
                EvalId = Id,
                QuestionId = q.QuestionId,
                QuestionText = q.QuestionText,
                QuestionCategory = q.Category,
                SortOrder = q.SortOrder,
                RespondentId = employeeId,
                RespondentName = evaluator?.FullName ?? "Unknown",
                RespondentRole = role,
                RatingValue = 0
            });
        }
    }

    private void RemoveEvaluator(int employeeId, string role)
    {
        evalResponses?.RemoveAll(r => r.RespondentId == employeeId && r.RespondentRole == role);
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null && form != null)
        {
            await form.Validate();
            if (form.IsValid)
            {
                updateRequest.IsFinalized = isFinalizedValue;
                if (isFinalizedValue && updateRequest.FinalizedAt == null)
                {
                    updateRequest.FinalizedAt = DateTime.Now;
                    updateRequest.Status = PerformanceEvaluationStatus.Finalized;
                }

                // Map updated ratings back to the request
                updateRequest.Responses = evalResponses?.Select(r => new UpdateAppraisalResponseRequest
                {
                    ResponseId = r.ResponseId,
                    EvalId = Id,
                    QuestionId = r.QuestionId,
                    RespondentId = r.RespondentId,
                    RespondentRole = r.RespondentRole,
                    RatingValue = r.RatingValue,
                    AnswerText = r.AnswerText
                }).ToList();

                try
                {
                    await PerformanceEvaluationService.UpdatePerformanceEvaluationAsync(Id, updateRequest);
                    Snackbar.Add("Performance evaluation updated successfully.", Severity.Success);
                    NavigationManager.NavigateTo("/performanceevaluations");
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error updating performance evaluation: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performanceevaluations");
}
