@page "/performanceevaluations/edit/{Id:int}"
@using EPMS.Shared.Requests
@using EPMS.Domain.Enums
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IEmployeeBlazorService EmployeeService
@inject IAppraisalCycleBlazorService CycleService
@inject IAppraisalFormBlazorService FormService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-4">Edit Performance Evaluation</MudText>
        <MudDivider Class="mb-6" />

        @if (updateRequest == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudForm Model="@updateRequest" @ref="@form" ValidationDelay="0">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Employee" @bind-Value="updateRequest.EmployeeId" Required="true" Variant="Variant.Outlined">
                            @if (employees != null)
                            {
                                @foreach (var emp in employees)
                                {
                                    <MudSelectItem T="int?" Value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Label="Appraisal Cycle" @bind-Value="updateRequest.CycleId" Required="true" Variant="Variant.Outlined">
                            @if (cycles != null)
                            {
                                @foreach (var cycle in cycles)
                                {
                                    <MudSelectItem T="int?" Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int" Label="Appraisal Form" @bind-Value="updateRequest.FormId" Required="true" Variant="Variant.Outlined">
                            @if (forms != null)
                            {
                                @foreach (var formItem in forms)
                                {
                                    <MudSelectItem T="int" Value="@formItem.FormId">@formItem.FormName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="PerformanceEvaluationStatus?" Label="Status" @bind-Value="updateRequest.Status" Variant="Variant.Outlined">
                            @foreach (PerformanceEvaluationStatus status in Enum.GetValues(typeof(PerformanceEvaluationStatus)))
                            {
                                <MudSelectItem T="PerformanceEvaluationStatus?" Value="@status">@status</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Self Rating" @bind-Value="updateRequest.SelfRating" Variant="Variant.Outlined" Min="0" Max="5" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Manager Rating" @bind-Value="updateRequest.ManagerRating" Variant="Variant.Outlined" Min="0" Max="5" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Self Comments" @bind-Value="updateRequest.SelfComments" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Manager Comments" @bind-Value="updateRequest.ManagerComments" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Final Rating Score" @bind-Value="updateRequest.FinalRatingScore" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                        <MudCheckBox T="bool" @bind-Value="isFinalizedValue" Label="Is Finalized" Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="12" Class="mt-6">
                        <MudText Typo="Typo.h5" Class="mb-4">Evaluation Feedback (360 Feedback)</MudText>
                        @if (evalResponses != null && evalResponses.Any())
                        {
                            <MudTable Items="@evalResponses" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="border">
                                <HeaderContent>
                                    <MudTh>Evaluator</MudTh>
                                    <MudTh>Role</MudTh>
                                    <MudTh>Question</MudTh>
                                    <MudTh>Rating</MudTh>
                                    <MudTh>Comments</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="response">
                                    <MudTd DataLabel="Evaluator">@response.RespondentName</MudTd>
                                    <MudTd DataLabel="Role">@response.RespondentRole</MudTd>
                                    <MudTd DataLabel="Question">@response.QuestionText</MudTd>
                                    <MudTd DataLabel="Rating">
                                        <MudRating SelectedValue="@(response.RatingValue ?? 0)" ReadOnly="true" MaxValue="5" />
                                    </MudTd>
                                    <MudTd DataLabel="Comments">@response.AnswerText</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">No feedback responses recorded for this evaluation.</MudAlert>
                        }
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-end mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Save Changes</MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private MudForm? form;
    private UpdatePerformanceEvaluationRequest? updateRequest;
    private bool isFinalizedValue { get; set; }
    private List<AppraisalResponseDto>? evalResponses;

    private List<EmployeeDto>? employees;
    private List<AppraisalCycleDto>? cycles;
    private List<AppraisalFormDto>? forms;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await EmployeeService.GetEmployeesAsync();
            var cyclesEnumerable = await CycleService.GetAllAppraisalCyclesAsync();
            cycles = cyclesEnumerable.ToList();
            var formsEnumerable = await FormService.GetAllAppraisalFormsAsync();
            forms = formsEnumerable.ToList();

            var eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
            if (eval != null)
            {
                updateRequest = new UpdatePerformanceEvaluationRequest
                {
                    EmployeeId = eval.EmployeeId,
                    CycleId = eval.CycleId,
                    FormId = eval.FormId,
                    Status = eval.Status,
                    SelfRating = eval.SelfRating,
                    ManagerRating = eval.ManagerRating,
                    SelfComments = eval.SelfComments,
                    ManagerComments = eval.ManagerComments,
                    FinalRatingScore = eval.FinalRatingScore,
                    IsFinalized = eval.IsFinalized,
                    FinalizedAt = eval.FinalizedAt
                };
                isFinalizedValue = eval.IsFinalized ?? false;
                evalResponses = eval.Responses;
            }
            else
            {
                Snackbar.Add("Performance evaluation not found.", Severity.Error);
                NavigationManager.NavigateTo("/performanceevaluations");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading performance evaluation: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/performanceevaluations");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null && form != null)
        {
            await form.Validate();
            if (form.IsValid)
            {
                updateRequest.IsFinalized = isFinalizedValue;
                if (isFinalizedValue && updateRequest.FinalizedAt == null)
                {
                    updateRequest.FinalizedAt = DateTime.Now;
                }
                try
                {
                    await PerformanceEvaluationService.UpdatePerformanceEvaluationAsync(Id, updateRequest);
                    Snackbar.Add("Performance evaluation updated successfully.", Severity.Success);
                    NavigationManager.NavigateTo("/performanceevaluations");
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error updating performance evaluation: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/performanceevaluations");
}
