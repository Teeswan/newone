@page "/positions"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Positions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700; color: #111827;">
    <MudIcon Icon="@Icons.Material.Filled.Work" Class="mr-2 mb-n1" Color="Color.Primary" />
    Position Management
</MudText>

<MudCard Elevation="2" Class="mb-4" Style="border-radius: 16px;">
    <MudCardContent Class="pa-6">
        @* Statistics Cards with beautiful gradients *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(positions?.Count() ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Total Positions</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #059669 0%, #10B981 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(positions?.Count(p => !string.IsNullOrEmpty(p.LevelName)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">With Level</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%);">
                    <div class="d-flex align-center">
                        <div class="mr-4" Style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Large" Style="color: white;" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h3" Class="fw-bold" Style="color: white;">@(positions?.Count(p => string.IsNullOrEmpty(p.LevelName)) ?? 0)</MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-weight: 500;">Without Level</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Toolbar with improved styling *@
        <MudPaper Elevation="0" Class="pa-4 mb-6" Style="background: #F9FAFB; border-radius: 12px;">
            <div class="d-flex flex-wrap justify-space-between align-center gap-4">
                <MudTextField @bind-Value="searchString" Placeholder="Search positions by title or level..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Style="min-width: 280px;"
                              Variant="Variant.Outlined" Clearable="true" />

                <div class="d-flex gap-3">
                    <MudTooltip Text="Refresh position list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshPositions"
                                   Class="rounded-lg">
                            Refresh
                        </MudButton>
                    </MudTooltip>

                    <MudTooltip Text="Add a new position" Arrow="true">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="NavigateToCreate"
                                   Class="rounded-lg"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Create New
                        </MudButton>
                    </MudTooltip>
                </div>
            </div>
        </MudPaper>

        @if (positions == null)
        {
            <div class="d-flex flex-column justify-center my-20 align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading positions...</MudText>
            </div>
        }
        else if (!FilteredPositions.Any())
        {
            <div class="text-center py-16">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Info" Class="mb-6" />
                <MudText Typo="Typo.h5" Class="fw-bold mb-3" Style="color: #374151;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "No positions found" : "No positions match your search")
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-8" Style="color: #6B7280;">
                    @(string.IsNullOrWhiteSpace(searchString) ? "Get started by creating your first position!" : "Try adjusting your search criteria.")
                </MudText>
                @if (string.IsNullOrWhiteSpace(searchString))
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToCreate" 
                               StartIcon="@Icons.Material.Filled.Add" Size="Size.Large"
                               Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 8px;">
                        Create First Position
                    </MudButton>
                }
            </div>
        }
        else
        {
            <MudTable Items="@FilteredPositions" T="PositionDto" Hover="true" Breakpoint="Breakpoint.Sm"
                      Elevation="1"
                      Class="rounded-xl">
                <HeaderContent>
                    <MudTh Style="font-weight: 700; color: #374151;">Position ID</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Title</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151;">Level</MudTh>
                    <MudTh Style="font-weight: 700; color: #374151; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Position ID">
                        <MudChip T="int" Size="Size.Medium" Color="Color.Primary">@context.PositionId</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Title">
                        <div class="d-flex align-center">
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-3">
                                @context.PositionTitle[0]
                            </MudAvatar>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@context.PositionTitle</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Level">
                        @if (!string.IsNullOrEmpty(context.LevelName))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@context.LevelName</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color: #6B7280;">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="View position details" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info"
                                           Size="Size.Small" OnClick="@(() => NavigateToDetails(context.PositionId))" />
                        </MudTooltip>

                        <MudTooltip Text="Edit position" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning"
                                           Size="Size.Small" OnClick="@(() => NavigateToEdit(context.PositionId))" />
                        </MudTooltip>

                        <MudTooltip Text="Delete position" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="@(() => DeletePosition(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private IEnumerable<PositionDto>? positions;
    private string searchString = "";

    private IEnumerable<PositionDto>? FilteredPositions
    {
        get
        {
            if (positions == null) return null;
            if (string.IsNullOrWhiteSpace(searchString)) return positions;

            return positions.Where(p =>
                p.PositionTitle.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrEmpty(p.LevelName) && p.LevelName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            );
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPositions();
    }

    private async Task LoadPositions()
    {
        try
        {
            positions = await PositionService.GetAllPositionsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading positions: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            positions = new List<PositionDto>();
        }
    }

    private async Task RefreshPositions()
    {
        await LoadPositions();
        Snackbar.Add("Position list refreshed!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/positions/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/positions/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/positions/edit/{id}");
    }

    private async Task DeletePosition(PositionDto position)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this position?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await PositionService.DeletePositionAsync(position.PositionId);
                if (success)
                {
                    Snackbar.Add("Position deleted successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadPositions();
                }
                else
                {
                    Snackbar.Add("Error deleting position.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting position: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }
}
