@page "/positions"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Positions</PageTitle>

<MudContainer>
    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudItem>
            <MudText Typo="Typo.h4" Class="mb-0">Positions</MudText>
        </MudItem>
        <MudItem>
            <MudButton Color="Color.Primary" OnClick="NavigateToCreate" StartIcon="@Icons.Material.Filled.Add">
                Create New
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="pa-4">
        @if (positions == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!positions.Any())
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                No positions found. Create your first position!
            </MudAlert>
        }
        else
        {
            <MudTable Items="@positions" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Position ID</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Level</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Position ID">@context.PositionId</MudTd>
                    <MudTd DataLabel="Title">@context.PositionTitle</MudTd>
                    <MudTd DataLabel="Level">@context.LevelName ?? "None"</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                            <MudButton Color="Color.Info" OnClick="() => NavigateToDetails(context.PositionId)" StartIcon="@Icons.Material.Filled.Visibility">View</MudButton>
                            <MudButton Color="Color.Warning" OnClick="() => NavigateToEdit(context.PositionId)" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                            <MudButton Color="Color.Error" OnClick="() => DeletePosition(context)" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                        </MudButtonGroup>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<PositionDto>? positions;

    protected override async Task OnInitializedAsync()
    {
        await LoadPositions();
    }

    private async Task LoadPositions()
    {
        try
        {
            positions = await PositionService.GetAllPositionsAsync();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading positions: {ex.Message}", Severity.Error);
            positions = new List<PositionDto>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/positions/create");
    }

    private void NavigateToDetails(int id)
    {
        NavigationManager.NavigateTo($"/positions/details/{id}");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/positions/edit/{id}");
    }

    private async Task DeletePosition(PositionDto position)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this position?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await PositionService.DeletePositionAsync(position.PositionId);
                if (success)
                {
                    Snackbar.Add("Position deleted successfully!", Severity.Success);
                    await LoadPositions();
                }
                else
                {
                    Snackbar.Add("Error deleting position.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting position: {ex.Message}", Severity.Error);
            }
        }
    }
}
