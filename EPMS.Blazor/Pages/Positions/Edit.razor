@page "/positions/edit/{id:int}"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Position</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Edit Position</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Update position information</MudText>
                </div>
            </div>
            <MudDivider Class="mb-8" />

            @if (isLoading)
            {
                <div class="d-flex flex-column justify-center my-16 align-center">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-6" Style="font-weight: 500; color: #6B7280;">Loading position...</MudText>
                </div>
            }
            else if (positionModel == null)
            {
                <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline">
                    Position not found.
                </MudAlert>
            }
            else
            {
                <EditForm Model="positionModel" OnValidSubmit="HandleUpdate">
                    <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%); border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Color="Color.Warning" />
                            Update Position Details
                        </MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12">
                                <MudTextField 
                                    T="int"
                                    Label="Position ID" 
                                    @bind-Value="positionId"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Disabled="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Badge"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField 
                                    T="string"
                                    Label="Position Title" 
                                    @bind-Value="positionModel.PositionTitle"
                                    Placeholder="Enter position title"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Required="true"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Work"
                                    Class="rounded-lg" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect 
                                    T="string"
                                    Label="Level" 
                                    @bind-Value="positionModel.LevelId"
                                    Placeholder="Select level (optional)"
                                    Variant="Variant.Outlined"
                                    Style="width: 100%"
                                    Clearable="true"
                                    Immediate="true"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Grade"
                                    Class="rounded-lg">
                                    <MudSelectItem T="string" Value="@((string?)null)">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Class="mr-2" Color="Color.Warning" />
                                        None (No Level)
                                    </MudSelectItem>
                                    @if (levels != null)
                                    {
                                        @foreach (var level in levels)
                                        {
                                            <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <div class="d-flex justify-end gap-3 pt-4">
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" 
                                       StartIcon="@Icons.Material.Filled.Close"
                                       Class="rounded-lg px-6">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save changes to this position" Arrow="true">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" 
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Class="rounded-lg px-8"
                                       Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                                Save Changes
                            </MudButton>
                        </MudTooltip>
                    </div>
                </EditForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private int positionId;
    private UpdatePositionRequest? positionModel;
    private IEnumerable<LevelDto>? levels;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            var positionTask = PositionService.GetPositionByIdAsync(Id);
            var levelsTask = LevelService.GetAllLevelsAsync();

            await Task.WhenAll(positionTask, levelsTask);

            var position = await positionTask;
            levels = await levelsTask;

            if (position != null)
            {
                positionId = position.PositionId;
                positionModel = new UpdatePositionRequest
                {
                    PositionTitle = position.PositionTitle,
                    LevelId = position.LevelId
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (positionModel == null) return;

        try
        {
            await PositionService.UpdatePositionAsync(Id, positionModel);
            Snackbar.Add("Position updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating position: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/positions");
    }
}
