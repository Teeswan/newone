@page "/positions/edit/{id:int}"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Position</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Warning" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Edit Position</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">Update position information</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        @if (isLoading)
        {
            <div class="d-flex flex-column justify-center my-10 align-center">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="mt-4 text-grey">Loading position...</MudText>
            </div>
        }
        else if (positionModel == null)
        {
            <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline">
                Position not found.
            </MudAlert>
        }
        else
        {
            <EditForm Model="positionModel" OnValidSubmit="HandleUpdate">
                <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                    <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-warning">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                        Update Position Details
                    </MudText>
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField 
                                T="int"
                                Label="Position ID" 
                                @bind-Value="positionId"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Disabled="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Badge" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Position Title" 
                                @bind-Value="positionModel.PositionTitle"
                                Placeholder="Enter position title"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Required="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Work" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect 
                                T="string"
                                Label="Level" 
                                @bind-Value="positionModel.LevelId"
                                Placeholder="Select level (optional)"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Class="mb-4"
                                Clearable="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Grade">
                                @if (levels != null)
                                {
                                    @foreach (var level in levels)
                                    {
                                        <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudGrid>
                    <MudItem xs="12" Class="pt-4">
                        <MudButtonGroup>
                            <MudTooltip Text="Cancel and go back to list" Arrow="true">
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.Close">
                                    Cancel
                                </MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Save changes to this position" Arrow="true">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Save">
                                    Save Changes
                                </MudButton>
                            </MudTooltip>
                        </MudButtonGroup>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private int positionId;
    private UpdatePositionRequest? positionModel;
    private IEnumerable<LevelDto>? levels;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            var positionTask = PositionService.GetPositionByIdAsync(Id);
            var levelsTask = LevelService.GetAllLevelsAsync();

            await Task.WhenAll(positionTask, levelsTask);

            var position = await positionTask;
            levels = await levelsTask;

            if (position != null)
            {
                positionId = position.PositionId;
                positionModel = new UpdatePositionRequest
                {
                    PositionTitle = position.PositionTitle,
                    LevelId = position.LevelId
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (positionModel == null) return;

        try
        {
            await PositionService.UpdatePositionAsync(Id, positionModel);
            Snackbar.Add("Position updated successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating position: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/positions");
    }
}
