@page "/positions/create"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Position</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="2" Style="border-radius: 16px;">
        <MudCardContent Class="pa-8">
            <div class="d-flex align-center mb-6">
                <div Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); border-radius: 16px; padding: 16px; margin-right: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Size="Size.Large" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold mb-0" Style="color: #111827;">Create Position</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6B7280;">Add a new position to your organization</MudText>
                </div>
            </div>
            <MudDivider Class="mb-8" />

            <EditForm Model="positionModel" OnValidSubmit="HandleCreate">
                <MudPaper Elevation="0" Class="pa-6 mb-6" Style="background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%); border-radius: 12px;">
                    <MudText Typo="Typo.h6" Class="mb-5" Style="font-weight: 600; color: #111827;">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" Color="Color.Primary" />
                        Position Information
                    </MudText>
                    <MudGrid Spacing="4">
                        <MudItem xs="12">
                            <MudTextField 
                                T="string"
                                Label="Position Title" 
                                @bind-Value="positionModel.PositionTitle"
                                Placeholder="Enter position title"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Required="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Work"
                                Class="rounded-lg" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect 
                                T="string"
                                Label="Level" 
                                @bind-Value="positionModel.LevelId"
                                Placeholder="Select level (optional)"
                                Variant="Variant.Outlined"
                                Style="width: 100%"
                                Clearable="true"
                                Immediate="true"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Grade"
                                Class="rounded-lg">
                                <MudSelectItem T="string" Value="@((string?)null)">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Class="mr-2" Color="Color.Warning" />
                                    None (No Level)
                                </MudSelectItem>
                                @if (levels != null)
                                {
                                    @foreach (var level in levels)
                                    {
                                        <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <div class="d-flex justify-end gap-3 pt-4">
                    <MudTooltip Text="Cancel and go back to list" Arrow="true">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" 
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Class="rounded-lg px-6">
                            Cancel
                        </MudButton>
                    </MudTooltip>
                    <MudTooltip Text="Save and create this position" Arrow="true">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" 
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Class="rounded-lg px-8"
                                   Style="background: linear-gradient(135deg, #1A56DB 0%, #3B82F6 100%); font-weight: 600;">
                            Create Position
                        </MudButton>
                    </MudTooltip>
                </div>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private CreatePositionRequest positionModel = new();
    private IEnumerable<LevelDto>? levels;

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        try
        {
            levels = await LevelService.GetAllLevelsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading levels: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task HandleCreate()
    {
        try
        {
            await PositionService.CreatePositionAsync(positionModel);
            Snackbar.Add("Position created successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating position: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/positions");
    }
}
