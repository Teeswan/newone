@page "/positions/create"
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.ILevelBlazorService LevelService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Position</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="4" Class="pa-8" Rounded="true">
        <div class="d-flex align-center mb-6">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Size="Size.Large" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold mb-0">Create Position</MudText>
                <MudText Typo="Typo.body2" Class="text-grey">Add a new position to your organization</MudText>
            </div>
        </div>
        <MudDivider Class="mb-8" />

        <EditForm Model="positionModel" OnValidSubmit="HandleCreate">
            <MudPaper Elevation="1" Class="pa-6 mb-6" Rounded="true">
                <MudText Typo="Typo.h6" Class="mb-4 fw-bold text-primary">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                    Position Information
                </MudText>
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField 
                            T="string"
                            Label="Position Title" 
                            @bind-Value="positionModel.PositionTitle"
                            Placeholder="Enter position title"
                            Variant="Variant.Outlined"
                            Style="width: 100%"
                            Class="mb-4"
                            Required="true"
                            Immediate="true"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Work" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect 
                            T="string"
                            Label="Level" 
                            @bind-Value="positionModel.LevelId"
                            Placeholder="Select level (optional)"
                            Variant="Variant.Outlined"
                            Style="width: 100%"
                            Class="mb-4"
                            Clearable="true"
                            Immediate="true"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Grade">
                            @if (levels != null)
                            {
                                @foreach (var level in levels)
                                {
                                    <MudSelectItem T="string" Value="@level.LevelId">@level.LevelName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid>
                <MudItem xs="12" Class="pt-4">
                    <MudButtonGroup>
                        <MudTooltip Text="Cancel and go back to list" Arrow="true">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.Close">
                                Cancel
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Save and create this position" Arrow="true">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Save">
                                Create Position
                            </MudButton>
                        </MudTooltip>
                    </MudButtonGroup>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CreatePositionRequest positionModel = new();
    private IEnumerable<LevelDto>? levels;

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        try
        {
            levels = await LevelService.GetAllLevelsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading levels: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private async Task HandleCreate()
    {
        try
        {
            await PositionService.CreatePositionAsync(positionModel);
            Snackbar.Add("Position created successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
            NavigateBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating position: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/positions");
    }
}
