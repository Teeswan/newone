@page "/positions/details/{id:int}"
@using System.Net.Http.Json
@inject EPMS.Blazor.Services.IPositionBlazorService PositionService
@inject EPMS.Blazor.Services.IPermissionBlazorService PermissionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient Http

<PageTitle>Position Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="d-flex align-center mb-4">
        <MudTooltip Text="Go back to positions list" Arrow="true">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Class="mr-2" />
        </MudTooltip>
        <MudText Typo="Typo.h5" Style="font-weight: bold; color: #1A56DB;">Position Details</MudText>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column justify-center my-10 align-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1" Class="mt-4 text-grey">Loading position details...</MudText>
        </div>
    }
    else if (position == null)
    {
        <MudAlert Severity="Severity.Error" Class="ma-4" Icon="@Icons.Material.Filled.ErrorOutline">
            Position not found.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="4" Class="pa-6" Rounded="true">
                    <div class="d-flex align-center mb-6">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                            <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Large" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-bold mb-0">Position Info</MudText>
                        </div>
                    </div>
                    
                    <MudGrid>
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 mb-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Position ID</MudText>
                                <MudChip T="int" Size="Size.Medium" Color="Color.Primary">@position.PositionId</MudChip>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 mb-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Title</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@position.PositionTitle</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Class="pa-3" Elevation="0" Rounded="true">
                                <MudText Typo="Typo.subtitle2" Class="text-grey mb-1">Level</MudText>
                                @if (!string.IsNullOrEmpty(position.LevelName))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@position.LevelName</MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body1" Class="text-grey">None</MudText>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />

                    <MudGrid>
                        <MudItem xs="12">
                            <MudTooltip Text="Edit this position" Arrow="true">
                                <MudButton Color="Color.Warning" OnClick="NavigateToEdit" StartIcon="@Icons.Material.Filled.Edit" Style="width: 100%;">
                                    Edit Position
                                </MudButton>
                            </MudTooltip>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8">
                <MudPaper Elevation="4" Class="pa-6" Rounded="true">
                    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudItem>
                            <MudText Typo="Typo.h5" Class="fw-bold">Assigned Permissions</MudText>
                        </MudItem>
                        <MudItem>
                            <div class="d-flex gap-2">
                                @if (selectedPermissions.Any())
                                {
                                    <MudTooltip Text="Revoke selected permissions" Arrow="true">
                                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="BulkRevoke" StartIcon="@Icons.Material.Filled.Delete">
                                            Revoke @selectedPermissions.Count
                                        </MudButton>
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Seed default permissions" Arrow="true">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="SeedPermissions" StartIcon="@Icons.Material.Filled.Extension">
                                        Seed Permissions
                                    </MudButton>
                                </MudTooltip>
                                <MudTooltip Text="Assign new permission" Arrow="true">
                                    <MudButton Color="Color.Primary" OnClick="ShowAssignPermissionDialog" StartIcon="@Icons.Material.Filled.Add">
                                        Assign Permission
                                    </MudButton>
                                </MudTooltip>
                            </div>
                        </MudItem>
                    </MudGrid>

                    @if (assignedPermissions == null)
                    {
                        <div class="d-flex justify-center my-10">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (!assignedPermissions.Any())
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4" Icon="@Icons.Material.Filled.Info">
                            No permissions assigned yet.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="@assignedPermissions" T="PermissionDto" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0"
                                  MultiSelection="true" @bind-SelectedItems="selectedPermissions" SelectOnRowClick="false">
                            <HeaderContent>
                                <MudTh></MudTh>
                                <MudTh Style="font-weight: 600;">Permission Code</MudTh>
                                <MudTh Style="font-weight: 600;">Description</MudTh>
                                <MudTh Style="font-weight: 600; text-align: right;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd></MudTd>
                                <MudTd DataLabel="Permission Code">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.PermissionCode</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Description">@context.Description</MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <MudTooltip Text="Revoke this permission" Arrow="true">
                                        <MudIconButton 
                                            Icon="@Icons.Material.Filled.RemoveCircleOutline" 
                                            Color="Color.Error" 
                                            Size="Size.Small"
                                            OnClick="() => RevokePermission(context)" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private PositionDto? position;
    private IEnumerable<PermissionDto>? assignedPermissions;
    private IEnumerable<PermissionDto>? allPermissions;
    private bool isLoading = true;
    private HashSet<PermissionDto> selectedPermissions = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            var positionTask = PositionService.GetPositionByIdAsync(Id);
            var assignedPermissionsTask = PermissionService.GetPermissionsByPositionAsync(Id);
            
            // Directly call API for all permissions to debug
            var response = await Http.GetAsync("api/Permissions");
            
            if (response.IsSuccessStatusCode)
            {
                allPermissions = await response.Content.ReadFromJsonAsync<IEnumerable<PermissionDto>>() ?? new List<PermissionDto>();
            }
            else
            {
                allPermissions = new List<PermissionDto>();
            }

            await Task.WhenAll(positionTask, assignedPermissionsTask);

            position = await positionTask;
            assignedPermissions = await assignedPermissionsTask;
            selectedPermissions.Clear();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowAssignPermissionDialog()
    {
        if (allPermissions == null || assignedPermissions == null) return;

        var availablePermissions = allPermissions
            .Where(p => !assignedPermissions.Any(ap => ap.PermissionId == p.PermissionId))
            .ToList();

        if (!availablePermissions.Any())
        {
            Snackbar.Add("All permissions are already assigned.", Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            { "AvailablePermissions", availablePermissions },
            { "PositionId", Id }
        };

        var dialog = DialogService.Show<AssignPermissionDialog>("Assign Permission", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task RevokePermission(PermissionDto permission)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to revoke permission '{permission.PermissionCode}'?" },
            { "ButtonText", "Revoke" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Revoke Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var request = new RevokePermissionRequest
                {
                    PositionId = Id,
                    PermissionId = permission.PermissionId
                };

                var success = await PermissionService.RevokePermissionAsync(request);
                if (success)
                {
                    Snackbar.Add("Permission revoked successfully!", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadData();
                }
                else
                {
                    Snackbar.Add("Error revoking permission.", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error revoking permission: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task BulkRevoke()
    {
        if (!selectedPermissions.Any()) return;

        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to revoke {selectedPermissions.Count} permission(s)?" },
            { "ButtonText", "Revoke All" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<MessageBox>("Bulk Revoke Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                int revokedCount = 0;
                foreach (var perm in selectedPermissions)
                {
                    var request = new RevokePermissionRequest
                    {
                        PositionId = Id,
                        PermissionId = perm.PermissionId
                    };

                    var success = await PermissionService.RevokePermissionAsync(request);
                    if (success)
                    {
                        revokedCount++;
                    }
                }

                if (revokedCount > 0)
                {
                    Snackbar.Add($"{revokedCount} permission(s) revoked successfully!", Severity.Success, 
                        config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                    await LoadData();
                }
                else
                {
                    Snackbar.Add("No permissions were revoked.", Severity.Warning, 
                        config => { config.Icon = Icons.Material.Filled.Warning; });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error revoking permissions: {ex.Message}", Severity.Error, 
                    config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
    }

    private async Task SeedPermissions()
    {
        try
        {
            Snackbar.Add("Seeding permissions... Please wait...", Severity.Info, config => { config.Icon = Icons.Material.Filled.Extension; });
            
            var response = await Http.PostAsync("api/Permissions/seed", null);
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Permissions seeded successfully! {content}", Severity.Success, config => { config.Icon = Icons.Material.Filled.CheckCircle; });
                await LoadData();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error seeding: {content}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error seeding: {ex.Message}", Severity.Error, config => { config.Icon = Icons.Material.Filled.ErrorOutline; });
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/positions");
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/positions/edit/{Id}");
    }
}
