@page "/change-password"
@using MudBlazor
@using Blazored.LocalStorage
@using EPMS.Blazor.Services
@using System.ComponentModel.DataAnnotations
@inject IAuthBlazorService AuthService
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager

<PageTitle>Change Password</PageTitle>

<MudCard Class="max-w-md mx-auto mt-8">
    <MudCardContent>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">Change Your Password</MudText>
                <MudText Typo="Typo.body2" Class="text-muted">Please set a new password for your account</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        @if (employeeId == null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">No employee found! Please login again!</MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">Changing password for Employee ID: @employeeId</MudAlert>
        }

        <EditForm EditContext="@editContext">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudTextField @bind-Value="model.NewPassword"
                          For="@(() => model.NewPassword)"
                          Label="New Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          InputType="InputType.Password" />

            <MudTextField @bind-Value="model.ConfirmPassword"
                          For="@(() => model.ConfirmPassword)"
                          Label="Confirm Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          InputType="InputType.Password" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(isLoading || employeeId == null)"
                       FullWidth="true"
                       Class="mt-4"
                       OnClick="HandleChangePassword">
                @if (isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Changing Password...</MudText>
                }
                else
                {
                    <MudText>Change Password</MudText>
                }
            </MudButton>
        </EditForm>
    </MudCardContent>
</MudCard>

@code {
    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "New Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm Password is required")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private ChangePasswordModel model = new();
    private EditContext? editContext;
    private bool isLoading = false;
    private int? employeeId;

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
    }

    protected override async Task OnInitializedAsync()
    {
        var loginResponse = await LocalStorage.GetItemAsync<LoginResponseDto>("loginResponse");
        employeeId = loginResponse?.EmployeeId;

        if (employeeId == null)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task HandleChangePassword()
    {
        // 1. Manual Validation Check
        if (editContext == null || !editContext.Validate())
        {
            Snackbar.Add("Please fix the validation errors", Severity.Warning);
            return;
        }

        if (employeeId == null) return;

        isLoading = true;
        try
        {
            var result = await AuthService.ChangePasswordAsync(employeeId.Value, model.NewPassword);
            
            if (result)
            {
                Snackbar.Add("Password changed successfully!", Severity.Success);
                await LocalStorage.RemoveItemAsync("loginResponse");
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add("Failed to change password", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}