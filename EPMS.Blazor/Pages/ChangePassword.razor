@page "/change-password"
@using MudBlazor
@using Blazored.LocalStorage
@using EPMS.Blazor.Services
@inject IAuthBlazorService AuthService
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager

<PageTitle>Change Password</PageTitle>

<MudCard Class="max-w-md mx-auto mt-8">
    <MudCardContent>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">Change Your Password</MudText>
                <MudText Typo="Typo.body2" Class="text-muted">Please set a new password for your account</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <EditForm Model="@model" OnValidSubmit="HandleValidSubmit" Class="mt-4">
            <DataAnnotationsValidator />
            <MudTextField 
                @bind-Value="model.NewPassword"
                Label="New Password"
                Type="InputType.Password"
                Variant="Variant.Outlined"
                Class="mb-4"
                Adornment="Adornment.End"
                AdornmentIcon="@(showNewPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                OnAdornmentClick="() => showNewPassword = !showNewPassword"
                InputType="showNewPassword ? InputType.Text : InputType.Password"
                Required="true" />

            <MudTextField 
                @bind-Value="model.ConfirmPassword"
                Label="Confirm Password"
                Type="InputType.Password"
                Variant="Variant.Outlined"
                Class="mb-4"
                Adornment="Adornment.End"
                AdornmentIcon="@(showConfirmPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                OnAdornmentClick="() => showConfirmPassword = !showConfirmPassword"
                InputType="showConfirmPassword ? InputType.Text : InputType.Password"
                Required="true" />

            <MudButton 
                Type="ButtonType.Submit"
                Variant="Variant.Filled" 
                Color="Color.Primary"
                Disabled="isLoading"
                FullWidth="true"
                Class="mt-4">
                @if (isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Changing Password...</MudText>
                }
                else
                {
                    <MudText>Change Password</MudText>
                }
            </MudButton>
        </EditForm>
    </MudCardContent>
</MudCard>

@code {
    public class ChangePasswordModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private ChangePasswordModel model = new();
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;
    private bool isLoading = false;
    private int? employeeId;

    protected override async Task OnInitializedAsync()
    {
        var loginResponse = await LocalStorage.GetItemAsync<LoginResponseDto>("loginResponse");
        employeeId = loginResponse?.EmployeeId;
        
        if (employeeId == null)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (model.NewPassword != model.ConfirmPassword)
        {
            Snackbar.Add("Passwords do not match", Severity.Warning);
            return;
        }

        if (model.NewPassword.Length < 6)
        {
            Snackbar.Add("Password must be at least 6 characters", Severity.Warning);
            return;
        }

        if (employeeId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        isLoading = true;
        try
        {
            var result = await AuthService.ChangePasswordAsync(employeeId.Value, model.NewPassword);
            if (result)
            {
                Snackbar.Add("Password changed successfully! Please login again.", Severity.Success);
                await LocalStorage.RemoveItemAsync("loginResponse");
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add("Failed to change password", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
