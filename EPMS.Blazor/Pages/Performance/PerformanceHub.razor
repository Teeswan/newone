@page "/performance-hub"
@attribute [Authorize]
@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@using EPMS.Blazor.Dialogs
@using EPMS.Domain.Enums
@inject IPerformanceEvaluationBlazorService EvaluationService
@inject IPerformanceOutcomeBlazorService OutcomeService
@inject IAppraisalCycleBlazorService CycleService
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Performance Management Hub</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @* Action Needed Section *@
    @if (GetActionItems().Any())
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-6 rounded-lg shadow-md" Icon="@Icons.Material.Filled.NotificationImportant">
            <MudText Typo="Typo.h6"><b>Action Required:</b> You have @GetActionItems().Count() pending performance tasks.</MudText>
            <MudList T="PerformanceEvaluationDto" Class="mt-2" Dense="true">
                @foreach (var item in GetActionItems().Take(3))
                {
                    <MudListItem Icon="@Icons.Material.Filled.ArrowForward" OnClick="@(() => ViewEvaluation(item.EvalId))">
                        @GetActionMessage(item)
                    </MudListItem>
                }
            </MudList>
        </MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-6 rounded-lg border-2" Icon="@Icons.Material.Filled.CheckCircle">
            <MudText Typo="Typo.h6"><b>All caught up!</b> You have no pending performance tasks at this time.</MudText>
        </MudAlert>
    }

    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-6">
        @* Evaluations Tab *@
        <MudTabPanel Text="Evaluations" Icon="@Icons.Material.Filled.HistoryEdu">
            @RenderEvaluationsTable()
        </MudTabPanel>

        @* Outcomes Tab *@
        <MudTabPanel Text="Outcomes" Icon="@Icons.Material.Filled.TaskAlt">
            <div class="d-flex justify-space-between align-center mb-6">
                <MudText Typo="Typo.h5" Style="font-weight: 700;">Performance Outcomes</MudText>
                @* Outcomes are auto-created upon evaluation finalization *@
            </div>
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
                <MudTextField @bind-Value="_outcomeSearch" Placeholder="Search outcomes..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
            </MudPaper>
            <MudTable Items="_outcomes" T="PerformanceOutcomeDto" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Filter="new Func<PerformanceOutcomeDto,bool>(FilterOutcomes)" Class="rounded-lg">
                <HeaderContent>
                    <MudTh>Employee</MudTh>
                    <MudTh>Recommendation</MudTh>
                    <MudTh>Effective Date</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Employee">@context.EmployeeName</MudTd>
                    <MudTd DataLabel="Recommendation">@context.RecommendationType</MudTd>
                    <MudTd DataLabel="Effective Date">@context.EffectiveDate?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="GetOutcomeStatusColor(context.ApprovalStatus)" Variant="Variant.Filled" Size="Size.Small">
                            @context.ApprovalStatus
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        @if (context.EvalId.HasValue)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Description" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewEvaluation(context.EvalId.Value))" Title="View Finalized Form" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OpenOutcomeEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteOutcome(context.OutcomeId))" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-8 d-flex flex-column align-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Color="Color.Default" Class="mb-2" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">No performance outcomes recorded yet.</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private RenderFragment RenderEvaluationsTable(AppraisalFormType? type = null, bool hideCreate = false) => __builder => {
        <div class="d-flex justify-space-between align-center mb-6 mt-4">
            <MudText Typo="Typo.h5" Style="font-weight: 700;">@(type.HasValue ? GetTypeName(type.Value) : "Performance") Evaluations</MudText>
            <div class="d-flex gap-2">
                @if (type == null && !hideCreate)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="OpenBulkStartDialog" Class="rounded-lg px-4 py-2">
                        Bulk Start
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => NavigationManager.NavigateTo("/performanceevaluations/create"))" Class="rounded-lg px-6 py-2 shadow-lg">
                        Start Evaluation
                    </MudButton>
                }
                else if (!hideCreate)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenEvaluationAddDialog(type!.Value))" Class="rounded-lg px-6 py-2 shadow-lg">
                        New @GetTypeName(type!.Value)
                    </MudButton>
                }
            </div>
        </div>
        <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background: #F9FAFB; border-radius: 12px;">
            <MudTextField @bind-Value="_evalSearch" Placeholder="Search evaluations..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
        </MudPaper>
        <MudTable Items="GetFilteredEvaluations(type)" T="PerformanceEvaluationDto" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Filter="new Func<PerformanceEvaluationDto,bool>(FilterEvaluations)" Class="rounded-lg">
            <HeaderContent>
                <MudTh>Employee</MudTh>
                @if (type == null)
                {
                    <MudTh>Type</MudTh>
                }
                <MudTh>Cycle</MudTh>
                <MudTh>Score</MudTh>
                <MudTh>Status</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                    <MudTd DataLabel="Employee">@context.EmployeeName</MudTd>
                    @if (type == null)
                    {
                        <MudTd DataLabel="Type">@GetTypeName(context.FormType)</MudTd>
                    }
                    <MudTd DataLabel="Cycle">@context.CycleName</MudTd>
                    <MudTd DataLabel="Score">@(context.FinalRatingScore?.ToString("N2") ?? "N/A")%</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="GetEvalStatusColor(context.Status)" Variant="Variant.Filled" Size="Size.Small">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewEvaluation(context.EvalId))" Title="View Details" />
                        @if (CanEditEvaluation(context))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OpenEvaluationEditDialog(context))" Title="Edit" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteEvaluation(context.EvalId))" Title="Delete" />
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-8 d-flex flex-column align-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-2" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">No evaluations found in this category.</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
        </MudTable>
    };

    private List<PerformanceEvaluationDto> _evaluations = new();
    private List<PerformanceOutcomeDto> _outcomes = new();
    private List<EmployeeDto> _employees = new();
    private EmployeeDto? currentUserEmployee;

    private string _evalSearch = "";
    private string _outcomeSearch = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var empIdClaim = user.FindFirst("EmployeeId")?.Value;

            _employees = (await EmployeeService.GetEmployeesAsync()).ToList();
            if (int.TryParse(empIdClaim, out int empId))
            {
                currentUserEmployee = _employees.FirstOrDefault(e => e.EmployeeId == empId);
            }

            var evalTask = EvaluationService.GetAllPerformanceEvaluationsAsync();
            var outcomeTask = OutcomeService.GetAllPerformanceOutcomesAsync();

            await Task.WhenAll(evalTask, outcomeTask);

            _evaluations = (await evalTask).ToList();
            _outcomes = (await outcomeTask).ToList();
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenBulkStartDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<BulkEvaluationDialog>("Bulk Start Evaluations", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadAllData();
        }
    }

    private IEnumerable<PerformanceEvaluationDto> GetFilteredEvaluations(AppraisalFormType? type = null)
    {
        if (currentUserEmployee == null) return Enumerable.Empty<PerformanceEvaluationDto>();

        var userLevel = ParseLevel(currentUserEmployee.LevelId);
        var baseList = type.HasValue ? _evaluations.Where(e => e.FormType == type.Value) : _evaluations;

        // Logic based on requirements:
        // Self-Assessment: L02 – L09
        // Performance Appraisal: L02 – L06
        // 360-Feedback: L02 – L08
        // Calibration/Review: L01 – L04

        return baseList.Where(e => 
            e.EmployeeId == currentUserEmployee.EmployeeId || // I am the subject
            e.Responses.Any(r => r.RespondentId == currentUserEmployee.EmployeeId) || // I am an evaluator
            (e.FormType == AppraisalFormType.PerformanceAppraisal && userLevel <= 6 && IsDirectReport(e.EmployeeId)) || // Manager review (L02-L06)
            (e.FormType == AppraisalFormType.CalibrationReview && userLevel <= 4) || // Senior management calibration (L01-L04)
            (userLevel <= 4) // Senior management sees all
        );
    }

    private bool IsDirectReport(int? employeeId)
    {
        if (!employeeId.HasValue || currentUserEmployee == null) return false;
        
        // Find the employee being evaluated and check their ReportsTo property using the employee list
        var subject = _employees.FirstOrDefault(e => e.EmployeeId == employeeId);
        return subject?.ReportsTo == currentUserEmployee.EmployeeId;
    }

    private bool CanCreateEvaluation(AppraisalFormType type)
    {
        if (currentUserEmployee == null) return false;
        var level = ParseLevel(currentUserEmployee.LevelId);

        return type switch
        {
            AppraisalFormType.SelfAssessment => (level >= 2 && level <= 9),
            AppraisalFormType.PerformanceAppraisal => (level >= 2 && level <= 6),
            AppraisalFormType.Feedback360 => (level >= 2 && level <= 8),
            AppraisalFormType.CalibrationReview => (level >= 1 && level <= 4),
            _ => false
        };
    }

    private bool CanEditEvaluation(PerformanceEvaluationDto eval)
    {
        if (currentUserEmployee == null || eval.Status == PerformanceEvaluationStatus.Finalized) return false;
        
        var level = ParseLevel(currentUserEmployee.LevelId);

        // Subject can edit their self-assessment in Draft
        if (eval.EmployeeId == currentUserEmployee.EmployeeId && eval.Status == PerformanceEvaluationStatus.Draft) 
            return true;

        // Managers (L02-L06) can edit if they are an evaluator or the subject's manager
        if (level <= 6) return true;

        // Senior Management (L01-L04) can edit for calibration
        if (level <= 4 && eval.Status == PerformanceEvaluationStatus.AwaitingCalibration) return true;

        return false;
    }

    private int ParseLevel(string? levelId)
    {
        if (string.IsNullOrEmpty(levelId)) return 99;
        var numericPart = new string(levelId.Where(char.IsDigit).ToArray());
        return int.TryParse(numericPart, out int level) ? level : 99;
    }

    private bool FilterEvaluations(PerformanceEvaluationDto eval) => 
        string.IsNullOrWhiteSpace(_evalSearch) || 
        eval.EmployeeName.Contains(_evalSearch, StringComparison.OrdinalIgnoreCase) ||
        eval.CycleName.Contains(_evalSearch, StringComparison.OrdinalIgnoreCase) ||
        GetTypeName(eval.FormType).Contains(_evalSearch, StringComparison.OrdinalIgnoreCase) ||
        eval.Status.ToString().Contains(_evalSearch, StringComparison.OrdinalIgnoreCase);

    private bool FilterOutcomes(PerformanceOutcomeDto outcome) => 
        string.IsNullOrWhiteSpace(_outcomeSearch) || 
        outcome.EmployeeName.Contains(_outcomeSearch, StringComparison.OrdinalIgnoreCase) ||
        outcome.RecommendationType?.Contains(_outcomeSearch, StringComparison.OrdinalIgnoreCase) == true ||
        outcome.ApprovalStatus?.Contains(_outcomeSearch, StringComparison.OrdinalIgnoreCase) == true;

    private IEnumerable<PerformanceEvaluationDto> GetActionItems()
    {
        if (currentUserEmployee == null) return Enumerable.Empty<PerformanceEvaluationDto>();

        var userLevel = ParseLevel(currentUserEmployee.LevelId);

        return _evaluations.Where(e => 
            (e.EmployeeId == currentUserEmployee.EmployeeId && e.Status == PerformanceEvaluationStatus.Draft) || // My self-assessment to do
            (e.CreatedByEmployeeId == currentUserEmployee.EmployeeId && e.Status == PerformanceEvaluationStatus.SelfSubmitted) || // I created this, employee submitted, I need to check/lock
            (IsDirectReport(e.EmployeeId) && e.Status == PerformanceEvaluationStatus.SelfSubmitted && userLevel <= 6) || // Manager review (L02-L06)
            (userLevel <= 4 && e.Status == PerformanceEvaluationStatus.AwaitingCalibration) || // Senior Management needs to calibrate (L01-L04)
            (e.Responses.Any(r => r.RespondentId == currentUserEmployee.EmployeeId && r.RatingValue == null && e.Status != PerformanceEvaluationStatus.Finalized)) // I am an evaluator but haven't rated yet
        );
    }

    private string GetActionMessage(PerformanceEvaluationDto item)
    {
        if (item.EmployeeId == currentUserEmployee?.EmployeeId && item.Status == PerformanceEvaluationStatus.Draft)
            return $"Complete your Self-Assessment for {item.CycleName}";
        
        if (item.CreatedByEmployeeId == currentUserEmployee?.EmployeeId && item.Status == PerformanceEvaluationStatus.SelfSubmitted)
            return $"Check and Finalize {item.EmployeeName}'s Evaluation";

        if (IsDirectReport(item.EmployeeId) && item.Status == PerformanceEvaluationStatus.SelfSubmitted)
            return $"Review and Appraise {item.EmployeeName}'s Performance";

        if (item.Status == PerformanceEvaluationStatus.AwaitingCalibration)
            return $"Calibrate Performance Score for {item.EmployeeName}";

        return $"Provide feedback for {item.EmployeeName} ({item.FormName})";
    }

    private Color GetEvalStatusColor(PerformanceEvaluationStatus status) => status switch
    {
        PerformanceEvaluationStatus.Draft => Color.Default,
        PerformanceEvaluationStatus.SelfSubmitted => Color.Info,
        PerformanceEvaluationStatus.ManagerReviewed => Color.Primary,
        PerformanceEvaluationStatus.AwaitingCalibration => Color.Warning,
        PerformanceEvaluationStatus.Finalized => Color.Success,
        _ => Color.Default
    };

    private Color GetOutcomeStatusColor(string? status) => status?.ToLower() switch
    {
        "pending" => Color.Warning,
        "requires hr review" => Color.Error,
        "approved" => Color.Success,
        "rejected" => Color.Error,
        _ => Color.Default
    };

    private string GetTypeName(AppraisalFormType type) => type switch
    {
        AppraisalFormType.PerformanceAppraisal => "Performance Appraisal",
        AppraisalFormType.SelfAssessment => "Self Assessment",
        AppraisalFormType.Feedback360 => "360 Feedback",
        AppraisalFormType.CalibrationReview => "Calibration & Review",
        _ => "Unknown"
    };

    // CRUD Handlers
    private async Task OpenEvaluationAddDialog(AppraisalFormType type) => NavigationManager.NavigateTo($"/performanceevaluations/create?type={(int)type}");
    private async Task OpenEvaluationEditDialog(PerformanceEvaluationDto eval) => NavigationManager.NavigateTo($"/performanceevaluations/edit/{eval.EvalId}");
    private void ViewEvaluation(int id) => NavigationManager.NavigateTo($"/performanceevaluations/details/{id}");
    private async Task DeleteEvaluation(int id) => await ConfirmAndDelete(() => EvaluationService.DeletePerformanceEvaluationAsync(id), "Evaluation");

    private async Task OpenOutcomeAddDialog() => NavigationManager.NavigateTo("/performanceoutcomes/create");
    private async Task OpenOutcomeEditDialog(PerformanceOutcomeDto outcome) => NavigationManager.NavigateTo($"/performanceoutcomes/edit/{outcome.OutcomeId}");
    private async Task DeleteOutcome(int id) => await ConfirmAndDelete(() => OutcomeService.DeletePerformanceOutcomeAsync(id), "Outcome");

    private async Task ShowDialog<T>(string title, DialogParameters parameters = null) where T : ComponentBase
    {
        try
        {
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<T>(title, parameters ?? new DialogParameters(), options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled)
            {
                await Task.Delay(200);
                await LoadAllData();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task ConfirmAndDelete(Func<Task<bool>> deleteAction, string entityName)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"Are you sure you want to delete this {entityName}?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = DialogService.Show<EPMS.Blazor.Layout.MessageBox>("Delete Confirmation", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                var success = await deleteAction();
                if (success)
                {
                    Snackbar.Add($"{entityName} deleted successfully!", Severity.Success);
                    await Task.Delay(200);
                    await LoadAllData();
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
