@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@using EPMS.Domain.Enums
@inject IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject IAppraisalCycleBlazorService AppraisalCycleService
@inject IAppraisalFormBlazorService AppraisalFormService
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">
            <MudIcon Icon="@Icons.Material.Filled.GroupAdd" Class="mr-3 mb-n1" Color="Color.Primary" />
            Bulk Start Performance Evaluations
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="request">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Label="Appraisal Cycle" @bind-Value="request.CycleId" Required="true" RequiredError="Cycle is required!" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.EventNote" Class="rounded-lg">
                        @foreach (var cycle in _cycles)
                        {
                            <MudSelectItem Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Label="Appraisal Form" Value="request.FormId" ValueChanged="OnFormChanged" Required="true" RequiredError="Form is required!" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" Class="rounded-lg">
                        @foreach (var formItem in _forms)
                        {
                            <MudSelectItem Value="@formItem.FormId">@formItem.FormName (@GetTypeName(formItem.FormType))</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Select Employees (@_selectedEmployees.Count() selected)</MudText>
                    <MudPaper Outlined="true" Class="pa-2" Style="max-height: 300px; overflow-y: auto;">
                        <MudGrid Spacing="1">
                            <MudItem xs="12" Class="d-flex align-center gap-2 mb-2">
                                <MudTextField @bind-Value="_employeeSearch" Placeholder="Search employees..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                                <MudButton Variant="Variant.Text" OnClick="SelectAll">Select All</MudButton>
                                <MudButton Variant="Variant.Text" OnClick="ClearAll">Clear</MudButton>
                            </MudItem>
                            @foreach (var emp in GetFilteredEmployees())
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudCheckBox T="bool" Value="@IsSelected(emp.EmployeeId)" ValueChanged="@((v) => ToggleEmployee(emp.EmployeeId, v))" Label="@emp.FullName" Dense="true" Color="Color.Primary" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary" Class="rounded-lg px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="rounded-lg px-8 ml-2" Disabled="@(!_selectedEmployees.Any())">Start Evaluations</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private BulkPerformanceEvaluationRequest request = new();
    private List<AppraisalCycleDto> _cycles = new();
    private List<AppraisalFormDto> _forms = new();
    private List<EmployeeDto> _employees = new();
    private EmployeeDto? _currentUserEmployee;
    private HashSet<int> _selectedEmployees = new();
    private string _employeeSearch = "";
    private MudForm form = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var empIdClaim = user.FindFirst("EmployeeId")?.Value;

            var cyclesTask = AppraisalCycleService.GetAllAppraisalCyclesAsync();
            var formsTask = AppraisalFormService.GetAllAppraisalFormsAsync();
            var employeesTask = EmployeeService.GetEmployeesAsync();

            await Task.WhenAll(cyclesTask, formsTask, employeesTask);

            _cycles = (await cyclesTask).ToList();
            _forms = (await formsTask).Where(f => f.IsActive == true).ToList();
            _employees = (await employeesTask).ToList();

            if (int.TryParse(empIdClaim, out int empId))
            {
                _currentUserEmployee = _employees.FirstOrDefault(e => e.EmployeeId == empId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private IEnumerable<EmployeeDto> GetFilteredEmployees()
    {
        if (_currentUserEmployee == null) return Enumerable.Empty<EmployeeDto>();

        var userLevel = ParseLevel(_currentUserEmployee.LevelId);
        var selectedForm = _forms.FirstOrDefault(f => f.FormId == request.FormId);

        IEnumerable<EmployeeDto> baseList = _employees;

        if (selectedForm != null)
        {
            baseList = selectedForm.FormType switch
            {
                AppraisalFormType.SelfAssessment => 
                    // Managers (L02-L06) can start for direct reports + self
                    (userLevel >= 2 && userLevel <= 6)
                        ? _employees.Where(e => e.EmployeeId == _currentUserEmployee.EmployeeId || e.ReportsTo == _currentUserEmployee.EmployeeId)
                        : _employees.Where(e => e.EmployeeId == _currentUserEmployee.EmployeeId),

                AppraisalFormType.PerformanceAppraisal => 
                    // Managers (L02-L06) can start for direct reports
                    (userLevel >= 2 && userLevel <= 6)
                        ? _employees.Where(e => e.ReportsTo == _currentUserEmployee.EmployeeId)
                        : (userLevel <= 4 ? _employees : Enumerable.Empty<EmployeeDto>()),

                AppraisalFormType.CalibrationReview =>
                    // Senior Management (L01-L04) can see all
                    (userLevel <= 4) ? _employees : Enumerable.Empty<EmployeeDto>(),

                _ => _employees
            };
        }

        if (string.IsNullOrWhiteSpace(_employeeSearch)) return baseList;
        return baseList.Where(e => e.FullName.Contains(_employeeSearch, StringComparison.OrdinalIgnoreCase));
    }

    private int ParseLevel(string? levelId)
    {
        if (string.IsNullOrEmpty(levelId)) return 99;
        var numericPart = new string(levelId.Where(char.IsDigit).ToArray());
        return int.TryParse(numericPart, out int level) ? level : 99;
    }

    private bool IsSelected(int id) => _selectedEmployees.Contains(id);

    private void ToggleEmployee(int id, bool selected)
    {
        if (selected) _selectedEmployees.Add(id);
        else _selectedEmployees.Remove(id);
    }

    private void OnFormChanged(int formId)
    {
        request.FormId = formId;
        _selectedEmployees.Clear();
        StateHasChanged();
    }

    private void SelectAll()
    {
        foreach (var emp in GetFilteredEmployees())
        {
            _selectedEmployees.Add(emp.EmployeeId);
        }
    }

    private void ClearAll() => _selectedEmployees.Clear();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid && _selectedEmployees.Any())
        {
            try
            {
                request.EmployeeIds = _selectedEmployees.ToList();
                var count = await PerformanceEvaluationService.CreateBulkPerformanceEvaluationsAsync(request);
                Snackbar.Add($"{count} evaluations started successfully!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private string GetTypeName(AppraisalFormType type) => type switch
    {
        AppraisalFormType.PerformanceAppraisal => "Performance Appraisal",
        AppraisalFormType.SelfAssessment => "Self Assessment",
        AppraisalFormType.Feedback360 => "360 Feedback",
        AppraisalFormType.CalibrationReview => "Calibration & Review",
        _ => "Performance Evaluation"
    };

    private void Cancel() => MudDialog.Cancel();
}
