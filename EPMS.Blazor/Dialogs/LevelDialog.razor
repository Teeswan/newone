@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@inject ILevelBlazorService LevelService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Grade)" Class="mr-3 mb-n1" Color="@(IsEdit ? Color.Warning : Color.Primary)" />
            @(IsEdit ? "Update Level" : "Create New Level")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="request">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="request.LevelId" 
                                  Label="Level ID" 
                                  Placeholder="e.g., L-01, MG-1"
                                  HelperText="Unique identifier for this level"
                                  Required="true" 
                                  RequiredError="Level ID is required!" 
                                  Validation="@(new Func<string, string?>(ValidateLevelId))"
                                  Variant="Variant.Outlined" 
                                  Immediate="true"
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Badge" 
                                  Class="rounded-lg" 
                                  Disabled="@IsEdit" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="request.LevelName" 
                                  Label="Level Name" 
                                  Placeholder="e.g., Junior, Senior, Manager"
                                  HelperText="Descriptive name of the level"
                                  Required="true" 
                                  RequiredError="Level name is required!" 
                                  Validation="@(new Func<string, string?>(ValidateLevelName))"
                                  Variant="Variant.Outlined" 
                                  Immediate="true"
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Grade" 
                                  Class="rounded-lg" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="request.LevelDescription" 
                                  Label="Description" 
                                  Placeholder="Describe the responsibilities or requirements for this level..."
                                  HelperText="Detailed information about this level"
                                  Variant="Variant.Outlined" 
                                  Lines="3" 
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Description" 
                                  Class="rounded-lg" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="request.IsActive" Label="Level is Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary" Class="rounded-lg px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="rounded-lg px-8 ml-2">@(IsEdit ? "Update" : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string? Id { get; set; }
    private bool IsEdit => !string.IsNullOrEmpty(Id);

    private CreateLevelRequest request = new();
    private MudForm form = null!;

    private string? ValidateLevelId(string id)
    {
        if (string.IsNullOrWhiteSpace(id)) return "Level ID is required";
        if (id.Length > 10) return "Level ID must not exceed 10 characters";
        return null;
    }

    private string? ValidateLevelName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "Level name is required";
        if (name.Length > 100) return "Level name must not exceed 100 characters";
        return null;
    }

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var level = await LevelService.GetLevelByIdAsync(Id!);
            if (level != null)
            {
                request = new CreateLevelRequest
                {
                    LevelId = level.LevelId,
                    LevelName = level.LevelName,
                    LevelDescription = level.LevelDescription,
                    IsActive = level.IsActive
                };
            }
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                if (IsEdit)
                {
                    var updateRequest = new UpdateLevelRequest
                    {
                        LevelName = request.LevelName,
                        LevelDescription = request.LevelDescription,
                        IsActive = request.IsActive
                    };
                    await LevelService.UpdateLevelAsync(Id!, updateRequest);
                    Snackbar.Add("Level updated successfully!", Severity.Success);
                }
                else
                {
                    await LevelService.CreateLevelAsync(request);
                    Snackbar.Add("Level created successfully!", Severity.Success);
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                await DialogService.ShowMessageBox(
                    "Error", 
                    (MarkupString)$"<b>Operation failed:</b><br />{ex.Message}", 
                    yesText: "OK");
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
