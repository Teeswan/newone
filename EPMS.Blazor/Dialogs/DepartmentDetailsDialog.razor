@using EPMS.Shared.DTOs

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center py-2">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-4">
                <MudIcon Icon="@Icons.Material.Filled.Business" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h5" Style="font-weight: 800; color: #111827;">@Department.DepartmentName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Department Configuration Details</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudDivider Class="mb-6" />
        
        <div class="px-2">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Style="font-weight: 700;">Department Code</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@(string.IsNullOrEmpty(Department.DepartmentIdName) ? "N/A" : Department.DepartmentIdName)</MudText>
                </MudItem>
                
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Style="font-weight: 700;">Current Status</MudText>
                    <div>
                        <MudChip T="string" Size="Size.Small" 
                                 Color="@(Department.IsActive ? Color.Success : Color.Error)" 
                                 Variant="Variant.Filled" 
                                 Class="ma-0 px-4">
                            @(Department.IsActive ? "ACTIVE" : "INACTIVE")
                        </MudChip>
                    </div>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Style="font-weight: 700;">Parent Department</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@(string.IsNullOrEmpty(Department.ParentDepartmentName) ? "None (Top Level)" : Department.ParentDepartmentName)</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Style="font-weight: 700;">System ID</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">#@Department.DepartmentId</MudText>
                </MudItem>
            </MudGrid>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-4 pb-4 w-100 d-flex justify-end">
            <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Default" Class="rounded-lg px-8 py-2" Style="text-transform: none; font-weight: 600;">
                Dismiss
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DepartmentDto Department { get; set; } = null!;

    private void Close() => MudDialog.Close();
}
