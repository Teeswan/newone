@using EPMS.Shared.DTOs
@using EPMS.Blazor.Services
@using EPMS.Domain.Enums
@inject IEmployeeKpiBlazorService EmpKpiService
@inject IAppraisalCycleBlazorService CycleService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-3 mb-n1" />
            KPI Performance Calculation
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="mb-4">
            <MudSelect T="int" Label="Select Appraisal Cycle" @bind-Value="_cycleId" 
                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                       SelectedValuesChanged="OnCycleChanged">
                @foreach (var cycle in _cycles)
                {
                    <MudSelectItem Value="@cycle.CycleId">@cycle.CycleName</MudSelectItem>
                }
            </MudSelect>
        </div>

        @if (_loading)
        {
            <div class="d-flex justify-center my-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_summary != null)
        {
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="background-color: var(--mud-palette-background-grey); border-radius: 12px;">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Performance Score</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_summary.TotalPerformanceScore.ToString("N2")</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Rating & Label</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5" Style="font-weight: 600;">@_summary.Rating</MudText>
                            <MudChip T="string" Color="@GetRatingColor(_summary.Rating)" Size="Size.Small" Variant="Variant.Filled">
                                @_summary.PerformanceLabel
                            </MudChip>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudTable Items="@_summary.Assignments" Hover="true" Bordered="false" Striped="true" Elevation="0" 
                      Dense="true" Class="mt-2" T="EmployeeKpiAssignmentDto">
                <HeaderContent>
                    <MudTh>KPI Name</MudTh>
                    <MudTh>Ver</MudTh>
                    <MudTh>Weight</MudTh>
                    <MudTh>Target</MudTh>
                    <MudTh>Actual</MudTh>
                    <MudTh>Score (%)</MudTh>
                    <MudTh>Weighted</MudTh>
                </HeaderContent>
                <RowTemplate Context="item">
                    <MudTd DataLabel="KPI Name">@item.KpiNameSnapshot</MudTd>
                    <MudTd DataLabel="Ver">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@($"V{item.VersionNo}")</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Weight">@item.WeightPercent%</MudTd>
                    <MudTd DataLabel="Target">@item.TargetValue</MudTd>
                    <MudTd DataLabel="Actual">@(item.ActualValue?.ToString() ?? "-")</MudTd>
                    <MudTd DataLabel="Score (%)">
                        <MudText Color="@GetScoreColor(item.KpiScore ?? 0)" Style="font-weight: 600;">
                            @(item.KpiScore?.ToString("N2") ?? "0.00")%
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Weighted">@(item.WeightedScore?.ToString("N2") ?? "0.00")</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else if (_cycleId > 0 && !_loading)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">No KPI assignments found for this cycle.</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Close</MudButton>
        <MudButton Color="Color.Primary" OnClick="LoadCalculation" StartIcon="@Icons.Material.Filled.Refresh" 
                   Disabled="@(_cycleId <= 0 || _loading)">Recalculate</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int EmployeeId { get; set; }

    private int _cycleId;
    private IEnumerable<AppraisalCycleDto> _cycles = new List<AppraisalCycleDto>();
    private KpiScoreSummaryDto? _summary;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _cycles = await CycleService.GetAllAppraisalCyclesAsync();
            if (_cycles.Any())
            {
                _cycleId = _cycles.First().CycleId;
                await LoadCalculation();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnCycleChanged()
    {
        await LoadCalculation();
    }

    private async Task LoadCalculation()
    {
        if (_cycleId <= 0) return;

        _loading = true;
        try
        {
            _summary = await EmpKpiService.GetScoreSummaryAsync(EmployeeId, _cycleId);
            if (_summary != null)
            {
                // Ensure assignments are loaded as they might not be part of the summary if not explicitly included
                var assignments = await EmpKpiService.GetAssignmentsAsync(EmployeeId, _cycleId);
                _summary.Assignments = assignments.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error calculating KPIs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetRatingColor(int rating) => rating switch
    {
        5 => Color.Success,
        4 => Color.Info,
        3 => Color.Warning,
        2 => Color.Error,
        1 => Color.Error,
        _ => Color.Default
    };

    private Color GetScoreColor(decimal score)
    {
        if (score >= 90) return Color.Success;
        if (score >= 70) return Color.Info;
        if (score >= 50) return Color.Warning;
        return Color.Error;
    }

    private void Close() => MudDialog.Close();
}