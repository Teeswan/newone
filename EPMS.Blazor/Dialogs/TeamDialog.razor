@using EPMS.Shared.DTOs
@using EPMS.Shared.Requests
@using EPMS.Blazor.Services
@inject ITeamBlazorService TeamService
@inject IDepartmentBlazorService DepartmentService
@inject IEmployeeBlazorService EmployeeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">
            <MudIcon Icon="@(Id.HasValue ? Icons.Material.Filled.Edit : Icons.Material.Filled.Groups)" Class="mr-3 mb-n1" Color="@(Id.HasValue ? Color.Warning : Color.Primary)" />
            @(Id.HasValue ? "Update Team" : "Create New Team")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="request">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="request.TeamName" 
                                  Label="Team Name" 
                                  Placeholder="e.g., Development Team, Sales Hub"
                                  HelperText="The descriptive name of the team"
                                  Required="true" 
                                  RequiredError="Team name is required!" 
                                  Validation="@(new Func<string, string?>(ValidateTeamName))"
                                  Variant="Variant.Outlined" 
                                  Immediate="true"
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Groups" 
                                  Class="rounded-lg" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="request.TeamIdName" 
                                  Label="Team ID/Code" 
                                  Placeholder="e.g., DEV-01, MKT-A"
                                  HelperText="Unique identifier or short code"
                                  Validation="@(new Func<string, string?>(ValidateTeamCode))"
                                  Variant="Variant.Outlined" 
                                  Immediate="true"
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Badge" 
                                  Class="rounded-lg" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="request.DepartmentId" 
                               Label="Department" 
                               Placeholder="Select the parent department"
                               HelperText="The department this team belongs to"
                               Variant="Variant.Outlined" 
                               T="int?" 
                               Adornment="Adornment.Start" 
                               AdornmentIcon="@Icons.Material.Filled.Business" 
                               Class="rounded-lg" 
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select Department</MudSelectItem>
                        @foreach (var dept in allDepartments)
                        {
                            <MudSelectItem T="int?" Value="@((int?)dept.DepartmentId)">@dept.DepartmentName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="request.ManagerId" 
                               Label="Team Manager" 
                               Placeholder="Assign a manager"
                               HelperText="The person leading this team"
                               Variant="Variant.Outlined" 
                               T="int?" 
                               Adornment="Adornment.Start" 
                               AdornmentIcon="@Icons.Material.Filled.Person" 
                               Class="rounded-lg" 
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select Manager</MudSelectItem>
                        @foreach (var emp in allEmployees)
                        {
                            <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="request.IsActive" Label="Team is Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary" Class="rounded-lg px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="rounded-lg px-8 ml-2">@(Id.HasValue ? "Update" : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int? Id { get; set; }
    [Parameter] public int? DefaultDepartmentId { get; set; }

    private UpdateTeamRequest request = new() { IsActive = true };
    private List<DepartmentDto> allDepartments = new();
    private List<EmployeeDto> allEmployees = new();
    private MudForm form = null!;

    private string? ValidateTeamName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "Team name is required";
        if (name.Length > 100) return "Team name must not exceed 100 characters";
        return null;
    }

    private string? ValidateTeamCode(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return null; // Optional
        if (code.Length > 20) return "Team code must not exceed 20 characters";
        return null;
    }

    protected override async Task OnInitializedAsync()
    {
        allDepartments = (await DepartmentService.GetAllDepartmentsAsync()).ToList();
        allEmployees = await EmployeeService.GetEmployeesAsync();
        
        if (Id.HasValue)
        {
            var team = await TeamService.GetTeamByIdAsync(Id.Value);
            if (team != null)
            {
                request = new UpdateTeamRequest
                {
                    TeamName = team.TeamName,
                    TeamIdName = team.TeamIdName,
                    DepartmentId = team.DepartmentId,
                    ManagerId = team.ManagerId,
                    IsActive = team.IsActive
                };
            }
        }
        else if (DefaultDepartmentId.HasValue)
        {
            request.DepartmentId = DefaultDepartmentId.Value;
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                if (Id.HasValue)
                {
                    await TeamService.UpdateTeamAsync(Id.Value, request);
                    Snackbar.Add("Team updated successfully!", Severity.Success);
                }
                else
                {
                    var createRequest = new CreateTeamRequest
                    {
                        TeamName = request.TeamName,
                        TeamIdName = request.TeamIdName,
                        DepartmentId = request.DepartmentId,
                        ManagerId = request.ManagerId,
                        IsActive = request.IsActive
                    };
                    await TeamService.CreateTeamAsync(createRequest);
                    Snackbar.Add("Team created successfully!", Severity.Success);
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                await DialogService.ShowMessageBox(
                    "Error", 
                    (MarkupString)$"<b>Operation failed:</b><br />{ex.Message}", 
                    yesText: "OK");
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
