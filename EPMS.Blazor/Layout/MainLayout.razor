@inherits LayoutComponentBase
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components.Authorization
@using EPMS.Client.Identity
@using EPMS.Blazor.Services
@using EPMS.Shared.DTOs
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationBlazorService NotificationService
@inject IEmployeeBlazorService EmployeeService
@inject ICurrentEmployeeStateService CurrentEmployeeState

<style>
    .main-layout, .mud-layout {
        height: 100% !important;
    }
</style>

<MudThemeProvider />
<MudLayout Class="main-layout">
    <MudAppBar Elevation="1" Color="Color.Primary">
        @if (!IsLoginPage)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        }
        <div class="d-flex align-items-center">
            <MudAvatar Color="@(IsLoginPage ? Color.Inherit : Color.Secondary)" Size="Size.Medium" Class="mr-3">
                <MudIcon Icon="@Icons.Material.Filled.Insights" Size="Size.Medium" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h6" Color="Color.Inherit" Class="fw-bold">Employee Performance Management System</MudText>
            </div>
        </div>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="mr-4">
                    <ActivatorContent>
                        <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)">
                            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
                        </MudBadge>
                    </ActivatorContent>
                    <ChildContent>
                        <MudText Typo="Typo.subtitle2" Class="px-4 py-2">Notifications</MudText>
                        <MudDivider />
                        @if (_notifications == null || !_notifications.Any())
                        {
                            <MudMenuItem>No new notifications</MudMenuItem>
                        }
                        else
                        {
                            @foreach (var notification in _notifications.Take(5))
                            {
                                <MudMenuItem OnClick="@(() => HandleNotificationClick(notification))">
                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body2" Color="@(notification.IsRead == true ? Color.Default : Color.Primary)">@notification.Title</MudText>
                                        <MudText Typo="Typo.caption">@notification.CreatedAt?.ToString("g")</MudText>
                                    </div>
                                </MudMenuItem>
                            }
                        }
                        <MudDivider />
                        <MudMenuItem Href="/notifications" Class="text-center">View All</MudMenuItem>
                    </ChildContent>
                </MudMenu>
                
                <!-- Profile Avatar -->
                <MudMenu Class="mr-4">
                    <ActivatorContent>
                        <MudAvatar Color="Color.Secondary" Size="Size.Medium" Class="cursor-pointer">
                            @if (CurrentEmployeeState.CurrentEmployee?.ProfilePicture != null && CurrentEmployeeState.CurrentEmployee.ProfilePicture.Length > 0)
                            {
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(CurrentEmployeeState.CurrentEmployee.ProfilePicture)"
                                     alt="Profile"
                                     style="width: 100%; height: 100%; object-fit: cover; object-position: center;" />
                            }
                            else
                            {
                                <MudText Typo="Typo.h6" Style="color: var(--mud-palette-secondary-text);">
                                    @GetFirstLetter(CurrentEmployeeState.CurrentEmployee?.FullName ?? context.User.Identity?.Name)
                                </MudText>
                            }
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Href="/profile">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-3" />
                            My Profile
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem OnClick="HandleLogout">
                            <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-3" />
                            Logout
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
                
                
            </Authorized>
            <NotAuthorized>
                @if (!IsLoginPage)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Href="/login" StartIcon="@Icons.Material.Filled.Login">
                        Login
                    </MudButton>
                }
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @if (!IsLoginPage)
    {
        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="4">
            <NavMenu CloseDrawer="() => _drawerOpen = false" />
        </MudDrawer>
    }

    <MudMainContent Class="@(IsLoginPage ? "mt-16" : "mt-16 pa-8")" Style="@(IsLoginPage ? "height: calc(100% - 64px); padding: 0;" : "")">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool IsLoginPage => Navigation.Uri.Contains("/login");
    private List<NotificationDto> _notifications = new();
    private int _unreadCount = 0;
    private int? _userId;
    private bool _disposed;

    private string GetFirstLetter(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
        {
            return "?";
        }
        return fullName.TrimStart().Substring(0, 1).ToUpper();
    }

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to current employee changes
        CurrentEmployeeState.CurrentEmployeeChanged += OnCurrentEmployeeChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst("UserId") ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
            {
                _userId = userId;
                await LoadNotifications();
                await LoadCurrentEmployee();
            }
        }
    }

    private async Task LoadNotifications()
    {
        if (_userId.HasValue)
        {
            _notifications = await NotificationService.GetUserNotificationsAsync(_userId.Value);
            _unreadCount = await NotificationService.GetUnreadCountAsync(_userId.Value);
            StateHasChanged();
        }
    }

    private async Task LoadCurrentEmployee()
    {
        try
        {
            var loginResponse = await LocalStorage.GetItemAsync<LoginResponseDto>("loginResponse");
            if (loginResponse != null)
            {
                // Always load fresh employee data when logging in (in case new user)
                var employee = await EmployeeService.GetEmployeeDetailsAsync(loginResponse.EmployeeId);
                if (employee != null)
                {
                    CurrentEmployeeState.SetCurrentEmployee(employee);
                }
            }
        }
        catch
        {
            // Ignore errors
        }
    }

    private void OnCurrentEmployeeChanged()
    {
        InvokeAsync(() => StateHasChanged());
    }

    private async Task HandleNotificationClick(NotificationDto notification)
    {
        if (notification.IsRead != true)
        {
            await NotificationService.MarkAsReadAsync(notification.NotificationId);
            await LoadNotifications();
        }

        // Navigate based on type
        if (notification.RelatedEntityId.HasValue)
        {
            if (notification.Type == "PerformanceEvaluation" || notification.Type == "360Feedback")
            {
                Navigation.NavigateTo($"/performance-evaluations/edit/{notification.RelatedEntityId.Value}");
            }
        }
    }

    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await LocalStorage.RemoveItemAsync("loginResponse");
        CurrentEmployeeState.ClearCurrentEmployee();
        Dispose();
        ((JwtAuthenticationStateProvider)AuthStateProvider).NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        if (!_disposed)
        {
            CurrentEmployeeState.CurrentEmployeeChanged -= OnCurrentEmployeeChanged;
            _disposed = true;
        }
    }
}
