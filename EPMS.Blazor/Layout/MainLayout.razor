@inherits LayoutComponentBase
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components.Authorization
@using EPMS.Client.Identity
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider

<MudLayout>
    <MudAppBar Elevation="4">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Class="ml-4" Typo="Typo.h6" Color="Color.Inherit">EPMS - Employee Performance Management System</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-4" Color="Color.Inherit">Welcome, @context.User.Identity?.Name!</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="HandleLogout">
                    <MudIcon Class="mr-2" Icon="@Icons.Material.Filled.Logout" /> Logout
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">
                    <MudIcon Class="mr-2" Icon="@Icons.Material.Filled.Login" /> Login
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu CloseDrawer="() => _drawerOpen = false" />
    </MudDrawer>

    <MudMainContent Class="mt-16 pa-6">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        ((JwtAuthenticationStateProvider)AuthStateProvider).NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
