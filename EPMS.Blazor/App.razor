<CascadingAuthenticationState>
    <MudThemeProvider />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated == true)
                    {
                        <MudPaper Class="mt-20 mx-auto" Elevation="3" MaxWidth="MaxWidth.Small">
                            <MudContainer Class="pa-8">
                                <MudText GutterBottom="true" Typo="Typo.h5" Color="Color.Error" Align="Align.Center">
                                    Access Denied
                                </MudText>
                                <MudText Align="Align.Center" Class="mb-6">
                                    You do not have permission to view this page.
                                </MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/">
                                    Go to Home
                                </MudButton>
                            </MudContainer>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="mt-20 mx-auto" Elevation="3" MaxWidth="MaxWidth.Small">
                            <MudContainer Class="pa-8">
                                <MudText GutterBottom="true" Typo="Typo.h5" Color="Color.Error" Align="Align.Center">
                                    Access Denied
                                </MudText>
                                <MudText Align="Align.Center" Class="mb-6">
                                    Please log in to continue.
                                </MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/login">
                                    Go to Login Page
                                </MudButton>
                            </MudContainer>
                        </MudPaper>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText GutterBottom="true" Typo="Typo.h5">
                    Sorry, there's nothing at this address.
                </MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
